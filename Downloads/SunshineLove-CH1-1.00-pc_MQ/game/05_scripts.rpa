label lb_w3mow_mc_c_talk:
    #     Week 3 (MOW)  Scene 31 - MC and Cousin talk in the pool area"
    if _in_replay:
        if y_name == None:
            $ y_name = "MC"
        else:
            $ y_name = persistent.y_name

        if s_name == None:
            $ s_name = "S"
        else:
            $ s_name = persistent.s_name

        if c_name == None:
            $ c_name = "Shortcake"
        else:
            $ c_name = persistent.c_name

        show screen toprightmenu
        play music "music/01/2936-fliegen-by-sascha-ende.mp3"
    scene sc w3cevening c01
    with dissolve
    play ambient "sound effects/01/00/soft_ocean_waves.mp3" fadein 1.0
    mc"(So‚Ä¶ It‚Äôs just me and [c_name] again, alone‚Ä¶)"
    show sc w3cevening c02
    c"I sure hope Connie will be okay."
    c"She looked really upset. Her father sounds like a real jerk, huh?"
    mc"It seems that way."
    show sc w3cevening c01
    mc"By the way, did you mean what you said before?"
    show sc w3cevening c05
    c"About what exactly?"
    show sc w3cevening c01
    mc"About being able to get over not knowing who your real father was a long time ago?"
    show sc w3cevening c08
    c"Oh, that..."
    c"Yeah, I don‚Äôt think about him much at all."
    c"He was never a part of my life so that has made things easier."
    show sc w3cevening c02
    mc"Do you ever wish you had a father around when you were growing up?"
    c"Sometimes. But I think my Mom and I have done just fine without him."
    show sc w3cevening c08
    c"A part of me wishes I had some kind of male influence when I was younger, like a Dad or even an older brother..."
    show sc w3cevening c03
    c"But I did pretty darn good through high school without having either."
    mc"Good for you [c_name]."
    show sc w3cevening c01
    mc"Sometimes having a father around isn‚Äôt all it‚Äôs cracked up to be."
    mc"My Dad was hardly ever home, and I ended up having a better relationship with Rosa, our maid, than I did with him."
    mc"And nothing changed before and even after Ashley and [s_name] moved in with us."
    mc"I think it‚Äôs fair to say that women have had a bigger influence on my life than my Dad has."
    show sc w3cevening c06
    c"Really?"
    show sc w3cevening c01
    mc"Yeah. It‚Äôs probably why I find it easy to talk to females, thanks to my upbringing."
    show sc w3cevening c08
    c"Do you find it easy to talk to me?"
    show sc w3cevening c01
    mc"Yeah. Well, most of the time."
    show sc w3cevening c02
    c"Is there anything you find hard to talk about with me?"
    mc"(Sigh‚Ä¶ Maybe now is the time to bring up that kiss the other night.)"
    mc"(At least if I do so now, then I‚Äôm also being honest with [c_name].)"
    show sc w3cevening c01
    mc"Well, maybe there‚Äôs one thing."
    c"And that is?"
    mc"Do you remember the other night, when you and I were sitting by the pool at the hotel?"
    show sc w3cevening c08
    c"Oh, right‚Ä¶"
    mc"(Hmm‚Ä¶)"
    mc"(We didn‚Äôt talk about it during our walk along the beach, but maybe I could quickly discuss it with her now, before [s_name] comes back.)"
    show sc w3cevening c02
    mc"I‚Äôve been wanting to talk to you about what happened [c_name] but it‚Äôs been kind of hard to..."
    mc"Especially because it‚Äôs been a stressful few days, not knowing where [s_name] was, and then having to look after Connie. But it has been on my mind."
    mc"Has it been on yours?"
    show sc w3cevening c08
    c"Yeah, it has."
    c"I felt very anxious every time I wanted to talk to you about it today."
    c"Even when we went for a walk along the beach earlier, I wanted to bring it up, but I got too nervous."
    c"And I was really hoping you would say something so I wouldn‚Äôt have to."
    mc"Oh‚Ä¶"
    show sc w3cevening c02
    mc"(Damn! I knew I should‚Äôve gone with my gut instinct.)"
    show sc w3cevening c08
    c"As you know, it was my first kiss..."
    c"But the truth is I don‚Äôt really remember it all that well, because of how much I had to drink and how tired I was that night."
    mc"I see‚Ä¶"
    show sc w3cevening c02
    mc"So your first kiss wasn‚Äôt what you hoped it would be?"
    c"No, I didn‚Äôt mean for that to sound like I regretted it."
    show sc w3cevening c09
    c"I uh, I liked it [y_name], a lot."
    show sc w3cevening c07
    c"And I was figuring, that if you were so inclined, that maybe we could do it again‚Ä¶"
    # (screen shakes)"
    show sc w3cevening c01
    mc"Oh! Are you sure?"
    show sc w3cevening c04
    c"Yeah, most definitely."
    show sc w3cevening c03
    c"That way, I‚Äôll definitely remember everything about it this time."
    c"I‚Äôm not as tired or intoxicated as I was the other night."
    # [Kiss her / Maybe we shouldn‚Äôt]"
    menu:
        "Kiss her"(wt="You will continue on the [c_name] path") if v_w3mow_c_date:
            $ v_w3_c_path = True
            # (MC and cousin look at each other - their faces in the same shot on screen)"
            show sc w3cevening c01
            mc"Okay, are you ready [c_name]?"
            show sc w3cevening c09
            c"Yeah, I am."
            # (slow motion animation of the MC moving in to kiss cousin)"
            show sc w3cevening c18
            mc"(She looks even more gorgeous under the pale moonlight. Here goes nothing...)"
            play sound "sound effects/01/00/FEMALE_MOAN_KISS_BREATHING_Sound_FX.mp3" loop
            if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
                window hide
                scene ani_05_c_kiss1:
                    size (config.screen_width, config.screen_height)
                pause
                window show
            else:
                show sc w3cevening c19
            c"(Mmm‚Ä¶ Oh my! So this is what it feels like to have butterflies in my stomach!)"
            $ c_points = change_stat(c_points,3,c_name)
            mc"(Oh wow‚Ä¶ This feels even more amazing than when we kissed the other night.)" #+3 COUSIN POINTS"
            # (Sound effect - kissing and moaning mp3 to be added here)"
            c"(I can feel my heart beating faster than ever before.)"
            c"(My whole body is vibrating...)"
            c"(I really don‚Äôt want this kiss to stop, but we should before one of the girls sees us like this.)"
            # (Cousin pulls back from the kiss, eyes still closed)"
            stop sound fadeout 1.0
            show sc w3cevening c20
            c"Wow‚Ä¶"
            mc"Yeah, that‚Äôs what I was thinking."
            show sc w3cevening c02
            c"Sorry for stopping you [y_name], I was just worried that [s_name] or Connie might see us."
            mc"Yeah, it‚Äôs probably best that we stopped."
            show sc w3cevening c08
            c"But, do you think we could do that again?"
            show sc w3cevening c01
            mc"Of course we can, but not now. I think it‚Äôs best that we try this again some other time."
            show sc w3cevening c09
            c"Sounds good."
            c"(I already can‚Äôt wait to have some time alone with [y_name] again. It's going to be so difficult having to wait...)"
            show sc w3cevening c01
            mc"I think [s_name] is coming this way."
            # (MC looks at cousin)"
            mc"Let‚Äôs keep this between us for now [c_name]. It could be our own little secret."
            show sc w3cevening c03
            c"Yeah, I like that idea."
        "Maybe we shouldn‚Äôt"(wt="The [c_name] path is now CLOSED"):
            $ v_w3_c_path = False
            show sc w3cevening c01
            mc"Uh, maybe we shouldn‚Äôt [c_name]. It‚Äôs probably not a good idea."
            show sc w3cevening c08
            c"Why not?"
            show sc w3cevening c02
            mc"You know, because of Connie and [s_name]."
            show sc w3cevening c06
            $ c_points = change_stat(c_points,-3,c_name)
            c"(Why is [y_name] deliberating with this? Does he not want to kiss me?)" #-3 COUSIN POINTS"
            show sc w3cevening c01
            mc"I think [s_name] is coming this way."
            show sc w3cevening c06
            c"(Sigh‚Ä¶ I guess that kiss last night was just a one-off.)"
            c"(I can‚Äôt help but be a little disappointed with [y_name]...)"
            c"(But it would be awkward if something serious started between us and [s_name] found out about it.)"
            c"(It‚Äôs easier if I just let things be, and pretended like nothing happened‚Ä¶)"

    stop ambient fadeout 1.0
    # (Cousin smiles)"
    # (S returns)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w3cevening c15
    with dissolve
    play ambient "sound effects/01/00/soft_ocean_waves.mp3" fadein 1.0
    s"Hey guys."
    show sc w3cevening c14
    mc"So, is everything okay with Connie?"
    show sc w3cevening c15
    s"It took me a while to calm her down, but I think she‚Äôll be fine."
    show sc w3cevening c14
    s"She said she‚Äôs going to have an early night and go to bed shortly."
    show sc w3cevening c17
    s"(I think I should talk to [y_name] about Connie‚Äôs father when [c_name] isn‚Äôt around.)"
    show sc w3cevening c14
    s"So what have you two been up to?"
    mc"Uh, just talking, drinking some more wine. Just relaxing in general."
    if v_w3_c_path:
        show sc w3cevening c12
        c"(Oh boy‚Ä¶ I‚Äôm wide awake after that kiss with [y_name]...)"
        c"(But the longer I stay here, the more I feel like [s_name] will figure out what [y_name] and I did.)"
    show sc w3cevening c11
    c"Excuse me guys, I‚Äôm starting to feel pretty tired as well."
    show sc w3cevening c10
    c"It‚Äôs probably from being out in the sun and having that last glass of wine."
    c"I‚Äôm sorry, but I‚Äôm going to say goodnight as well."
    show sc w3cevening c16
    s"Oh, is everything okay [c_name]?"
    show sc w3cevening c13
    c"Yeah, I‚Äôm fine, I promise. Night guys!"
    # (Cousin leaves)"
    show sc w3cevening c16
    s"Night [c_name]!"
    # (S turns to the MC)"
    show sc w3cevening c14
    s"Well that was strange, don‚Äôt you think [y_name]?"
    mc"Yeah, maybe a little."
    mc"But perhaps [c_name] really is tired. I mean, it‚Äôs been a long day for all of us."
    s"Yeah, I guess so."
    mc"(I get the feeling that [c_name] was worried that she may not have been able to keep our secret, and that's why she decided to bail.)"
    show sc w3cevening c14
    s"So I was wondering, are you going to stay up for a little while longer?"
    show sc w3cevening c15
    s"I thought that maybe we could discuss a few things."
    mc"Yeah, I‚Äôm good for another half an hour at least."
    s"Great! Let‚Äôs head inside, shall we?"
    stop ambient fadeout 1.0
    if _in_replay:
        scene black
        with dissolve
