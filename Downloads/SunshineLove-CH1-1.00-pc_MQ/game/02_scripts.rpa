    mc"Yeah. We should get out of here as soon as the old man heads back inside, just in case he does use his dog to try and locate us."
    show sc day3doghouse d141
    c"(OH! I think I can feel [y_name]‚Äôs thing against my‚Ä¶)"
    #(final shot is the MC‚Äôs crotch against cousin‚Äôs ass)"
    # (screen goes blank)"
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (Cousin and the MC stand somewhere away from the house)"
    scene sc day3doghouse d101
    with dissolve
    mc"All right, here are the documents for Trisha. Looks like you‚Äôre all set." #+2 TRISHA POINTS"
    show sc day3doghouse d100
    c"I cannot thank you enough [y_name]. But I don‚Äôt know if what you did was incredibly brave, or incredibly stupid!"
    show sc day3doghouse d97
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day3doghouse d97","sc day3doghouse d97x","v_pt_image_index_57")
    mc"Maybe a bit of both, haha!"
    hide screen scr_peeping_tom
    show sc day3doghouse d98
    c"How on earth did you get past the dog the second time?"
    # ‚ÄúIf the player chose RUN FOR IT and the timer didn‚Äôt run out‚Äù"
    if v_day3_doghouse_steak:
        mc"I figured that he that might be hungry..."
        mc"So rather than let him take a chunk out of me, I grabbed a steak from the old man‚Äôs freezer and threw it at his dog to distract him while I made my escape."
    else:
        mc"I just pinned the ears back and ran like greased lightning! He almost caught me though!"
    show sc day3doghouse d97
    c"That was clever thinking!"
    show sc day3doghouse d100
    c"You‚Äôre so crazy [y_name]. I don‚Äôt think I could ever be like that, not with a vicious dog in there."
    show sc day3doghouse d97
    mc"Yeah, I was shitting myself when he first made eye contact with me. And his constant barking was making me sweat bullets."
    c"Thank god it‚Äôs all over with now."
    show sc day3doghouse d98
    c"All right, well I better get going [y_name]."
    # (Cousin kisses the MC on the cheek)  +2 COUSIN POINTS"
    # (Cousin kisses the MC on the cheek)"
    play sound "sound effects/01/01/short_kiss_sound_effect.mp3"
    show sc day3doghouse d102
    c"Mwah!"
    show sc day3doghouse d100
    stop sound
    c"We‚Äôll talk again soon."
    show sc day3doghouse d97
    mc"Bye [c_name]."
    # (C leaves)"
    show sc day3trishahouse t01
    mc"(Man, I was so lucky that I found those documents as quickly as I did.)"
    mc"(Anyway, I better get back to the hotel as [s_name] could already be waiting for me to return.)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day3_mc_walks_back



label lb_day3_doghouse_late_badending:
    hide screen scr_minigame_clock
    play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
    scene sc day3doghouse d80
    with dissolve
    c"[y_name]? Are you okay? Did you get it?"
    if v_day3_doghouse_dog_doc:
        mc"No, the dog almost caught me and I dropped the documents by accident ..."
    else:
        mc"No, the old man caught me...."
    show sc day3doghouse d87
    c"I‚Äôm really sorry that I couldn‚Äôt distract him any longer for you [y_name]."
    c"I got all messed up and I couldn‚Äôt remember what we practised yesterday."
    show sc day3doghouse d81
    mc"It‚Äôs okay [c_name], I should never have put you in that situation to begin with."
    show sc day3doghouse d87
    $ c_points = change_stat(c_points,-3,c_name)
    mc"It was a stupid plan and it‚Äôs all my fault. I‚Äôm sorry I couldn‚Äôt help you."# -3 COUSIN POINTS"
    c"(Sigh‚Ä¶ Mom is going to be so pissed with me, especially if the old man tells her that [y_name] broke into his house.)"
    show sc day3doghouse d81
    $ trisha_points = change_stat(trisha_points,-3,"Trisha")
    c"It‚Äôs okay, I‚Äôll figure out something with my Mom. I could perhaps explain to her why this guy wouldn‚Äôt hand over the documents." #-3 TRISHA POINTS"
    show sc day3doghouse d80
    mc"Yeah, maybe she‚Äôll understand. I tell you what, I am never doing that again!"
    show sc day3doghouse d87
    c"Yeah, I can understand why."
    show sc day3doghouse d81
    mc"Oh, I still need to pick my tools from your house."
    c"Yes, of course. Let‚Äôs head back there now‚Ä¶"
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    #(cousin and the MC outside her house)"
    scene sc day3trishahouse t26
    with dissolve
    c"Well, you have your things."
    mc"Thanks [c_name]."
    mc"And again, I‚Äôm really sorry we couldn‚Äôt get those documents for your Mom.."
    c"It‚Äôs okay, I‚Äôll take care of it."
    c"Well, goodbye for now [y_name]. We‚Äôll talk again soon."
    mc"Bye [c_name]."
    #(C leaves)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3trishahouse t01
    with dissolve
    mc"(Damn, I really let her down. What on earth was I thinking trying to steal the documents? I‚Äôm no criminal.)"
    mc"(However, I‚Äôm lucky that I didn‚Äôt become that mutt‚Äôs latest meal!)"
    mc"(Anyway, I better get back to the hotel, as [s_name] could already be waiting for me to return.)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day3_mc_walks_back





label lb_day3_kristina_intro:
    $ k_name = "Kristina"
    # Day 3 (EOW) 17 - *Kristina intro (he meets her at the church)"
    # - two versions of this scene - if the player arrives here first or second"
    # IF THE PLAYER GOES TO THE CHURCH FIRST (before seeing cousin)"
    # SCENE BEGINS"
    scene sc day3church c01
    with dissolve
    show screen scr_rewards("sc day3church c01b","v_rewards_k_1")
    play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(So‚Ä¶ This is Faith plus One.)"
    mc"(I‚Äôm not feeling the negative vibe that the townspeople supposedly get from this group.)"
    mc"(Then again, I‚Äôve only been here a few minutes.)"
    hide screen scr_rewards
    show sc day3church c03
    k"Excuse me, are you [y_name]?"
    # (MC turns around, sees Kristina)"
    mc"Yes, that would be me‚Ä¶"
    # ROLLING WIP OF KRISTINA"
    if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
        window hide
        scene wip_02_k_church  at tt_top
        pause
        window show
    else:
        show sc day3church c02
    k"It‚Äôs nice to meet you [y_name]. Randy told me that we‚Äôd be expecting you."
    $ k_points = change_stat(k_points,3,k_name)
    $ v_char_kris_known = True
    $ renpy.notify(k_name+" has been added to the Relationship Menu.")
    k"By the way, thank you so much for coming as quickly as you did." #+3 Kristina Points"
    #NOTIFICATION ON SCREEN - From this scene onwards, you can change Kristina‚Äôs name in her character bio section of the menu, or keep it the same.
    #*Kristina‚Äôs number and bio added to tablet
    call screen scr_k_rename
    mc"Uh, you‚Äôre welcome. So, you‚Äôre [k_name]?"
    show sc day3church c06
    k"Yes I am. Were you expecting someone else?"
    show sc day3church c03
    mc"I uh‚Ä¶ Sorry to sound rude, but, I was expecting someone a little older."
    show sc day3church c10
    k"Haha, well our church accepts people of all ages into our special community [y_name]."
    show sc day3church c09
    mc"That‚Äôs great to hear."
    mc"I guess I was also somewhat taken aback because your face looks so familiar."
    show sc day3church c10
    k"Yeah, I get told that a lot. I guess it‚Äôs because I based my look and my hairstyle on a famous model when I was in my early to mid-teen years."
    mc"Oh, really?"
    show sc day3church c02
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day3church c02","sc day3church c02x","v_pt_image_index_50")
    k"Yeah, I was obsessed with her. But not so much nowadays, as most of my time is spent here at the church."
    hide screen scr_peeping_tom
    show sc day3church c05
    k"However, I‚Äôd give up everything if I ever got the chance to meet her!"
    show sc day3church c09
    mc"Haha, well maybe you could ask the man upstairs for some divine intervention to make that happen?"
    show sc day3church c12
    k"Oh, I never thought of that."
    jump lb_day3_kristina_intro_menu

label lb_day3_kristina_intro_menu:
    if v_day3_chouse_menu_role and v_day3_chouse_menu_outsidechurch:
        jump lb_day3_kristina_intro_end
    # [Your role / Outside of church]"
    menu:
        "Your role":
            if v_day3_chouse_menu_role == False:
                $ v_day3_chouse_menu_role = True
                show sc day3church c09
                mc"So what is your role here if I may ask?"
                show sc day3church c02
                k"Oh, I‚Äôm an assistant to the minister."
                k"I‚Äôm usually here during the week to make newcomers like yourself feel more at ease when they enter through those doors."
                k"Do you like what you see so far?"
                # [Check her out / Answer her]"
                menu:
                    "Check her out":
                        $ k_points = change_stat(k_points,-1,k_name)
                        #‚Äù  -1 Kristina Point"
                        show sc day3church c13
                        show screen scr_rewards("sc day3church c13b","v_rewards_k_2")
                        mc"Yes, I like what I‚Äôve seen so far a lot."
                        hide screen scr_rewards
                        show sc day3church c08
                        k"Uh, sure."
                        # (Kristina has an unsure look on her face)"
                    "Answer her"(wt="Best choice"):
                        #‚Äù +1 Kristina Point"
                        $ k_points = change_stat(k_points,1,k_name)
                        show sc day3church c03
                        mc"Yeah, it looks like a pretty swell set up your church has here."
                        # (Kristina has a smile on her face)"
                        # (scene continues)"
                show sc day3church c09
                k"Are you a part of any specific church?"
                # [No, I‚Äôm not / Sure I am]"
                menu:
                    "No, I‚Äôm not"(wt="Best choice"):
                        mc"Uh, no I‚Äôm not. I‚Äôm not exactly a person of any specific faith I‚Äôm afraid."
                        show sc day3church c10
                        k"That‚Äôs okay, we don‚Äôt judge here."
                        k"Nor would I try and force my own beliefs on anyone new to our church."
                        $ k_points = change_stat(k_points,1,k_name)
                        k"And honesty is a great trait to have [y_name]." #+1 Kristina Point"
                        mc"Thanks."
                        show sc day3church c09
                        mc"Being a person with a background in law, speaking, and finding the truth is something that comes naturally."
                        show sc day3church c12
                        k"Haha, I can imagine."
                    "Sure I am":
                        show sc day3church c09
                        mc"Oh, sure I am. I‚Äôm a huge fan of the man upstairs."
                        show sc day3church c02
                        k"You know [y_name], it‚Äôs a sin to lie in a place of worship."
                        k"Perhaps you have some other sins that you would like to share with one of the priests in one of our confessional booths?"
                        mc"Oh, um. Maybe some other time."
                        show sc day3church c05
                        k"Haha, it‚Äôs all right, I‚Äôm just messing with you. We don‚Äôt judge here."
                        show sc day3church c07
                        k"Nor would I try and force my own beliefs on anyone new to our church."
                        show sc day3church c08
                        $ k_points = change_stat(k_points,-1,k_name)
                        k"But you shouldn‚Äôt lie." #-1 Kristina Point"
                        show sc day3church c03
                        mc"Uh, okay. I‚Äôll try and remember that."
                jump lb_day3_kristina_intro_menu

            mc"(We've already talked about this.)"
            jump lb_day3_kristina_intro_menu
        "Outside of church":
            if v_day3_chouse_menu_outsidechurch == False:
                $ v_day3_chouse_menu_outsidechurch = True
                show sc day3church c03
                mc"I take it you have a life outside of the church. What else do you do during the week [k_name]?"
                show sc day3church c02
                k"Oh, well I‚Äôm also studying interior design."
                show sc day3church c10
                k"If I were to ever leave the church..."
                k"Then one day I‚Äôd like to be in charge of the overall beauty and style of bedrooms and home living rooms."
                k"I‚Äôve always been interested in that kind of thing ever since I was young."
                k"I change the set up of my own bedroom quite frequently."
                show sc day3church c09
                mc"And I‚Äôm guessing that the church isn‚Äôt the kind of place to encourage your childhood passion?"
                show sc day3church c11
                k"No, not really."
                k"Even though I‚Äôve expressed my desire to change things around here, they‚Äôre very intent on keeping the same look for now."
                jump lb_day3_kristina_intro_menu

            mc"(We've already talked about this.)"
            jump lb_day3_kristina_intro_menu



label lb_day3_kristina_intro_end:
    show sc day3church c03
    mc"Anyway, as you know I was sent here by Randy to pick up some tools for the hotel that I‚Äôm working at."
    show sc day3church c04
    k"Oh yes, about that. There‚Äôs a bit of a problem."
    k"The minister took it and it‚Äôs now in his office, but I‚Äôm not allowed to go in there."
    mc"Oh, how come?"
    k"Only the minister and some of the male priests are allowed in the main office."
    k"It would be deemed a sin and a sign of mistrust if I were to go in there."
    show sc day3church c03
    mc"All right, so is the minister around? Maybe I could talk to him about the toolbox."
    show sc day3church c06
    k"I‚Äôm afraid not, he‚Äôs out at the moment."
    show sc day3church c10
    k"Hey, I just had an idea. Maybe you could go in there and get it?"
    mc"Me?? But I‚Äôm not exactly a priest, nor would I want to put myself at risk if someone was to find me snooping around inside the minister‚Äôs office."
    show sc day3church c12
    k"You won‚Äôt be at risk. Come and follow me into the back room."
    show sc day3church c10
    mc"(Hmm‚Ä¶ This already sounds like a bad idea.)"
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3church c17
    with dissolve
    mc"So what are we doing here [k_name]?"
    show sc day3church c18
    k"Well, the idea I had was that you could wear one of our priest gowns."
    show sc day3church c14
    k"That way you‚Äôll be able to move around the office and no one should suspect you of any wrongdoing."
    show sc day3church c15
    mc"Wait, you want me to dress up like a priest? That‚Äôs crazy!! "
    show sc day3church c20
    k"Look, do you want your tools or not? It‚Äôs your choice."
    show sc day3church c15
    mc"(Hmm‚Ä¶ That sounded very direct from this girl. Strange‚Ä¶)"
    mc"Well yes, I do need them, but do you even know where the toolbox would be kept inside the office?"
    show sc day3church c21
    k"It‚Äôs more than likely going to be locked away inside a cabinet, which you‚Äôll need a code for."
    show sc day3church c24
    k"It‚Äôs okay, I have the code for you."
    mc"(Hmm‚Ä¶ Why would the toolbox be kept inside a cabinet?)"
    show sc day3church c15
    mc"You‚Äôre definitely sure about this?"
    show sc day3church c17
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom(" sc day3church c17"," sc day3church c17x","v_pt_image_index_51")
    k"Yes, I‚Äôm positive it will be in there."
    mc"(I have to get that toolbox, even if I have to pretend to be something I‚Äôm clearly not!)"
    mc"(And I really don‚Äôt want to return to [s_name] empty-handed.)"
    mc"All right fine, I‚Äôll do it."
    hide screen scr_peeping_tom
    show sc day3church c24
    k"Let me write down the code for you and some extra instructions."
    # (Kristina leans down to write on a piece of paper the code)"
    show sc day3church c15
    mc"If you don‚Äôt mind me asking [k_name], how did the toolbox end up in the minister‚Äôs office?"
    mc"I thought you were the one who was keeping it aside for Randy?"
    show sc day3church c21
    k"Yeah, it‚Äôs kind of a long story. Too long for me to go into much detail with you now."
    show sc day3church c25
    k"Here‚Äôs the code to get into the cabinet, and also where the key to the second office is."
    # (Kristina hands the MC the paper and looks at the code written on the sheet - it reads 6969. There‚Äôs scribbled details underneath the number about where the key is, but it‚Äôs too hard to read)"
    show sc day3church c29
    mc"Sixty-nine, sixty-nine? Is this some kind of a joke?"
    show sc day3church c15
    k"Huh? How you do mean?"
    mc"Uh, never mind."
    show sc day3church c24
    k"I‚Äôve also drawn a rough idea of what the office looks like on the opposite side of that paper."
    k"You‚Äôll need a key to get into the second room that has the cabinet in it."
    show sc day3church c15
    mc"Okay, so should I just get changed in here then?"
    k"Yeah, any of those gowns behind you should fit. I‚Äôll wait outside until you‚Äôve changed."
    show sc day3church c27
    mc"Sure, thanks [k_name]. By the way, would it not be considered a sin by your community for someone to impersonate a priest?"
    show sc day3church c17
    k"It would be if you were a part of this community [y_name]."
    # (she smiles)"
    show sc day3church c22
    k"You better get changed before someone comes in here."
    # (Kristina leaves)"
    show sc day3church c26
    mc"(Oh boy, how did I get myself into this situation?)"
    # (screen goes blank)"
    # (MC comes out but we don‚Äôt see him yet, we see Kristina standing in the hall area with her back facing him)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3church c19
    with dissolve
    mc"Okay, I‚Äôm ready‚Ä¶"
    # (Kristina turns around, and smiles as she sees the MC)"
    show sc day3church c18
    k"Oh my, you look great [y_name]! I think you‚Äôd fit in well here at Faith plus One."
    # (An unimpressed look on the MC‚Äôs face for the first shot here, not happy wearing a priests gown)"
    show sc day3church c33
    mc"I feel ridiculous. Are you sure that no one here will be suspicious or will know I‚Äôm not really a priest?"
    show sc day3church c18
    k"I keep telling you, it‚Äôs fine."
    show sc day3church c17
    k"And if anyone asks where you are from, just tell them that you‚Äôre a priest who is just visiting, from two towns over."
    show sc day3church c31
    mc"Uh, sure [k_name]. So where is this office then?"
    show sc day3church c24
    k"It‚Äôs this way, follow me."
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (they stand outside the minister‚Äôs office)"
    scene sc day3church c34
    with dissolve
    k"Okay, the toolbox is in there."
    show sc day3church c35
    k"I‚Äôll stand out here and try and keep watch to let you know if there‚Äôs anyone close by."
    show sc day3church c36
    k"But I may have to leave unexpectedly, so you could be on your own for a few minutes."
    show sc day3church c35
    k"I‚Äôll definitely come back to check on you if that happens."
    k"Just make sure you lock the door behind you after you enter."
    mc"I can do that."
    k"I‚Äôll knock on the door if someone important is coming this way. All right, are you all set?"
    mc"Yeah, I think so."
    show sc day3church c38
    k"Great! May God be with you [y_name]."
    show sc day3church c35
    mc"Uh, thanks, I guess."
    # (there‚Äôs a computer screen, some books and a plant pot on there - all important)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3church c44
    with dissolve
    mc"(Man, what on earth am I doing in here? I can‚Äôt imagine I‚Äôll have many days like this one ever again.)"
    # (MC sees a door to the next room - where the cabinet is that has the tools)"
    show sc day3church c45
    mc"(That must be the door to the other room where the toolbox is being kept.)"
    show sc day3church c67
    mc"([k_name] left me some notes on where to find the key in this office so I can get into the next room.)"
    show sc day3church c66
    mc"(Now, where did I put it?)"
    # (MC places his hands on his sides, looking for pockets that don‚Äôt exist)"
    show sc day3church c68
    mc"(Oh crap! This gown doesn‚Äôt have any pockets! SHIT!!)"
    show sc day3church c65
    mc"(I left the note [k_name] wrote out for me back in the change room!)"
    show sc day3church c63
    mc"(Maybe I could open the main door and quickly ask her?)"
    # (MC opens the front door where he entered the office, Kristina is gone)"
    show sc day3church c60
    mc"(Dammit, she‚Äôs gone. She must have been called to go somewhere else.)"
    show sc day3church c50
    mc"(It looks like I‚Äôm on my own. That key will be in here somewhere. But where?)"
    mc"(If I were to hide a key to a room that I didn‚Äôt want everyone to have access to, then where would I hide it?)"
    show sc day3church c45
    menu:
        "Open the second door":
            mc"(Well, I may as well check to see if the guy forgot to lock the door.)"
            # (MC tries to open the second door)".
            show sc day3church c46
            mc"(Ahh! Locked! Of course it is. I couldn‚Äôt be that lucky.)"
            mc"(I‚Äôll have to look somewhere else‚Ä¶)"
            jump lb_day3_church_menu

label lb_day3_church_menu:
    show sc day3church c50
    # [Behind the picture frame / Check the desk drawer / Under the pot plant]"
    menu:
        "Behind the picture frame":
            if v_day3_church_frame == False:
                $ v_day3_church_frame = True
                # (An expanded shot of the office so we can see everything in there)"
                show sc day3church c51
                mc"(Hmm, what about behind the picture frame?)"
                # (MC stands in front of the picture)"
                mc"(Free all angels? Hmm, interesting‚Ä¶)"
                # [Check behind there]"
                # (MC takes it off the wall)"
                mc"(I better be careful with this, as it looks quite expensive.)"
                # (MC checks the back of the frame)"
                show sc day3church c52
