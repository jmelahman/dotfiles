label lb_day3_chouse_intro_late:
    # IF THE PLAYER GOES TO COUSIN + TRISHA‚ÄôS SECOND"
    # (scene begins with the MC standing outside cousin house)"
    scene sc day3trishahouse t01
    with dissolve
    mc"(I hope [c_name] isn‚Äôt too pissed at me for being quite late.)"
    mc"(Then again, if I explain to her what happened, then maybe she‚Äôll understand.)"
    play sound "sound effects/01/01/Door_Knock_Sound_Effect_Free.mp3" fadein 1.0
    "(Knock, knock, knock)"
    #- Door Knock - sound effect to be added"
    stop sound fadeout 1.0
    # (Cousin answers the door)"
    show sc day3trishahouse t21
