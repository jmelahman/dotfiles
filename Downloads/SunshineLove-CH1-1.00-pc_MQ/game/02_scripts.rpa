            # (MC opens the drawer)"
            show sc day3church c70
            mc"(It could be a long shot, but if I try and lift this up, then maybe‚Ä¶)"
            mc"(Oh! What‚Äôs this?)"
            # (MC pulls up the base of the drawer and finds the key underneath it)"
            show sc day3church c57
            mc"(This must be it!)"
            # (*There will be some photos that are also in the draw that will be upside-down. The player must click on them for the MC to view them)"
            # ‚ÄúIf the player clicks on the photos‚Äù"
            mc"(Oh, I wonder what these are?)"
            # (MC turns them over, sees a priest with a couple of strippers)"
            show sc day3church c59
            mc"(Oh wow! I can see why this would be hidden away.)"
            show sc day3church c69
            mc"(What a minute, is that father David??)"
            mc"(So, you‚Äôre not exactly the holy man that you claim to be, are you father?)"
            show sc day3church c59
            mc"(The minister obviously didn‚Äôt want others to see this, but why didn‚Äôt he just destroy them?)"
            # [Put it back / Copy the photo]"
            menu:
                "Put it back":
                    show sc day3church c57
                    mc"(I better put these back, and turn them over again.)"

                "Copy the photo"(wt="Best choice"):
                    #‚Äù *Item could be added to the Tablet menu perhaps?"
                    $ v_day3_church_steal_photo = True
                    show sc day3church c58
                    mc"(I‚Äôm not sure why, but my gut instinct is telling me that these photos might come in handy at some point.)"
                    mc"(I'll just take a photo of it with my phone, and then put it back.)"
                    # (The MC takes a photo with the camera on his phone)"
                    # (scene continues)"
            # (MC closes the drawer)"
            show sc day3church c57
            mc"(Done. All right, now to try and get into this other room‚Ä¶)"
            scene black
            with dissolve
            scene black
            with Pause (2)





        "Under the pot plant":
            if v_day3_church_late_pot == False:
                $ v_day3_church_late_pot = True
                show sc day3church c53
                mc"(Hmm‚Ä¶ Maybe it‚Äôs under the pot plant?)"
                show sc day3church c54
                mc"(Sigh‚Ä¶ It‚Äôs not here.)"
                jump lb_day3church_late_menu
            mc"(I've already tried this.)"
            jump lb_day3church_late_menu

    show sc day3church c48
    mc"(Jackpot!)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC enters the second room, which is like another change room and has the cabinet in the corner)"
    scene sc day3church c71
    with dissolve
    mc"(That must be the cabinet that [k_name] told me about.)"
    # (MC stands in front of the cabinet)"
    show sc day3church c71
    mc"(Okay, what was the code again?)"
    show sc day3church c88
    mc"(Right, how could I forget!)"
    # (The player must click on 6-9-6-9 for the cabinet to open. If they get the number wrong, it will fail until they get it right)"
    show sc day3church c72
    menu:
        "6969":
            show sc day3church c88
            mc"(Here we go‚Ä¶)"
    # (MC looks inside the cabinet and sees other things that look like confiscated items)"
    show sc day3church c89
    # (MC looks on the bottom shelf)"
    mc"(This must be it! Finally!)"
    # [Open it / Don‚Äôt open it]"
    menu:
        "Open it"(wt="Best choice"):
            $ v_day3_church_toolbox_open = True
            show sc day3church c89
            mc"(I better check that the tools are definitely in there.)"
            # (MC opens it)"
            show sc day3church c90
            mc"(Yep, there they are.)"
            show sc day3church c92
            mc"(Huh? What the hell is this??)"
            # (MC picks up a vibrator that is inside the toolbox)"
            show sc day3church c93
            mc"(Why on earth is this in here?? And whose is it?)"
            show sc day3church c94
            mc"(I better put it back in there, then make sure to lock the cabinet, and leave everything else the way I found it.)"
            show sc day3church c91
            $ k_points = change_stat(k_points,1,k_name)
            mc"(Then I need to put the key back before someone finds me in here!)" #+1 Kristina Point"
            # (screen goes blank) "
        "Don‚Äôt open it":
            show sc day3church c92
            mc"(Okay, I better lock this cabinet, then lock the door to this room when I leave, and put the key back before someone finds me in here!)"
            # (screen goes blank) "
    # (scene continues)"


    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC puts the key back in the desk drawer under the hidden compartment)"
    scene sc day3church c95
    with dissolve
    mc"(There, it‚Äôs back where it should be. Hmm‚Ä¶ What‚Äôs that?)"
    # (MC looks at the screensaver and sees a picture of the minister and Kristina in a close photo,"
    # to show that they‚Äôre father and daughter, but he doesn‚Äôt know that yet. Maybe they are looking at each other smiling)"
    mc"(If I didn‚Äôt know any better, I‚Äôd say that they were very close.)"
    mc"(Or it could be what this particular community is like.)"
    mc"(All right, now I can leave. I wonder if [k_name] is outside the office?)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3church c14
    with dissolve
    k"There you are!"
    show sc day3church c96
    k"And you got it! How do you find the key?"
    show sc day3church c15
    mc"I got lucky I guess. Where‚Äôs father David?"
    show sc day3church c24
    k"It‚Äôs okay, he‚Äôs occupied at the moment."
    k"I didn‚Äôt want him to find you in the office so I told him that one of the sisters needed him for something."
    show sc day3church c16
    k"So that gives you about two minutes to get back into the change room and out of those clothes!"
    mc"Oh, sure thing."
    show sc day3church c17
    k"Leave the toolbox with me while you‚Äôre getting changed."
    # ‚ÄúIf the player chose to Open it‚Äù"
    if v_day3_church_toolbox_open:
        show sc day3church c18
        mc"(Hmm‚Ä¶ She sounds pretty intent on getting this toolbox from me.)"
        mc"(Surely the item that I found in there isn‚Äôt hers? But what if it is?)"
        show sc day3church c17
        mc"Uh, okay. Here it is. I‚Äôll be back in a moment."
        show sc day3church c14
        k"Great, I‚Äôll keep a lookout for you."
        # (screen goes blank)"
    else:
        # ‚ÄúIf the player chose Don‚Äôt open it‚Äù"
        show sc day3church c17
        mc"No problem, I‚Äôll be back in a moment."
        k"Great, I‚Äôll keep a lookout for you."
        # (screen goes blank)"
    # (MC returns, is changed into his original clothing, and they are standing outside the front of the church)"
    # ‚ÄúIf the player chose to Open it‚Äù"
    scene black
    with dissolve
    scene black
    with Pause (2)

    if v_day3_church_toolbox_open:
        scene sc day3church c02
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        with dissolve
        mc"Well it was nice to meet you [k_name], and thanks for your help."
        k"You‚Äôre welcome."
        show sc day3church c03
        k"So, did you find anything interesting inside the toolbox?"
        mc"Um‚Ä¶ What do you mean?"
        show sc day3church c08
        k"Don‚Äôt play coy with me [y_name]. I know what you saw."
        show sc day3church c03
        mc"So, it‚Äôs yours then?"
        show sc day3church c11
        k"Yeah, it is. I needed some tools to fix it. But things didn‚Äôt exactly go according to plan."
        k"And it‚Äôs also the reason why the toolbox ended up in the minister‚Äôs office and inside that cabinet."
        k"So I‚Äôd appreciate it if you keep this little secret between you and me, you got it?"
        show sc day3church c10
        k"You don‚Äôt say anything about what you found in that toolbox, and I won‚Äôt tell anyone that you were in my father‚Äôs office."
        k"Is that understood?"
        mc"Yes, perfectly [k_name]."
        show sc day3church c02
        k"Great, we understand each other then."
        k"Perhaps you could meet the minister and some of the other priests the next time that you visit?"
        show sc day3church c03
        mc"Uh, I think I‚Äôll pass if it‚Äôs okay by you."
        mc"(After what I just discovered, I highly doubt that I‚Äôll ever come back here.)"
        mc"(However, she has me intrigued now.)"
        show sc day3church c02
        k"Sure, or you could always drop by just to visit little ole‚Äô me if you wanted to?"
        # (Kristina gives the MC a cheeky, mischievous look)"
        mc"(Oh! Is she still trying to convert me, or was she insinuating something else?)"
        mc"(I‚Äôm really getting mixed signals from this girl now.)"
        mc"(Is it all because of the sex toy that I found of hers?)"
        mc"Um, I may just do that [k_name]."
        mc"(Hmm‚Ä¶ I just had an idea.)"
        show sc day3church c03
        mc"Say, rather me coming to visit you, maybe we could meet somewhere else?"
        show sc day3church c09
        k"Oh, and for what reason would I want to do that?"
        mc"You said before that you have an interest in interior design, correct?"
        jump lb_day3church_late_menu_1

        label lb_day3church_late_menu_1:
        mc"I work at a hotel with a friend of mine and we might be looking for someone to re-design our hotel rooms and foyer area in the future."

        label lb_day3church_late_menu_2:
        mc"So I thought that seeing as your talents are being wasted here..."
        mc"Then perhaps you might be interested in using your ‚Äúpassion‚Äù for designing and styling, in a place where it may be of some use?"
        show sc day3church c10
        k"Oh, well that‚Äôs a very kind offer [y_name]."
        show sc day3church c07
        k"Okay, let me give you my number."
        # *Kristina‚Äôs number and bio added to tablet"
        show sc day3church c02
        mc"Thanks, I‚Äôll be in touch once I‚Äôve spoken to the hotel owner about you."
        mc"Okay, I better get going, I have places to be and people to see."
        $ k_points = change_stat(k_points,3,k_name)
        k"I sure hope I‚Äôll hear from you again soon [y_name]." # +3 Kristina Points"
        show sc day3church c05
        k"Go in peace. And have a great day."
        # (Kristina‚Äôs persona changes back to calm and proper again)"
        # (Kristina goes back into the church)"
        show sc day3church c97
        mc"(Man, I got a bit of a rush being in the minister‚Äôs office and fearing that someone might see me in there.)"
        show sc day3church c98
        mc"(Hang on a minute?? Did [k_name] just say that the office I was in was her father‚Äôs??)"
        mc"(Oh!! That explains the picture I saw in the office!)"
        mc"(And he must have confiscated the toolbox when he found [k_name] with that sex toy.)"
        show sc day3church c100
        mc"(So maybe she‚Äôs not the sweet, innocent young woman I initially made her out to be.)"
        mc"(What other secrets does she have that her father doesn‚Äôt know about yet?)"
        # (MC looks down at the tools)"
        show sc day3church c103
        mc"(At least I have the tools now. Time to get back to the hotel now.)"
        stop sound fadeout 1.0

    else:
        scene sc day3church c02
        with dissolve
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        mc"Well it was nice to meet you [k_name], and thanks for your help."
        k"It was nice meeting you too."
        k"Perhaps you could meet the minister and some of the other priests the next time that you visit?"
        mc"Uh, I think I‚Äôll pass if it‚Äôs okay by you."
        show sc day3church c05
        k"Sure, or you could always drop by just to visit little ole‚Äô me if you wanted to?"
        # (Kristina gives the MC a cheeky, mischievous look)"
        show sc day3church c02
        mc"(Oh! Is she still trying to convert me, or was she insinuating something else?)"
        mc"Um, I may just do that [k_name]."
        mc"(Hmm‚Ä¶ I just had an idea.)"
        show sc day3church c03
        mc"Say, rather me coming to visit you, maybe we could meet somewhere else?"
        show sc day3church c09
        k"Oh, and for what reason would I want to do that?"
        mc"You said before that you have an interest in interior design, correct?"
        jump lb_day3church_late_menu_3

        label lb_day3church_late_menu_3:
        mc"I work at a hotel with a friend of mine and we might be looking for someone to re-design our hotel rooms and foyer area in the future."

        label lb_day3church_late_menu_4:
        mc"So I thought that seeing as your talents are being wasted here..."
        mc"Then perhaps you might be interested in using your ‚Äúpassion‚Äù for designing and styling, in a place where it may be of some use?"
        show sc day3church c12
        k"Oh, well that‚Äôs a very kind offer [y_name]."
        show sc day3church c07
        k"Okay, let me give you my number."
        show sc day3church c02
        mc"Thanks, I‚Äôll be in touch once I‚Äôve spoken to the hotel owner about you."
        mc"Okay, I better get going, I have places to be and people to see."
        show sc day3church c05
        k"Go in peace. And have a great day [y_name]."
        # (Kristina goes back into the church)"
        show sc day3church c97
        mc"(Man, I got a bit of a rush being in the minister‚Äôs office and fearing that someone might see me in there.)"
        show sc day3church c103
        mc"(At least I have the tools now. Time to get back to the hotel now.)"
        stop sound fadeout 1.0
    scene black
    with dissolve
