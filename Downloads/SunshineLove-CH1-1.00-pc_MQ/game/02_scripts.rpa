label lb_day3_doghouse_late_goodending:
    hide screen scr_minigame_clock
    if v_c_date1_choice1 == False or v_c_date1_choice2 == False or v_c_date1_choice3 == False:
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        scene sc day3doghouse d80
        with dissolve
        c"[y_name]? Are you okay? Did you get it?"
        show sc day3doghouse d91
        $ v_day3_doghouse_get_document = True
        mc"Yeah, I got it."
        show sc day3doghouse d83
        c"Oh my god! How did even manage to get past his dog??"
        mc"Well, luckily I found a chew toy that I threw at him to distract him. Then I ran like greased lightning!!"
        show sc day3doghouse d95
        $ c_points = change_stat(c_points,5,c_name)
        c"You are so amazing!!"
        # (Without thinking, cousin jumps up and hugs the MC)"
        show sc day3doghouse d96
        mc"Okay, okay. We better get out of here before the old man knows that something is up."
        show sc day3doghouse d142
        c"Quick! I think he‚Äôs coming! Follow me‚Ä¶"
        #(cousin grabs the MC‚Äôs hand and they hide)"
        stop sound fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
    else:
        scene sc day3doghouse d92
        with dissolve

        if v_day3_doghouse_feeddog == False:
            play sound "sound effects/01/03/Large Dog Barking Sound Effect Lower.mp3" loop fadeout 1.0 fadein 1.0
            c"(Oh, [y_name] is safe!!)"
            show sc day3doghouse d93
            c"(And it looks like we‚Äôll get away with this.)"
            # (Dog continues barking during the scene) - Dog Barking - sound effect continuously running here"
            show sc day3doghouse d14
            c"Uh, anyway, perhaps you should feed your dog while I wait for my friend to return."
            c"He sounds like he‚Äôs pretty hungry."
            show sc day3doghouse d22
            norm"Yeah, whatever. You wait right here and I‚Äôll be back to collect my money."
            stop sound fadeout 1.0
            # (Norman turns and shouts out to the dog)"
            show sc day3doghouse d23
            with vpunch
            play sound "sound effects/01/03/Door Slam - sound effect.mp3"
            norm"Shut up you stupid mutt, I‚Äôm coming!!"
            stop sound
            c"(Phew! Looks like the coast is clear‚Ä¶)"

        else:
            play sound "sound effects/03/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
            c"(Oh, [y_name] is safe!!)"
            show sc day3doghouse d93
            c"(And it looks like we‚Äôll get away with this.)"
            show sc day3doghouse d14
            c"Uh, anyway, it sounded like your dog needed you. He might be hungry."
            c"I can just wait here until my friend returns."
            show sc day3doghouse d22
            norm"Yeah, whatever. You wait right here and I‚Äôll be back to collect my money."
            stop sound fadeout 1.0
            # (Norman turns and shouts out to the dog)"
            show sc day3doghouse d77
            norm"(I wonder why on earth that mutt stopped barking all of a sudden...)"
            show sc day3doghouse d23
            with vpunch
            play sound "sound effects/01/03/Door Slam - sound effect.mp3"
            c"(Phew! Looks like the coast is clear‚Ä¶)"
            stop sound



        scene black
        with dissolve
        scene black
        with Pause (2)
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        scene sc day3doghouse d80
        with dissolve
        c"[y_name]? Are you okay? Did you get it?"
        show sc day3doghouse d91
        $ v_day3_doghouse_get_document = True
        mc"Yeah, I got it."
        show sc day3doghouse d83
        c"Oh my god! How did even manage to get past his dog??"
        mc"Well, luckily I found a chew toy that I threw at him to distract him. Then I ran like greased lightning!!"
        show sc day3doghouse d95
        $ c_points = change_stat(c_points,5,c_name)
        c"You are so amazing!!"
        # (Without thinking, cousin jumps up and hugs the MC)"
        show sc day3doghouse d96
        mc"Okay, okay. We better get out of here before the old man knows that something is up."
        show sc day3doghouse d142
        c"Quick! I think he‚Äôs coming! Follow me‚Ä¶"
        #(cousin grabs the MC‚Äôs hand and they hide)"
        stop sound fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)



    #(starts with a shot of cousins face)"
    scene sc day3doghouse d135
    with dissolve
    play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"Uh, are you sure this is the best place to hide [c_name]?"
    show sc day3doghouse d136
    mc"(There‚Äôs hardly any room for us between these two houses.)"
    show sc day3doghouse d137
    c"Sorry, I didn‚Äôt have much time to think [y_name]."
    show sc day3doghouse d138
    c"Oh shit! I think he‚Äôs looking over this way!"
