    k"He‚Äôd like you to sign off on them. I‚Äôll need you to come with me, as it sounds pretty urgent."
    mc"(This must be [k_name]‚Äôs way of getting me into the minister‚Äôs office.)"
    show sc day3church c83
    pri"Yes, of course."
    show sc day3church c80
    pri"Would you excuse me for a moment father Ted?"
    mc"Yes, no problem. I can show myself around."
    # (Kristina and Priest #1 walk away, and Kristina diverts her eyes towards the minister‚Äôs office)"
    show sc day3church c39
    mc"(That must be the minister‚Äôs office.)"
    mc"(Okay, I better work quickly here to find that toolbox‚Ä¶)"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)



    # (there‚Äôs a computer screen, some books and a plant pot on there - all important)"
    scene sc day3church c44
    with dissolve
    mc"(Man, what on earth am I doing in here? I can‚Äôt imagine I‚Äôll have many days like this one ever again.)"
    # (MC sees a door to the next room - where the cabinet is that has the tools)"
    show sc day3church c45
    mc"(That must be the door to the other room where the toolbox is being kept.)"
    mc"(But how do I get in there?)"
    show sc day3church c46
    mc"(Well, I may as well check to see if the guy forgot to lock the door.)"
    # (MC tries to open the second door)"
    mc"(Ahh! Locked! Of course it is. I couldn‚Äôt be that lucky.)"
    show sc day3church c49
    mc"(So the key must be in this office somewhere. But where? )"
    show sc day3church c50
    mc"(If I were to hide a key to a room that I didn‚Äôt want everyone to have access to, then where would I hide it?)"
    jump lb_day3church_late_menu


label lb_day3church_late_menu:
    show sc day3church c50
    # [Behind the picture frame / Check the desk drawer / Under the pot plant]"
    menu:
        "Behind the picture frame":
            if v_day3_church_late_frame == False:
                $ v_day3_church_late_frame = True
                show sc day3church c51
                mc"(Hmm, what about behind the picture frame?)"
                mc"(Free all angels? Hmm, interesting‚Ä¶)"
                mc"(I better be careful with this, as it looks quite expensive.)"
                show sc day3church c52
                mc"(Nope, it‚Äôs not here.)"
                mc"(I‚Äôll have to look somewhere else‚Ä¶)"
                jump lb_day3church_late_menu
            mc"(I've already tried this.)"
            jump lb_day3church_late_menu

        "Check the desk drawer" if v_day3_church_late_drawer == False:
            $ v_day3_church_late_drawer = True
            # (An expanded shot of the office so we can see everything in there)"
            show sc day3church c55
            mc"(I guess the most obvious place to hide a key would be in the top drawer of a desk.)"
            # [Move behind desk]"
