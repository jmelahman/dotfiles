label lb_day3_kristina_intro_late:
    $ k_name = "Kristina"
    scene sc day3church c01
    play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
    with dissolve
    mc"(So‚Ä¶ This is Faith plus one.)"
    mc"(Hopefully this [k_name] girl is still here, given how late I am.)"
    show sc day3church c03
    k"Excuse me, are you [y_name]?"
    # (MC turns around, sees Kristina)"
    if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
        window hide
        scene wip_02_k_church  at tt_top
        pause
        window show
    else:
        show sc day3church c02
    mc"Yes, that would be me‚Ä¶"
    # ROLLING WIP OF KRISTINA"
    # - Kristina will have to be dressed appropriately if she's at the church. Maybe wearing an angelical white dress, or a classy blouse and mid-thigh high skirts"
    show sc day3church c11
    $ k_points = change_stat(k_points,-3,k_name)
    k"Randy told me that we‚Äôd be expecting you, but he said that you would be here an hour ago!" # -1 Kristina Point"
    mc"Yeah, I‚Äôm really sorry about that."
    mc"There was something else I needed to attend to, and it took longer than I hoped it would."
    show sc day3church c09
    mc"So, you‚Äôre [k_name]?"
    show sc day3church c04
    k"Yes I am. Were you expecting someone else?"
    mc"I uh‚Ä¶ Sorry to sound rude, but, I was expecting someone a little older."
    show sc day3church c10
    k"Haha, well our church accepts people of all ages into our special community [y_name]."
    show sc day3church c09
    mc"That‚Äôs great. I guess I was also somewhat taken aback because your face looks so familiar."
    show sc day3church c08
    k"Yeah, I get told that a lot."
    show sc day3church c07
    k"I guess it‚Äôs because I based my look and my hairstyle on a famous model when I was in my early to mid-teen years."
    show sc day3church c02
    mc"Oh, really?"
    k"Yeah, I was obsessed with her."
    show sc day3church c03
    k"But not so much nowadays, as most of my time is spent here at the church."
    show sc day3church c05
    k"However, I‚Äôd give up everything if I ever got the chance to meet her!"
    show sc day3church c02
    mc"Haha, well maybe you could ask the man upstairs for some divine intervention to make that happen?"
    k"Oh, I never thought of that."
    $ v_char_kris_known = True
    $ renpy.notify(k_name+" has been added to the Relationship Menu.")
    # [Your role / Outside of church]"
    call screen scr_k_rename
    jump lb_day3_kristina_intro_late_menu


label lb_day3_kristina_intro_late_menu:
