label lb_day3_doghouse_late_minigame:

    if v_minigame_clock == 1:
        show sc day3doghouse d49
        mc"(Dammit! I don‚Äôt have much time.)"
        show sc day3doghouse d58
        mc"(I better find this document sooner rather than later.)"


    if v_minigame_clock == 2:
        show sc day3doghouse d61
        mc"(Oh shit! I think the old man is getting out of the shower!)"
        show sc day3doghouse d58
        mc"(Come on [y_name]! Get your shit together!)"

    if v_minigame_clock == 3:
        show sc day3doghouse d49
        mc"(FUCK!! Where the hell is this thing! I‚Äôm running out of time!)"

    if v_minigame_clock >= 4:
        show sc day3doghouse d64
        norm"YOU!!"
        show sc day3doghouse d63
        mc"(Shit, I‚Äôm busted!!)"
        show sc day3doghouse d65
        norm"WHAT THE HELL ARE YOU DOING HERE? GET THE FUCK OUT BEFORE I CALL THE COPS ON YOUR ASS!!"
        scene black
        with dissolve
        scene black
        with Pause (2)
        jump lb_day3_doghouse_late_badending


    menu:
        "Section #1"(wt=None if v_day3_doghouse_fridge_enable else "Best choice"):
            $ v_day3_doghouse_fridge_enable = True
            # (The MC pushes the paperwork around, and finds and note Norman left for himself)"
            show sc day3doghouse d49
            mc"(Oh, what‚Äôs this?)"
            # (He picks up the note and reads it to himself)"
            show sc day3doghouse d47
            mc"(Feed Poochy the t-bone in the fridge before leaving the house.)" #*This is also a clue for the player on how to distract the dog when he leaves"
            show sc day3doghouse d48
            mc"(Poochy? Oh, he must be that ugly mutt dog of his outside.)"
            # *Add one of the WRONG CHOICE OPTIONS lines here. This will depend on how much time is left on the timer (see below)"
            show sc day3doghouse d49
            mc"(All right, so it‚Äôs not in this section, I better check one of the other ones.)"
            show sc day3doghouse d46
            $ v_minigame_clock += 1
            jump lb_day3_doghouse_late_minigame
            # *The remaining options on the table come up on screen, and the timer adds fifteen seconds"

        "Section #2":
            # (The MC pushes the paperwork around, and finds some adult magazines underneath the stack that has Dee on the cover.)"
            show sc day3doghouse d51
            mc"(Oh, what‚Äôs this?)"
            # (He picks it up and opens it to the middle page, and sees pictures of Dee as the centrefold from her photoshoot with Ryan)"
            show sc day3doghouse d53
            mc"(Geez, the old man is nothing but a pervert!)"
            mc"(However, I can‚Äôt knock the guy for having good taste, she‚Äôs pretty cute this girl, and looks awfully familiar.)"
            # *Add one of the WRONG CHOICE OPTIONS lines here (see below)"
            show sc day3doghouse d49
            mc"(All right, so it‚Äôs not in this section, I better check one of the other ones.)"
            show sc day3doghouse d46
            $ v_minigame_clock += 1
            jump lb_day3_doghouse_late_minigame
            # *The remaining options on the table come up on screen, and the timer adds fifteen seconds"
        "Section #3"(wt="Best choice" if v_day3_doghouse_fridge_enable else None):
            # (The MC pushes the paperwork around, and the canister with Trisha‚Äôs documents will fall to the ground)"
            show sc day3doghouse d55
            mc"(Oh, what‚Äôs this?)"
            # (He picks it up and sees Trisha‚Äôs name on it)"
            show sc day3doghouse d54
            mc"(Holy shit! I found it!)"
            show sc day3doghouse d57
            mc"(Okay, now I just have to silently leave before the old man sees me in here.)"
            show sc day3doghouse d61
            mc"(Damn, the dog‚Ä¶ He‚Äôll go ape shit once I go back into the yard!)"
            mc"(And the old man will know something is up for sure.)"
            show sc day3doghouse d109
            show screen scr_rewards("sc day3doghouse d110b","v_rewards_c_16")
            mc"(I‚Äôm going to need [c_name]‚Äôs help to distract him so she can buy me some time.)"
            hide screen scr_rewards
            # [Call [c_name] ]"
            # (MC calls cousin who is waiting out front)"
            scene black
            with dissolve
            scene black
            with Pause (2)
            scene sc day3doghouse d111
            with dissolve
            play ambient "sound effects/03/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
            c"[y_name], are you okay??"
            mc"Yeah, I‚Äôm still inside the house, so I‚Äôm going to have to whisper to you."
            mc"I need you to create a diversion so I can escape out of here."
            show sc day3doghouse d111
            c"Why don‚Äôt you just walk straight out the front door?"
            mc"I would, but it sounded like there were numerous locks on the inside when we spoke to the old man when we arrived."
            mc"And I can see the front door from the other end of the house, which means the old man will see me if I go out that way. It‚Äôs too much of a risk."
            mc"Plus I need to get out of this house without him ever knowing I was here."
            show sc day3doghouse d111
            mc"So I‚Äôm going to have to go out the way I came in."
            show sc day3doghouse d112
            c"But what about the dog? He‚Äôs not tied down."
            mc"I‚Äôll take care of that. But I need you to go to the front door and ring the bell."
            mc"Oh shit! The old man is coming, I gotta hide!"
            show sc day3doghouse d113
            c"Hello? [y_name]?"
            # (call ends)"
            # (screen goes blank)"
            # (cousin stands outside the old man, Norman‚Äôs house)"
            show sc day3doghouse d114
            c"(Okay, he really needs my help...)"
            c"(I just have to remember my session with [y_name] yesterday.)"
            # (Cousin presses on the door bell)"
            show sc day3doghouse d115
            c"(Wait, what was it again?)"
            stop ambient fadeout 1.0
            scene black
            with dissolve
            scene black
            with Pause (2)
            scene sc day3doghouse d23
            with dissolve
            play sound "sound effects/01/01/Door_Knock_Sound_Effect_Free.mp3"
            "(Knock, knock, knock.)"
            stop sound
            # (Norman answers the door)"
            show sc day3doghouse d22
            play ambient "sound effects/03/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
            norm"You? What are you doing here again?"
            # ‚ÄúIf the player chose this order for the Yoga session with cousin during Day 2‚Äù"
            # Correct order: CLOSE YOUR EYES > BREATHE NATURALLY > MAINTAIN FOCUS"
            if v_c_date1_choice1 == False or v_c_date1_choice2 == False or v_c_date1_choice3 == False:

                # ‚ÄúIf the player chose the WRONG order for the Yoga session with cousin during Day 2‚Äù"
                # (Dog continues barking during the scene) - Dog Barking - sound effect continuously running here"
                show sc day3doghouse d13
                c"I um, err‚Ä¶"
                show sc day3doghouse d144
                c"(Okay, [y_name] told me to focus on my breathing first. Or did he tell me to smile and keep my eyes open? )"
                show sc day3doghouse d22
                norm"Come on girly, I asked you question!"
                # (Cousin smiles with her eyes wide open)"
                show sc day3doghouse d14
                norm"What the hell are you smiling at??"
                show sc day3doghouse d13
                c"Uhh, nothing, no reason."
                c"(Then he said something about regaining my centre before I respond, I think.)"
                show sc day3doghouse d12
                c"I just wanted to let you know that my friend is getting the money for you."
                show sc day3doghouse d14
                c"He should be back in about five minutes."
                show sc day3doghouse d22
                norm"Well he better hurry up. I have to head out soon and I still haven‚Äôt fed my dog."
                show sc day3doghouse d13
                c"(If I want to buy [y_name] some more time, I have to distract him somehow and engage him in conversation.)"
                show sc day3doghouse d144
                c"Oh, I like dogs too. But not the kind of dog that barks a lot like your one."
                c"Or one that is left in the backyard not tied up."
                show sc day3doghouse d22
                norm"How do you know my dog is not tied up?"
                show sc day3doghouse d13
                c"I uh‚Ä¶ I don‚Äôt know. I just presumed he wasn't."
                show sc day3doghouse d22
                norm"Where is the young man that was with you girly?"
                show sc day3doghouse d21
                norm"(Something fishy is going on‚Ä¶)"
                stop sound
                show sc day3doghouse d77
                c"(Uh-oh‚Ä¶)"
                norm"Wait right here, don‚Äôt you dare move."
                play sound "sound effects/01/03/Door Slam - sound effect.mp3"
                # (Norman heads back into the house)"
                show sc day3doghouse d23
                with vpunch
                stop ambient fadeout 1.0
                c"(Oh shit! He knows!!)"
                # (cousin turns and calls out to the MC)"
                show sc day3doghouse d94
                c"RUN FOR IT [y_name!u]!!!"
                scene black
                with dissolve
                scene black
                with Pause (2)
                $ v_minigame_clock += 1

            else:
                show sc day3doghouse d13
                c"I um, err‚Ä¶"
                show sc day3doghouse d144
                c"(Okay, [y_name] told me to focus on my breathing first.)"
                show sc day3doghouse d22
                norm"Come on girly, I asked you question!"
                show sc day3doghouse d13
                c"(Then he said to regain my centre before I respond‚Ä¶)"
                show sc day3doghouse d14
                c"Hello again Sir. I, I just wanted to let you know that my friend is getting the money for you."
                c"He should be back in about five minutes."
                show sc day3doghouse d21
                norm"Well he better hurry up. I have to head out soon and I still haven‚Äôt fed my dog."
                show sc day3doghouse d13
                c"(If I want to buy [y_name] some more time...)"
                c"(I better maintain my focus and continue to engage in conversation with this guy for as long as possible.)"
                show sc day3doghouse d12
                c"Oh, what kind of dog do you have?"
                show sc day3doghouse d22
                norm"A mean old bastard of a dog, especially when he‚Äôs been kept waiting on his food."
                show sc day3doghouse d13
                c"Right, of course. You know‚Ä¶ I had a dog once."
                show sc day3doghouse d144
                c"A beautiful golden retriever that I named Honey."
                c"But we left the front gate open one night and he got out, and never came back."
                c"I‚Äôd like to think he‚Äôs okay though."
                show sc day3doghouse d22
                norm"Well I‚Äôm really sorry to hear that. But is there a point to your story?"
                show sc day3doghouse d21
                norm"(Why the hell is she telling me this for?)"
                stop ambient fadeout 1.0
                scene black
                with dissolve
                scene black
                with Pause (2)


            if v_minigame_clock >= 4:
                show sc day3doghouse d64
                norm"YOU!!"
                show sc day3doghouse d63
                mc"(Shit, I‚Äôm busted!!)"
                show sc day3doghouse d65
                norm"WHAT THE HELL ARE YOU DOING HERE? GET THE FUCK OUT BEFORE I CALL THE COPS ON YOUR ASS!!"
                scene black
                with dissolve
                scene black
                with Pause (2)
                jump lb_day3_doghouse_late_badending
            else:
                scene sc day3doghouse d57
                with dissolve
                mc"(All right, the old man is at the front door talking with [c_name]. Now is my time to escape!)"
                mc"(What‚Äôs my plan here though?)"
                # [Head outside / Go to the kitchen]"
                menu:
                    "Head outside":
                        scene black
                        with dissolve
                        scene black
                        with Pause (2)

                    "Go to the kitchen"(wt="Best choice") if v_day3_doghouse_fridge_enable:
                        show sc day3doghouse d60
                        mc"(But before I do, there‚Äôs something I‚Äôm going to need to get to stop that mutt from barking‚Ä¶)"
                        # (screen goes blank)"
                        scene black
                        with dissolve
                        scene black
                        with Pause (2)
                        # (MC is in the kitchen)"
                        scene sc day3doghouse d107
                        with dissolve
                        mc"(Hmm‚Ä¶ Where should I be looking?)"
                        # [In the freezer / Leave]"
                        menu:
                            "In the freezer"(wt="Best choice"):
                                $ v_day3_doghouse_steak = True
                                show sc day3doghouse d108
                                mc"(Here it is. This should aid me in trying to escape.)"
                                # (MC is looking in the freezer at a t-bone steak but don‚Äôt show it here)"
                                mc"(Okay, I better get going.)"
                                # (screen goes blank)"
                                scene black
                                with dissolve
                                scene black
                                with Pause (2)
                            "Leave":
                                show sc day3doghouse d107
                                mc"(On second thoughts, I should get out of here, as I‚Äôm wasting valuable time‚Ä¶)"
                                # (screen goes blank)"
                                scene black
                                with dissolve
                                scene black
                                with Pause (2)
                                # (GO DOWN TO PHASE #3 - Part 1)"

                scene sc day3doghouse d131
                with dissolve
                play sound "sound effects/01/03/Large Dog Barking Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
                mc"(God damn dog! He‚Äôs going to blow my cover for sure!)"
                menu:
                    "Run for it":
                        show sc day3doghouse d126
                        show screen scr_rewards("sc day3doghouse d126b","v_rewards_c_18")
                        #*Fifteen seconds will be lost - the timer will change if this option is picked."
                        # If the player is at 60 seconds, then you will be caught by the old man and the dog. If not, you‚Äôll get away with it."
                        mc"(I better make a run for it, as I‚Äôm so close to getting out of here!!)"
                        # (Dog starts barking) - Dog Barking - sound effect to be added"
                        $ v_minigame_clock += 1
                        if v_minigame_clock >= 4:
                            $ v_day3_doghouse_dog_doc = True
                            hide screen scr_rewards
                            show sc day3doghouse d134
                            mc"(Oh no, the documents!!)"
                            mc"(Ohhhhhh shit!!!!)"
                            stop sound fadeout 1.0
                            scene black
                            with dissolve
                            scene black
                            with Pause (2)
                            jump lb_day3_doghouse_late_badending
                        else:
                            mc"(Ohhhhhh shit!!!!)"
                            stop sound fadeout 1.0
                            hide screen scr_rewards
                            scene black
                            with dissolve
                            scene black
                            with Pause (2)
                            jump lb_day3_doghouse_late_goodending

                    "Feed dog"(wt="Best choice") if v_day3_doghouse_steak:
                        $ v_day3_doghouse_feeddog = True
                        #‚Äù (If the player chooses this, they won‚Äôt be caught by the dog or the old man,"
                        # unless cousin fails to distract the old man properly - i.e. she isn‚Äôt perfect during the Yoga session)"
                        show sc day3doghouse d130
                        mc"(Luckily I have this!)"
                        # (MC steps outside and holds up the T-bone steak)"
                        # (Dog runs towards him)"
                        show sc day3doghouse d128
                        mc"Here Poochy!"
                        show sc day3doghouse d132
                        show screen scr_rewards("sc day3doghouse d133b","v_rewards_c_17")
                        mc"Here Poochy, Poochy, Poochy‚Ä¶"
                        stop sound
                        # (MC throws the T-Bone at the dog)"
                        # (Dog catches it and lays on the ground chewing at it)"
                        show sc day3doghouse d133
                        hide screen scr_rewards
                        mc"(Phew‚Ä¶ Thank god that worked.)"
                        show sc day3doghouse d129
                        mc"(Now to get the hell out of here‚Ä¶)"
                        # (MC steps aside from the dog who is chewing on the t-bone on the ground)"
                        scene black
                        with dissolve
                        scene black
                        with Pause (2)









        "Section #4":
            #(Bottom right corner of the table)"
            # (The MC pushes the paperwork around, and finds nothing of interest.)"
            show sc day3doghouse d49
