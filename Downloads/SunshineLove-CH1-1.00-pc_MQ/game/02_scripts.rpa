            show sc day3doghouse d53
            show screen scr_rewards("sc day3doghouse d53b","v_rewards_c_15")
            mc"(Geez, the old man is nothing but a pervert!)"
            hide screen scr_rewards
            show sc day3doghouse d51
            mc"(However, I can‚Äôt knock the guy for having good taste, she‚Äôs pretty cute this girl, and looks awfully familiar.)"
            # *Add one of the WRONG CHOICE OPTIONS lines here (see below)"
            show sc day3doghouse d52
            mc"(All right, so it‚Äôs not in this section...)"
            show sc day3doghouse d49
            mc"(I better check one of the other ones.)"
            show sc day3doghouse d46
            $ v_minigame_clock += 1
            jump lb_day3_doghouse_minigame
            # *The remaining options on the table come up on screen, and the timer adds fifteen seconds"
        "Section #3"(wt="Best choice"):
            #‚Äù (Bottom left corner of the table)"
            # (The MC pushes the paperwork around, and the canister with Trisha‚Äôs documents will fall to the ground)"
            show sc day3doghouse d49
            mc"(Oh, what‚Äôs this?)"
            # (He picks it up and sees Trisha‚Äôs name on it)"
            show sc day3doghouse d54
            mc"(Holy shit! I found it!)"
            show sc day3doghouse d56
            mc"(Okay, now I just have to silently leave before the old man sees me in here.)"
            show sc day3doghouse d57
            mc"(I better go back out the way I came in, just in case he‚Äôs key locked the front door.)"
            # (GO DOWN TO PHASE #3)"
        "Section #4":
            #‚Äù  (Bottom right corner of the table)"
