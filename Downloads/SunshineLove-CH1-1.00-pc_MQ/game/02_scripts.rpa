                            show sc day3doghouse d41
                            mc"(Okay, let‚Äôs see if the door is unlocked.)"
                            # (MC gets to the door, opens it)"
                            mc"(Right, I won‚Äôt have much time until the old man finishes his shower. I better move quickly.)"
                            # *The timer remains the same, doesn‚Äôt change"
                            scene black
                            with dissolve
                            scene black
                            with Pause (2)



                "Stay against the wall":
                    stop sound
                    show sc day3doghouse d35
                    mc"(Oh shit‚Ä¶)"
                    play sound "sound effects/01/03/Large Dog Growling Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
                    show sc day3doghouse d106
