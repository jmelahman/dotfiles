    else:
        # Correct order: CLOSE YOUR EYES > BREATHE NATURALLY > MAINTAIN FOCUS"
        show sc day3doghouse d13
        c"I um, err‚Ä¶"
        show sc day3doghouse d144
        c"(Okay, [y_name] told me to focus on my breathing first.)"
        show sc day3doghouse d22
        norm"Come on girly, I asked you a question!"
        show sc day3doghouse d13
        c"(Then he said to regain my centre before I respond‚Ä¶)"
        show sc day3doghouse d14
        c"Hello again Sir. I, I just wanted to let you know that my friend is getting the money for you."
        c"He should be back in about five minutes."
        show sc day3doghouse d22
        norm"Well he better hurry up. I have to head out soon and I still haven‚Äôt fed my dog."
        show sc day3doghouse d13
        c"(If I want to buy [y_name] some more time, I better maintain my focus and continue to engage in conversation with this guy for as long as possible.)"
        show sc day3doghouse d12
        c"Oh, what kind of dog do you have?"
        show sc day3doghouse d21
        norm"A mean old bastard of a dog, especially when he‚Äôs been kept waiting on his food."
        show sc day3doghouse d13
        c"Right, of course. You know‚Ä¶ I had a dog once. A beautiful golden retriever that I named Honey."
        show sc day3doghouse d144
        c"But we left the front gate open one night and he got out, and never came back."
        c"I‚Äôd like to think he‚Äôs okay though."
        show sc day3doghouse d22
        norm"Well I‚Äôm really sorry to hear that. But is there a point to your story?"
        show sc day3doghouse d21
        norm"(Why the hell is she telling me this for?)"
        # (Cousin looks to her right and sees the MC exit the yard)"
        show sc day3doghouse d92
        c"(Oh, [y_name] is safe!!)"
        show sc day3doghouse d93
        c"(And it looks like we‚Äôll get away with this.)"
        # (Dog continues barking during the scene) - Dog Barking - sound effect continuously running here"
        show sc day3doghouse d14
        c"Uh, anyway, perhaps you should feed your dog while I wait for my friend to return. He sounds like he‚Äôs pretty hungry."
        show sc day3doghouse d22
        norm"Yeah, whatever. You wait right here and I‚Äôll be back to collect my money."
        stop sound fadeout 1.0
        # (Norman turns and shouts out to the dog)"
        show sc day3doghouse d23
        with vpunch
        play sound "sound effects/01/03/Door Slam - sound effect.mp3"
        norm"Shut up you stupid mutt, I‚Äôm coming!!"
        stop sound
        show sc day3doghouse d93
        c"(Phew! Looks like the coast is clear‚Ä¶)"
        scene black
        with dissolve
        scene black
        with Pause (2)




    hide screen scr_minigame_clock


    if v_minigame_clock >= 4:
        # Bad ending - MC is out the front with cousin and has failed - LOSS of Cousin and Trisha points"
        # ‚ÄúIf the player gets caught in the yard, these lines will happen first‚Äù"
        scene sc day3doghouse d104
        with dissolve
        norm"YOU!! I KNEW IT!!"
        show sc day3doghouse d105
        mc"(Shit, I‚Äôm busted!!)"
        show sc day3doghouse d104
        norm"WHAT THE HELL ARE YOU DOING HERE?"
        norm"GET THE FUCK OUT BEFORE I CALL THE COPS ON YOUR ASS!!"
        norm"AND GIVE ME THOSE DOCUMENTS!!"
        # (screen goes blank)"
        # (bad ending with cousin, they stand outside the old man‚Äôs place)"
        scene black
        with dissolve
        scene black
        with Pause (2)
        with dissolve
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        scene sc day3doghouse d81
        c"[y_name]? Are you okay? Did you get it?"
        show sc day3doghouse d88
        mc"No, the old man caught me. He still has the documents. I‚Äôm so sorry [c_name]."
        show sc day3doghouse d84
        $ c_points = change_stat(c_points,-3,c_name)
        mc"It was a stupid plan in the first place and it‚Äôs my fault. I‚Äôm sorry I couldn‚Äôt help you." #-3 COUSIN POINTS"
        # ‚ÄúAdd these lines if the player had the WRONG ORDER FOR COUSIN‚Äù"
        show sc day3doghouse d87
        c"I‚Äôm really sorry that I couldn‚Äôt distract him any longer for you [y_name]."
        c"I got all messed up and I couldn‚Äôt remember what we practised yesterday."
        show sc day3doghouse d81
        mc"It‚Äôs okay [c_name], I should never have put you in that situation to begin with."
        show sc day3doghouse d87
        c"(Sigh‚Ä¶ Mom is going to be so pissed with me, especially if the old man tells her that [y_name] broke into his house.)"
        show sc day3doghouse d81
        c"It‚Äôs okay, I‚Äôll figure out something with my Mom."
        $ trisha_points = change_stat(trisha_points,-3,"Trisha")
        c"I could perhaps explain to her why this guy wouldn‚Äôt hand over the documents." #-3 TRISHA POINTS"
        mc"Yeah, maybe she‚Äôll understand."
        c"All right, I better get going. Bye [y_name]."
        show sc day3doghouse d88
        mc"Bye [c_name]."
        # (C leaves)"
        mc"(Dammit. I really let her down. What on earth was I thinking trying to steal the documents? I‚Äôm no criminal.)"
        mc"(I better get to the church, as I‚Äôm already running way behind schedule!)"
        stop sound fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
        jump lb_day3_kristina_intro_late
    else:
        show sc day3doghouse d81
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        scene sc day3doghouse d81
        c"[y_name]? Are you okay? Did you get it?"
        show sc day3doghouse d91
        $ v_day3_doghouse_get_document = True
        mc"Yeah, I got it."
        show sc day3doghouse d83
        c"Oh my god!"
        show sc day3doghouse d95
        $ c_points = change_stat(c_points,5,c_name)
        c"You are so amazing [y_name]!!"
        # (Without thinking, cousin jumps up and hugs the MC)"
        show sc day3doghouse d96
        mc"Okay, okay. We better get out of here before the old man knows that something is up."
        show sc day3doghouse d142
        c"Quick! I think he‚Äôs coming! Follow me‚Ä¶"
        #(cousin grabs the MC‚Äôs hand and they hide)"
        stop sound fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
        #(starts with a shot of cousins face)"
        scene sc day3doghouse d135
        with dissolve
        play sound "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
        mc"Uh, are you sure this is the best place to hide [c_name]?"
        show sc day3doghouse d136
        if persistent.v_xray_enabled:
            show screen scr_peeping_tom("sc day3doghouse d136","sc day3doghouse d136x","v_pt_image_index_55")
        mc"(There‚Äôs hardly any room for us between these two houses.)"
        hide screen scr_peeping_tom
        show sc day3doghouse d137
        c"Sorry, I didn‚Äôt have much time to think [y_name]."
        show sc day3doghouse d138
        c"Oh shit! I think he‚Äôs looking over this way!"
        show sc day3doghouse d139
        mc"Hide!"
        #(C and the MC move out of sight, so that her ass is pressed up against the MC‚Äôs crotch, trying to stay out of sight)"
        show sc day3doghouse d140
        show screen scr_rewards("sc day3doghouse d140b","v_rewards_c_19")
        mc"Can you see him?"
        #(C peeks her head out)"
        c"No I can‚Äôt. But I think if we wait here for a few minutes, he may give up looking soon."
        hide screen scr_rewards
        show sc day3doghouse d139
        c"It‚Äôs just as well he didn‚Äôt let his dog loose, or he may have sniffed us out!"
        mc"Yeah. We should get out of here as soon as the old man heads back inside, just in case he does use his dog to try and locate us."
        show sc day3doghouse d141
        if persistent.v_xray_enabled:
            show screen scr_peeping_tom("sc day3doghouse d141","sc day3doghouse d141x","v_pt_image_index_56")
        c"(OH! I think I can feel [y_name]‚Äôs thing against my‚Ä¶)"
        stop sound fadeout 1.0
        #(final shot is the MC‚Äôs crotch against cousin‚Äôs ass)"
        # (screen goes blank)"
        hide screen scr_peeping_tom
        scene black
        with dissolve
        scene black
        with Pause (2)
        # (Cousin and the MC stand somewhere away from the house)"
        scene sc day3doghouse d101
        with dissolve
        mc"All right, here are the documents for Trisha. Looks like you‚Äôre all set."
        show sc day3doghouse d100
        c"I cannot thank you enough [y_name]. But I don‚Äôt know if what you did was incredibly brave, or incredibly stupid!"
        show sc day3doghouse d97
        mc"Maybe a bit of both, haha!"
        show sc day3doghouse d98
        mc"You should give yourself some credit too [c_name]."
        mc"If not for you distracting the old man, I may not have been able to escape without getting busted!"
        mc"What did you say to him anyway?"
        show sc day3doghouse d99
        c"I uh, I just did what you taught me."
        show sc day3doghouse d97
        c"I took my time when answering his questions, I kept my focus and made sure to breathe naturally."
        c"By doing that, I was able to stall him long enough to allow you to escape."
        c"I spoke to him about his dog and told him that you were going to get the money he asked for."
        mc"Oh wow, that was good thinking!"
        show sc day3doghouse d98
        mc"He‚Äôs going to be pissed when he doesn‚Äôt get the money and when he finds out that the documents are missing, but that‚Äôs his problem."
        mc"You did really well [c_name]." #+3 COUSIN POINTS"
        show sc day3doghouse d97
        c"It‚Äôs just as well that the dog was tied down though as well, hey?"
        mc"Yeah, I was shitting myself when he first made eye contact with me."
        mc"And his constant barking was making me sweat bullets."
        mc"Thank god it‚Äôs all over with now."
        c"All right, well I better get going [y_name]. Thanks again." #+2 COUSIN POINTS"
        # (Cousin kisses the MC on the cheek)"
        play sound "sound effects/01/01/short_kiss_sound_effect.mp3"
        show sc day3doghouse d102
        c"Mwah!"
        stop sound
        show sc day3doghouse d100
        c"We‚Äôll talk again soon."
        show sc day3doghouse d97
        mc"Bye [c_name]."
        # (C leaves)"
        show sc day3trishahouse t01
        mc"(Man, I was so lucky that I found those documents as quickly as I did.)"
        mc"(Anyway, I better get to the church, as I‚Äôm already running way behind schedule!)"
        scene black
        with dissolve
        scene black
        with Pause (2)
        jump lb_day3_kristina_intro_late




