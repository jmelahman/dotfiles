    show sc day3trishahouse t22
    c"Yeah, I promised her that I would pick them up, but I would wait for you to arrive."
    $ c_points = change_stat(c_points,-1,c_name)
    c"Please, come on in." #-1 Cousin Pt (for being late)"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)
