                    stop sound
                    $ v_minigame_clock += 1
                    show sc day3doghouse d39
                    mc"(All right, I‚Äôm almost there. Now to step forward, and‚Ä¶)"
                    # (MC stands on the dog‚Äôs squeaky chew toys) Squeaky noise - sound effect to be added"
                    play sound "sound effects/01/03/Squeaky noise - sound effect.mp3"
                    mc"(Uh-oh!)"
                    stop sound
                    # (Dog turns and sees the MC)"
