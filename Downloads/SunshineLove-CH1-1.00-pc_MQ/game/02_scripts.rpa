    mc"Oh, um, I‚Äôm standing on a bridge over a small stream of water in what looks like a local park. There‚Äôs uh, aw geez, trees, shrubs.."
    #(MC sees a monument)"
    show sc day3mclost l08
    mc"Hang on, there‚Äôs a monument here as well. And it has a plaque with writing on it."
    ash"What does it say?"
    #(MC stands in front of it, reads the plaque)"
    show sc day3mclost l09
    mc"Jeremiah Leapfield, founder of Sunshine Bay."
    show sc day3mclost l26
    ash"I know exactly where you are!"
    show sc day3mclost l29
    ash"Oh wow, you still have a fair walk to go before you get back to the hotel."
    show sc day3mclost l26
    ash"Let me guess, you were walking up a steep hill just now?"
    show sc day3mclost l28
    mc"Yes I was. And with this weather the way it is, and me not being used to it, it‚Äôs making the journey even more difficult."
    show sc day3mclost l26
    ash"I would‚Äôve thought a strong young man like yourself would be able to handle such a long walk regardless of the conditions."
    ash"However, it sounds like you‚Äôre heading in the wrong direction."
    ash"How about I come and pick you up? I‚Äôm pretty close by and I could take you back to the hotel."
    ash"And I‚Äôm sure you‚Äôd love some air conditioning right now, correct?"
    show sc day3mclost l28
    mc"I sure would! But you don‚Äôt mind coming to get me?"
    show sc day3mclost l27
    $ ash_points = change_stat(ash_points,2,"Ashley")
    ash"Not at all! You just stay right where you are, and I‚Äôll be there very soon!"
    show sc day3mclost l26
    mc"Thank you so much Ashley."
    mc"(If I didn‚Äôt know any better, I‚Äôd say she was talking to me completely naked! Or at the very least topless.)"
    mc"(Should I say something?)"
    # [Ask her / Don‚Äôt say anything]"
    menu:
        "Ask her"(wt="Best choice"):
            show sc day3mclost l28
            mc"Um, Ashley?"
            ash"Yes [y_name]?"
            mc"Sorry to ask, but, are you wearing any clothes right now?"
            show sc day3mclost l29
            ash"Excuse me?"
            show sc day3mclost l28
            mc"My apologies, but from this point of view, you look like you‚Äôre topless."
            show sc day3mclost l26
            ash"Oh, really?  Haha! Let‚Äôs find out then, shall we?"
            show sc day3mclost l31
            mc"(Oh god‚Ä¶)"
            # (Ashley pans the tablet camera down, shows her with a red dress on)"
            ash"Nope, I‚Äôm not topless [y_name]."
            show sc day3mclost l26
            mc"Oh, I am so sorry for being so presumptuous Ashley."
            show sc day3mclost l27
            ash"Don‚Äôt be. It‚Äôs actually quite funny, haha!"
            show sc day3mclost l26
            $ ash_points = change_stat(ash_points,2,"Ashley")
            ash"I like a guy who can make me laugh, especially when it‚Äôs unintentional." #+2 ASHLEY PTS"
            mc"Oh, well, you‚Äôre welcome."
            mc"(Oh I am such a jackass!)"
            ash"Stay right where you are, I‚Äôll come and pick you up shortly. Bye [y_name]."
            mc"Bye Ashley."
            stop ambient fadeout 1.0
        "Don‚Äôt say anything":
            show sc day3mclost l26
            mc"(On second thoughts, maybe I shouldn‚Äôt mention it.)"
            mc"(She could get embarrassed or it could turn out to be an uncomfortable talk for both of us.)"
            ash"Stay right where you are, I‚Äôll come and pick you up shortly. Bye [y_name]."
            mc"Bye Ashley."
            stop ambient fadeout 1.0
            # (call ends)"

    scene black
    with dissolve
    scene black
    with Pause (2)
    if v_day3_chouse_late == False and v_day3_doghouse_get_document == True:
        jump lb_day3_clothes_store_trisha
    else:
        jump lb_day3_clothes_store












label lb_day3_yuki_swimwear_store:
    # Day 3 (EOW) 18.1 -  The MC is picked up by Yuki - he goes with her to an swimwear store"
    # SCENE BEGINS"
    # (scooter sounds) Sound Effect required here"
    if _in_replay:
        if persistent.y_name == None:
            $ y_name = "MC"
        else:
            $ y_name = persistent.y_name

        if s_name == None:
            $ s_name = "S"
        else:
            $ s_name = persistent.s_name

        show screen toprightmenu

        play music "music/01/2936-fliegen-by-sascha-ende.mp3"

    $ v_day3_yuki_swim_call = True
    scene sc day3mclost l10
    with dissolve
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day3mclost l10","sc day3mclost l10x","v_pt_image_index_62")
    # (show Yuki riding towards the MC on her scooter, helmet on. She pulls up next to him)"
    play sound "sound effects/01/01/Moped_running_effect2.mp3" loop fadeout 1.0 fadein 1.0
    yuki"Hey [y_name]!"
    mc"Hey Yuki. Thanks again for helping out."
    hide screen scr_peeping_tom
    show sc day3mclost l11
    yuki"It‚Äôs my pleasure. Shall we go now?"
    yuki"You can just sit the toolbox on the floor between my legs."
    yuki"I have a spare helmet for you as well."
    # (Yuki hands him a helmet)"
    mc"Oh, thanks."
    show sc day3mclost l12
    yuki"I just have one condition before you get on."
    show sc day3mclost l13
    yuki"I need to buy something at the shopping mall and I need you to come with me, as I need a guy‚Äôs opinion."
    yuki"Do you have some time to spare?"
    show sc day3mclost l04
    mc"(Hmm‚Ä¶ [s_name] said that there was no need for me to rush back to the hotel, so spending some time with Yuki should be okay.)"
    mc"(I wonder what she needs to buy that requires my thoughts though?)"
    show sc day3mclost l06
    mc"Yeah, that should be fine."
    show sc day3mclost l11
    yuki"Great! Well, once you‚Äôve put on your helmet, hop on the back behind me."
    show sc day3mclost l05
    mc"(Here we go again‚Ä¶)"
    stop sound fadeout 1.0
    # (screen goes blank)"
    # (MC sits on the back of Yuki‚Äôs scooter)"
    # (scooter sounds) Sound Effect required here"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3yukiswimstore s01
    with dissolve
    # (Yuki and the MC arrive at the shopping mall)"
    yuki"Well, here we are. My scooter should be okay to leave here."
    yuki"Let‚Äôs start walking towards the store, shall we?"
    show sc day3yukiswimstore s03
    mc"Sounds good. I‚Äôll just have to bring the tools with me so they don‚Äôt get stolen."
    show sc day3yukiswimstore s01
    yuki"Of course."
    # (They start walking)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3yukiswimstore s07
    with dissolve
    yuki"So what did [s_name] need them for?"
    mc"The guy that hurt himself, Randy..."
    mc"He left them at this local church where he was fixing something, and he wasn‚Äôt able to pick them up due to his injury."
    mc"I‚Äôm guessing there are a few things [s_name] wants your Dad to fix at the hotel with these tools, if he‚Äôs up to it that is."
    mc"Have you spoken to your Dad since yesterday? I didn‚Äôt see him before I left the hotel this morning."
    show sc day3yukiswimstore s06
    yuki"I spoke to him a few hours ago, he said he was feeling better but not well enough to do too much work."
    mc"That‚Äôs good to hear."
    show sc day3yukiswimstore s07
    yuki"So, have you really been walking the whole time since you left the hotel before I came to pick you up?"
    mc"Yeah I have. Why?"
    show sc day3yukiswimstore s05
    yuki"Well some people in Sunshine Bay don‚Äôt mind walking, but they at least have a scooter or will hire one if they‚Äôre only in town for a short period of time."
    show sc day3yukiswimstore s09
    yuki"Maybe you should consider hiring one if you‚Äôre going to be here over the summer."
    show sc day3yukiswimstore s07
    mc"I would, but riding scooters isn‚Äôt my thing, to be honest with you Yuki."
    show sc day3yukiswimstore s09
    yuki"What‚Äôs the problem, are you afraid?"
    show sc day3yukiswimstore s06
    mc"(Why do people keep saying that?)"
    mc"Not at all."
    yuki"If riding one is an issue, then I could teach you how to some time [y_name]. It‚Äôs not that difficult."
    yuki"I mean, you can already see how having a scooter could have been a huge benefit to you today, right?"
    yuki"So what do you say? Would you like my help?"
    # [Agree / I‚Äôll think about it]"
    menu:
        "Agree"(wt="Best choice"):
            mc"(Hmm‚Ä¶ She makes a good point. I‚Äôm going to need some mode of transportation while I‚Äôm in town, even it means having a scooter of all things.)"
            show sc day3yukiswimstore s07
            mc"I think I‚Äôll take you up on that offer Yuki."
            mc"The only problem is I‚Äôm a little strapped for cash to buy one at the moment."
            show sc day3yukiswimstore s06
            yuki"That‚Äôs okay. My father has one at our family home that I‚Äôm sure he‚Äôll let you borrow."
            yuki"I could ask him for you if you‚Äôd like me to?"
            $ yuki_points = change_stat(yuki_points,2,"Yuki")
            mc"Yeah, that‚Äôd be awesome! Thanks Yuki, that‚Äôs really generous of you to offer." #+2 Yuki points"
            show sc day3yukiswimstore s09
            yuki"As I said, I‚Äôm more than happy to help."
        "I‚Äôll think about it":
            show sc day3yukiswimstore s07
            mc"(Hmm‚Ä¶ I‚Äôd like to keep my options open for now.)"
            mc"(However, I‚Äôm going to need some mode of transportation while I‚Äôm in town, even if it means having a scooter of all things.)"
            mc"Give me some time to think about it Yuki."
            mc"The reason being is that I‚Äôm a little strapped for cash to buy one at the moment."
            show sc day3yukiswimstore s06
            yuki"That‚Äôs okay. My father has one at our family home that I‚Äôm sure he‚Äôll let you borrow."
            yuki"I could ask him for you if you‚Äôd like me to?"
            mc"Oh really? That would be great if he can."
            $ yuki_points = change_stat(yuki_points,1,"Yuki")
            mc"Thanks Yuki, that‚Äôs really generous of you to offer." #+1 Yuki point"
            yuki"As I said, I‚Äôm more than happy to help."
    show sc day3yukiswimstore s05
    yuki"This is the place."
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC and Yuki stand inside the store)"
    scene sc day3yukiswimstore s11
    with dissolve
    mc"Okay, so what are we doing here Yuki?"
    show sc day3yukiswimstore s12
    yuki"Well, the summer has just begun as you know, and some people from college who I‚Äôve just become friends with recently invited me to go to the beach with them."
    yuki"It‚Äôs been a long while since I last bought a swimming costume or a bathing suit."
    show sc day3yukiswimstore s10
    yuki"I just wanted your opinion on a suit I had my eye on."
    mc"(This sounds like an unusual request.)"
    show sc day3yukiswimstore s11
    mc"Uh, I don‚Äôt mean to offend you Yuki, but maybe you could‚Äôve asked someone like [s_name] to join you here today for some ideas."
    mc"Or maybe one of these new friends of yours at college?"
    show sc day3yukiswimstore s12
    yuki"I thought about asking [s_name], but she‚Äôs been so stressed out with the hotel and not having Randy available, plus my father has not been overly well too as you know."
    yuki"And I need to get something today as we‚Äôre going to the beach tomorrow."
    show sc day3yukiswimstore s10
    yuki"I was going to come here alone, but that was before you called and I thought you might be interested in helping me."
    show sc day3yukiswimstore s11
    yuki"You are, aren‚Äôt you?"
    mc"(Sigh‚Ä¶ Well I couldn‚Äôt possibly say no to her. Maybe this situation isn‚Äôt as weird as I‚Äôm making it out to be.)"
    mc"Yes, of course."
    show sc day3yukiswimstore s10
    mc"All right, well how about you go and pick out this swimming suit you were thinking of buying, and then we could go from there?"
    yuki"Sounds good."
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day3yukiswimstore s16
    with dissolve
    yuki"Okay, just give me a minute or two. Wait right here and I‚Äôll call you when I‚Äôm ready."
    # (Yuki disappears)"
    show sc day3yukiswimstore s20
    mc"(What am I getting myself into by being here? Am I simply helping out a would-be friend?)"
    # (screen goes blank)"
    # (Yuki peeks her head over a curtain in the change room to get his attention)"
    yuki"Okay, I‚Äôm ready [y_name]. Please don‚Äôt laugh when I show it to you."
    mc"I promise I won‚Äôt."
    yuki"All right, here it goes‚Ä¶"
    # (Yuki comes out wearing one of these:"
    # (Yuki meekly parades it, what she‚Äôs wearing isn‚Äôt overly flattering)"
    if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
        window hide
        scene wip_02_yuki_swim1  at tt_top
        pause
        window show
    else:
        show sc day3yukiswimstore s22
    mc"(Hmm‚Ä¶ )"
    show sc day3yukiswimstore s22
    mc"(She looks like an Olympic swimmer!)"
    show sc day3yukiswimstore s25
    mc"(But perhaps that‚Äôs the look she feels most comfortable with.)"
    show sc day3yukiswimstore s22
    yuki"So, what do you think [y_name]?"
    show sc day3yukiswimstore s29
    yuki"Does it look good on me?"
    show sc day3yukiswimstore s30
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day3yukiswimstore s30","sc day3yukiswimstore s30x","v_pt_image_index_63")
    mc"Uhmm..."
    show sc day3yukiswimstore s31
    # [Very Nice / Something else]"
    hide screen scr_peeping_tom
    menu:
        "Very nice":
            show sc day3yukiswimstore s22
            mc"It looks very nice, a very conservative and smart-looking swimsuit."
            mc"Was that what you were aiming for?"
            show sc day3yukiswimstore s21
            yuki"Yeah I was. When I was growing up, my parents made me wear swimsuits like this one."
            yuki"So it always seemed like perfectly normal attire for me whenever we went swimming."
            show sc day3yukiswimstore s22
            mc"Was it a cultural thing for your parents to have you dress like that?"
            show sc day3yukiswimstore s24
            yuki"I guess so. And not just with my swimwear."
            show sc day3yukiswimstore s27
            yuki"My parents always made sure that I dressed quite modestly whenever we were out in public. Two-piece bikinis were forbidden."
            show sc day3yukiswimstore s26
            yuki"My father has been a lot more relaxed with this in recent years, but out of respect for him, I try to abide by family traditions."
            show sc day3yukiswimstore s22
            mc"I see. This looks great on you Yuki, so perhaps you should get this one."
            show sc day3yukiswimstore s23
            yuki"Thanks [y_name], I will!"
            show sc day3yukiswimstore s21
            yuki"Wait here while I get changed back into my clothes."
            show sc day3yukiswimstore s20
            mc"(Hmm‚Ä¶ I hope Yuki didn‚Äôt think I was simply agreeing with her.)"
            mc"(But who am I to try and talk her out of something she‚Äôs obviously comfortable wearing?)"
            mc"(Or did I miss something?)"
        "Something else"(wt="Best choice"):
            show sc day3yukiswimstore s22
            mc"It‚Äôs nice, but‚Ä¶"
            show sc day3yukiswimstore s24
            yuki"But what [y_name]?"
            show sc day3yukiswimstore s22
            mc"Don‚Äôt take this the wrong way Yuki..."
            mc"But it‚Äôs not quite what I was imagining when you said that you wanted to buy a swimsuit to wear to the beach."
            show sc day3yukiswimstore s26
            yuki"Oh.. Well what did you have in mind?"
            show sc day3yukiswimstore s22
            mc"Again, I don‚Äôt mean to offend you..."
            show sc day3yukiswimstore s41
            mc"But I was thinking you were going to wear something like this one."
            show sc day3yukiswimstore s40
            yuki"Oh! Oh no, I could never wear anything like that."
            mc"How come?"
            show sc day3yukiswimstore s24
            yuki"When I was growing up, my parents made me wear swimsuits like this one that I'm wearing."
            mc"So it was for cultural reasons why your parents chose for you to dress so conservatively?"
            show sc day3yukiswimstore s26
            yuki"I guess so. And not just with my swimwear."
            show sc day3yukiswimstore s24
            yuki"My parents always made sure that I dressed quite modestly whenever we were out in public. Two-piece bikinis were forbidden."
            show sc day3yukiswimstore s22
            yuki"My father has been a lot more relaxed with this in recent years..."
            yuki"But out of respect for him, I try to abide by family traditions. I just don‚Äôt want to offend anyone."
            mc"I see. However, I don‚Äôt believe you‚Äôd be offending anyone by wearing something like what's on this mannequin."
            mc"It seems like an outdated tradition if you don‚Äôt mind me saying so, and they‚Äôre only relevant in certain situations."
            mc"Our generation I believe is trying to create its own traditions and to also keep up with the times."
            show sc day3yukiswimstore s40
            yuki"Maybe you‚Äôre right. But unfortunately I don‚Äôt see myself wearing something like what that girl has on."
            show sc day3yukiswimstore s22
            mc"(Hmm‚Ä¶ It would be great to help Yuki break out of her shell a little.)"
            mc"Well, how about we choose something that won‚Äôt draw a lot of attention to you, but will still impress these new college friends of yours?"
            show sc day3yukiswimstore s39
            yuki"Which one are you suggesting [y_name]?"
            show sc day3yukiswimstore s22
            mc"I think I have one in mind. Go back into the change room Yuki, and I‚Äôll hand one over to you to try on."
            yuki"Okay, if you say so."
            scene black
            with dissolve
            scene black
            with Pause (2)
            scene sc day3yukiswimstore s20
            with dissolve
            mc"(I hope she likes the one that I've picked out for her.)"
            mc"(Nicole was a little trepidatious when she first tried on a new bathing suit in front of me, when we first started dating.)"
            mc"(Only weeks later, she tried on something similar to what I just gave Yuki...)"
            mc"(And she seemed gradually more comfortable with wearing eye-catching swimmers after that day.)"
            mc"(I felt pretty damn lucky when she wore that two-piece that I suggested for her, and she didn‚Äôt even hesitate to buy it!)"
            yuki"Okay [y_name], I‚Äôm coming out now."
            mc"All right, let‚Äôs have a look."
            if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
                window hide
                scene wip_02_yuki_swim2  at tt_top
                pause
                window show
            else:
                show sc day3yukiswimstore s33
            yuki"Hmm..."
            show sc day3yukiswimstore s33
            yuki"How‚Äôs this?"
            show sc day3yukiswimstore s43
            yuki"Do you like it?"
            show sc day3yukiswimstore s44
            # [It looks great / It works] "
            menu:
                "It looks great":
                    show sc day3yukiswimstore s42
                    mc"Oh wow! It looks great on you Yuki!"
                    show sc day3yukiswimstore s33
                    mc"You should definitely get it."
                    mc"And if you wanted to, you could try one of the other two-pieces that they have over there."
                    show sc day3yukiswimstore s32
                    yuki"Uh, thanks [y_name]."
                    show sc day3yukiswimstore s37
                    yuki"I‚Äôm glad you like it, but, I think I‚Äôm still going to get the first one that I tried on."
                    show sc day3yukiswimstore s33
                    yuki"This swimsuit just doesn‚Äôt feel like me, you know?"
                    mc"(Hmm‚Ä¶ I shouldn‚Äôt push her if she doesn‚Äôt feel right about it. It‚Äôs not really my place to.)"
                    mc"Sure Yuki, I understand."
                    mc"I mean if you‚Äôre not satisfied, then you should go with your instinct and what you feel most comfortable with."
                    show sc day3yukiswimstore s32
                    yuki"Thanks [y_name]. Give me a few minutes and I‚Äôll get changed back into my clothes, then I‚Äôll buy the first one."
                    mc"No problem Yuki."
                    # (Yuki disappears)"
                    show sc day3yukiswimstore s20
                    mc"(Sigh‚Ä¶ You can‚Äôt win them all I guess. She looked really good in that second outfit I thought.)"
                    mc"(But ultimately, that wasn‚Äôt enough to convince Yuki. I wonder what I could have done or said differently here‚Ä¶)"
                "It works"(wt="Best choice"):
                    show sc day3yukiswimstore s33
                    mc"You know what Yuki, this swimsuit looks a lot better on you than I thought it would. It works really well."
                    show sc day3yukiswimstore s38
                    yuki"Really? What makes you so sure?"
                    show sc day3yukiswimstore s33
                    mc"This one that you‚Äôre wearing kind of has the best of both worlds."
                    mc"It appeals to a lot of girls your age because of the designer attached to it, and it still gives you that conservative look that I know is important to you."
                    show sc day3yukiswimstore s36
                    yuki"(Oh my! How does he know so much about this kind of thing? I‚Äôm so glad I invited [y_name] to come along with me.)"
                    show sc day3yukiswimstore s32
                    yuki"You really seem to know a lot about swimsuits and bikinis [y_name]!"
                    mc"Haha! Well I‚Äôve seen plenty of women wearing them, but I‚Äôm hardly an expert. I just pay attention to the important details you see."
                    mc"So, do you think you‚Äôll get this one then?"
                    show sc day3yukiswimstore s34
                    $ v_day3_yuki_new_swimsuit = True
                    $ yuki_points = change_stat(yuki_points,2,"Yuki")
                    yuki"Yes, you‚Äôve convinced me [y_name]. I will definitely get this one." #+2 Yuki points"
                    show sc day3yukiswimstore s32
                    if persistent.v_xray_enabled:
                        show screen scr_peeping_tom("sc day3yukiswimstore s32","sc day3yukiswimstore s32x","v_pt_image_index_64")
                    mc"You‚Äôre welcome Yuki."
                    yuki"Wait right here while I get changed back into my clothes and then I‚Äôll pay for at the front counter."
                    mc"Great!"
                    # (Yuki disappears)"
                    hide screen scr_peeping_tom
                    show sc day3yukiswimstore s20
                    mc"(It‚Äôs great to see her try something different and I was able to convince her not to stick to an old tradition.)"
                    mc"(I‚Äôm sure she would‚Äôve looked drop-dead gorgeous in the two-piece, but it would have been wrong of me to force that opinion on her.)"
                    mc"(Maybe in time she‚Äôll want to try one of these other swimwear options that they have here‚Ä¶)"
                    # (screen goes blank)"



    # (Yuki and the MC outside the store)"
    scene black
