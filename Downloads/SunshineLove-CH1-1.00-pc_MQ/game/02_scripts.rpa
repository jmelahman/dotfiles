    jump lb_day3_mc_walks_back




label lb_day3_mc_walks_back:
    # Day 3 (EOW) 18 -  The MC walks back to the hotel"
    # SCENE BEGINS"
    # (MC walks to the lighthouse, carrying the toolbox. Show drops of sweat on the sides of his face and eyebrows)"
    # (Show the MC walking up a steep hill with the tools)"
    scene sc day3mclost l01
    with dissolve
    play ambient "sound effects/01/03/Morning Sound Effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(Man, this walk seems so much further on the way back!)"
    mc"(It doesn‚Äôt help that it‚Äôs mostly uphill, I‚Äôm carrying this heavy toolbox and it‚Äôs stinking hot today.)"
    show sc day3mclost l02
    mc"(I must be lost, as I think I‚Äôve passed these houses twice already!)"
    # (MC‚Äôs phone rings) Cell Phone Ring Sound Effect.mp3 to be added here"
    # [Answer your phone]"
    $ v_calling = True
    show sc day3mclost l15
    play sound "sound effects/01/02/Tablet_ringing_sound_effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(Oh, someone is calling.)"
    stop sound
    show sc day3mclost l18
    mc"Hello?"
    s"Hey [y_name]!"
    mc"Oh hi [s_name]."
    show sc day3mclost l16
    s"I was just checking to see if you were okay, because I hadn‚Äôt heard from you."
    mc"Yeah, I‚Äôm fine [s_name]. I got the tools you asked me to retrieve, but I might be a little late returning to the hotel."
    show sc day3mclost l18
    s"That‚Äôs okay, take your time."
    show sc day3mclost l19
    s"I‚Äôm still out with Jazmin at the moment, so I may be a bit late getting back myself."
    show sc day3mclost l16
    s"And if you try to ring me and I don‚Äôt answer, it‚Äôs probably because I‚Äôm riding my scooter."
    mc"That‚Äôs okay, I shouldn‚Äôt need you for anything until I return."
    show sc day3mclost l18
    s"All right, well as long as you‚Äôre okay. And [y_name]? Make sure to drink plenty of water, as it‚Äôs pretty hot outside today!"
    mc"Yeah, you‚Äôre not kidding!"
    show sc day3mclost l19
    s"Bye [y_name], I‚Äôll see you soon."
    show sc day3mclost l18
    mc"Bye [s_name]."
    # (call ends)"
    $ v_calling = False
    show sc day3mclost l07
    mc"(Damn, it really is hot out today!)"
    mc"(I think I‚Äôm going to need some help actually...)"
    show sc day3mclost l03
    mc"(But I can‚Äôt rely on [s_name] now, as she said she‚Äôs occupied with Jazmin.)"
    show sc day3mclost l01
    mc"(And I‚Äôm pretty sure that the three of us and this toolbox won‚Äôt all fit onto that little scooter of hers.)"
    show sc day3mclost l02
    mc"(I wonder who I could call that might be able to help me?)"
    $ v_calling = True
    show sc day3mclost l20
    show screen char_call_null
    mc"(All right, who should I call next?)"
    $ v_char_ashley_cancall = True
    $ v_char_yuki_cancall = True
    $ v_char_ashley_date = 2
    $ v_char_yuki_date = 1
    window hide
    $ renpy.choice_for_skipping()
    call screen char_call_active
    hide screen char_call_null
    # [Yuki / Ashley]"


label lb_day3mclost_yuki_call:
    hide screen char_call_null
    $ v_calling = False
    show sc day3mclost l21
    play sound "sound effects/01/02/Tablet_ringing_sound_effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(Hmm‚Ä¶ I know I‚Äôve only met her once, but Yuki seemed pretty friendly, and the kind of person who would be likely to help a person in need.)"
    mc"(Well, there‚Äôs only one way to find out‚Ä¶)"
    # [Call Yuki]"
    show sc day3mclost l22
    stop sound
    yuki"Hello?"
    jump lb_day3mclost_yuki_call_1

label lb_day3mclost_yuki_call_1:
    mc"Hi Yuki, this is [y_name]. We met yesterday at the hotel."

label lb_day3mclost_yuki_call_2:
    show sc day3mclost l25
    yuki"Yes of course! How are you?"
    show sc day3mclost l22
    mc"I‚Äôm in a bit of jam actually."
    mc"I had to pick some tools up for [s_name] and I‚Äôm currently on my way back, but I‚Äôm not quite sure where I am."
    mc"I would have called [s_name] but I know that‚Äôs she‚Äôs quite busy at the moment."
    show sc day3mclost l24
    yuki"Sure, I‚Äôd be happy to help as I know Sunshine Bay quite well."
    show sc day3mclost l22
    yuki"Can you describe to me where you are right now?"
    show sc day3mclost l24
    yuki"That way, it will give me an idea of how far you are from the hotel, and I should be able to direct you from there."
    show sc day3mclost l22
    mc"Oh, um, I‚Äôm standing on a bridge over a small stream of water in what looks like a local park. There‚Äôs uh, aw geez, trees, shrubs.."
    #(MC sees a monument)"
    show sc day3mclost l08
    mc"Hang on, there‚Äôs a monument here as well. And it has a plaque with writing on it."
    yuki"What does it say?"
    #(MC stands in front of it, reads the plaque)"
    show sc day3mclost l09
    mc"Jeremiah Leapfield, founder of Sunshine Bay."
    show sc day3mclost l25
    yuki"I know exactly where you are!"
    show sc day3mclost l23
    yuki"Oh wow, you still have a fair walk to go before you get back to the hotel."
    show sc day3mclost l24
    yuki"Let me guess, you were walking up a steep hill just now?"
    show sc day3mclost l22
    mc"Yes I was. And with this weather the way it is, and me not being used to it, it‚Äôs making the journey even more difficult."
    show sc day3mclost l24
    yuki"How about I come and pick you up? I‚Äôm probably about five minutes away and I could take you back to the hotel."
    mc"Oh, are you sure? You really don‚Äôt mind?"
    show sc day3mclost l25
    $ yuki_points = change_stat(yuki_points,2,"Yuki")
    yuki"Not at all! I‚Äôd be happy to help!"
    show sc day3mclost l24
    yuki"You just stay right where you are, and I‚Äôll be there before you know it!"
    mc"Thank you so much Yuki!"
    yuki"See you soon [y_name]."
    stop ambient fadeout 1.0
    # (call ends)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day3_yuki_swimwear_store
    # END SCENE"
    # NEXT SCENE (to be written): Day 3 EOW 18.1 - The MC is picked up by Yuki - he goes with her to a swimsuit store"


