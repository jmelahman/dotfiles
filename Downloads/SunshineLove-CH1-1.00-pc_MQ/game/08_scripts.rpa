        # ‚ÄúAdd these lines if the player is on the OPEN RELATIONSHIP path‚Äù"
        mc"(I made a deal with Nicole that if I did see anyone else while I was here in Sunshine Bay then it would be just for the summer.)"
        mc"(I‚Äôd return home to her and then we could try to start our relationship anew. And I‚Äôd also try and be a professional lawyer again.)"
        mc"(Hmm‚Ä¶ But the longer I stay here in town, the less I feel that becoming a lawyer is going to be my future path.)"
        mc"(Will my interest in staying with Nicole reduce significantly with every day that I‚Äôm away from her?)"
        mc"(Anyway, I should turn my attention to [s_name] for now.)"
    show sc w4eowbeachnight b101
    mc"[s_name], I‚Ä¶"
    mc"[s_name]?"
    # (Sis has fallen asleep)"
    mc"(Hmm‚Ä¶ I guess that [s_name] falling asleep shouldn‚Äôt be a surprise. It‚Äôs been a long day and the evening was quite eventful too, hehe.)"
    if v_w3_ashley_path:
        # ‚ÄúAdd these lines if the player is on the Ashley path‚Äù"
        mc"(Now that I‚Äôve slept with [s_name], I feel even more guilty about seeing her mother behind her back.)"
        mc"(If it wasn‚Äôt so late I‚Äôd be going over to Ashley‚Äôs place right now to talk things out with her‚Ä¶)"
        mc"(But she‚Äôs probably still busy with damage control after the festival was abandoned.)"
        mc"(Maybe I should try calling her in the next few days to find out what her real intentions are with me?)"
    if v_w3_c_path:
        # ‚ÄúAdd these lines if the player is on the Cousin path‚Äù"
        mc"(I like where things are going with [c_name] but she‚Äôs one person who I definitely wouldn‚Äôt want to let down either.)"
        mc"(I hope she understands that our relationship is strictly casual and that something more serious between us is very unlikely to happen.)"
        mc"(She has a good heart though, and one I definitely don‚Äôt want to break.)"

    # ‚ÄúAdd these lines if the player is on any of the other girls‚Äô paths - Trisha, Yuki, Vicky, The Twins, Connie, Jazmin, Kristina‚Äù"
    mc"(I have other options, but I don‚Äôt know what will happen there.)"
    mc"(Should I be spending all my free time with [s_name] or should I still continue making time with other girls during the summer?)"
    mc"(I‚Äôm sure I‚Äôll figure out what is best over the coming days.)"
    mc"(But for the next eight weeks, I still have to do what I was asked to when I was offered this job here in Sunshine Bay.)"
    mc"(And that is to help [s_name] make this hotel not only a success but to make it the best hotel in the entire town‚Ä¶)"
    # (MC kisses Sis on the forehead)"
    mc"Goodnight [s_name]‚Ä¶"
    # (Sis keeps her eyes closed and talks in her sleep)"
    show sc w4eowbeachnight b102
    s"Night [y_name]‚Ä¶ I love you‚Ä¶"
    mc"(Wow‚Ä¶ She really does love me. She‚Äôs even saying it while she‚Äôs half-asleep..)"
    mc"(I have a lot of crucial questions to ask and that need answering, but I‚Äôll worry about that tomorrow.)"
    mc"(But when I wake up in the morning, let the real game begin‚Ä¶)"
    $ v_chapter_1_finished = True
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_ch1_end

    # END OF CHAPTER 1 (*THIS IS SHOWN ON SCREEN)"
    # SCENE NOTES:"




label lb_w4eow_chapter1_end:
    $ quick_menu = False
    show main_screen
    $ v_transfer_name = renpy.input("This is the end of Chapter 1. Enter a name for this playthrough to save its choices for transfer to chapter 2, or leave blank to skip:")
    if v_transfer_name:
        if v_transfer_name in mp.ch1_ch2_transfer:
            menu:
                "You've already transferred a playthrough with that name. Would you like to overwrite it?"
                "Yes":
                    pass
                "No":
                    jump lb_w4eow_chapter1_end
        $ mp.ch1_ch2_transfer[v_transfer_name] = {
            'y_name': y_name,
            's_name': s_name,
            'c_name': c_name,
            'k_name': k_name,
            's_points': s_points,
            'c_points': c_points,
            'vic_points': vic_points,
            'tw_points': tw_points,
            'ash_points': ash_points,
            'yuki_points': yuki_points,
            'trisha_points': trisha_points,
            'jazmin_points': jazmin_points,
            'k_points': k_points,
            'connie_points': connie_points,
            'v_s_path': v_w4_s_path,
            'v_ashley_path': v_w3_ashley_path,
            'v_c_path': v_w3_c_path,
            'v_vicky_path': v_w2_mow_vicdate_sex,
            'v_yuki_path': v_w2_k_yuki_plane_lessons,
            'v_twins_ivy_path': v_w2_twins_ivy,
            'v_twins_lily_path': v_w2_twins_lily,
            'v_w4mow_roshi_nurse': v_w4mow_roshi_nurse,
            'v_jazmin_path': v_w2eow_jazmin_happyending,
            'v_trisha_path': v_day3_trisha_website,
            'v_k_path': v_w3eow_k_eve_date,
            'v_connie_path': v_w3eow_connie_path,
            'v_w2_nicole_open_relationship': v_w2_nicole_open_relationship,
            'v_w3eow_k_church_photo': v_w3eow_k_church_photo,
            'v_georgina_threesome': v_georgina_threesome,
            'v_w3eow_k_church_photo': v_w3eow_k_church_photo,
            'v_w4sow_c_surftable': v_w4sow_c_surftable,
            'v_w4eow_tw_nosex': v_w4eow_tw_nosex,
            'v_day1_tw_necklace': v_day1_tw_necklace,
        }
        python:
            try:
                mp.save()
            except:
                v_ch1_ch2_transfer_failed = True
        if v_ch1_ch2_transfer_failed:
            $ renpy.choice_for_skipping()
            "Your choices could not be transferred automatically. This is common on Android and does not indicate a problem with your device. Please save your game now, and then manually copy it to chapter 4's saves directory."

    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_ch1_thankyou_for_playing
