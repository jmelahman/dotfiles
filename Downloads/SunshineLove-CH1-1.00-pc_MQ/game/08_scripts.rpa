            k"No it‚Äôs not."
            k"You know that lying is a sin, don‚Äôt you [y_name]?"
            mc"Oh‚Ä¶"
            $ k_points = change_stat(k_points,-4,k_name)
            mc"(Hmm‚Ä¶ That wasn‚Äôt exactly smart of me to try and suck up to [k_name] like that.)" #-4 KRISTINA POINTS"
        "Blue"(wt="Best choice"):
            show sc w4eowmaskshop m23
