    if _in_replay:
        scene black
        with dissolve
        scene black
        with Pause (2)
    $ persistent.intro_03_wakes_mc_up = False
    $ renpy.end_replay()
    scene black
    with dissolve
    scene black
    with Pause (2)







label lb_intro_04_breakfast_suit:
    scene sc kitchen k01 with dissolve
    nic"So‚Ä¶ Do you think you‚Äôre ready for this today?"
    show sc kitchen k02
    mc"I sure hope so. It just never felt like it would happen."
    show sc kitchen k03
    mc"(I‚Äôve had several years of studying law, and followed that with an unpaid clerkship with Judge Rumpole.)"
    mc"(I‚Äôve sacrificed so much just to get to this point.)"
    mc"(There really is no reason why they wouldn‚Äôt deem me to be a fit and proper person for this next step.)"
    play sound "sound effects/01/00/Cell_phone_vibration.mp3" loop fadeout 1.0 fadein 1.0
    "(Phone buzzes)"
    show sc kitchen k07
    nic"Oh, I think your phone just went off [y_name]."
    menu:
        "Check your phone":
            stop sound
            show sc kitchen k08
            mc"Yeah, looks like it‚Äôs just a text message."
            mc"It‚Äôs from my boss!"
    show sc kitchen k06
    nic"What did he text you?"
    show sc kitchen k08
    mc"He‚Äôs asked for me to come in a half hour early today, before everyone else gets to the office."
    show sc kitchen k02
    mc"That sounds like good news then, right?"
    show sc kitchen k05
    nic"It seems that way. Perhaps he wants to speak to you in private before work commences for the day."
    show sc kitchen k02
    mc"(This is incredible. It‚Äôs finally going to happen. I can feel it.)"
    mc"Well then, I guess I better jump in the shower real quick after I finish my breakfast."
    mc"Will it be all right if we leave a little earlier than usual Nicole?"
    show sc kitchen k05
    nic"Yeah of course we can babe."
    nic"While I‚Äôm waiting to start work, I can do some reading in the coffee shop across the road from the firm."
    nic"It‚Äôs this case I‚Äôve just been assigned."
    show sc kitchen k02
    mc"That‚Äôs nice Nicky."
    show sc kitchen k05
    nic"It‚Äôs just as well we work in the same district, hey?"
    show sc kitchen k02
    mc"Haha, it certainly is! See you shortly‚Ä¶. "
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (screen goes blank)"
    scene sc kitchen k09 with dissolve
    mc"So, how do I look?"
    nic"You‚Äôre good to go [y_name]. You look very handsome, and a professional lawyer in waiting."
    mc"Thanks Nicky."
    show sc kitchen k14
    mc"I just wish I wasn‚Äôt so nervous."
    show sc kitchen k15
    nic"Just remember, think good thoughts."
    mc"Sure Nicky."
    show sc kitchen k13
    mc"Look, about this morning. Again, I‚Äôm really sorry."
    show sc kitchen k10
    nic"We have plenty to discuss [y_name]..."
    nic"About our jobs, our future plans, what we‚Äôre going to do once we pay off the mortgage."
    nic"But most importantly, we need to sit down and talk about us..."
    nic"And these arguments and disagreements we‚Äôve been having over the past few weeks."
    nic"It‚Äôs been pretty unhealthy for both of us."
    show sc kitchen k14
    mc"Yeah I know."
    show sc kitchen k13
    mc"We can‚Äôt keep putting off that talk, I certainly realise that."
    mc"(Landing this job will hopefully mean that Nicky and I won‚Äôt have anymore of the full-blown quarrels like the one we had last week.)"
    mc"(It‚Äôs been tough seeing her go to court everyday and then to come home to tell me all about it.)"
    mc"(I‚Äôm happy for Nicky sure, but I just want to have that experience and that position...)"
    mc"(So I can tell her about my day  with the same enthusiasm‚Ä¶)"
    show sc kitchen k15
    nic"All right, it looks like we‚Äôre ready."
    nic"How about I go and start the car up, and you can lock up the house and I‚Äôll meet you out front?"
    show sc kitchen k12
    mc"Sounds good hun. Hey, what‚Äôs the weather like out today?"
    show sc kitchen k10
    nic"I just checked before, it looks like it's going to rain again."
    show sc kitchen k14
    mc"That‚Äôs just great..."
    mc"(This shit weather is just never-ending‚Ä¶ I really hope this isn‚Äôt a sign of things to come today.)"
    show sc kitchen k15
    nic"I know it rains here a lot [y_name], but this is where some of the major law firms are, you know that."
    nic"But once we get more established and after you get this position today..."
    nic"Then we can travel and live anywhere in the world we want to."
    show sc kitchen k10
    mc"Yeah I know this Nicky, because I brought that up with you before we moved here."
    show sc kitchen k15
    nic"Look on the bright side‚Ä¶"
    nic"When we buy our dream house, then you‚Äôll never have to water the lawn, that is, if we decide to continue living here in the city."
    # (MC laughs halfheartedly)"
    show sc kitchen k12
    mc"Haha, touch√©!"
    show sc kitchen k14
    mc"However, it just feels like we never get the time to travel to warmer, sunnier places."
    mc"I mean, when was the last time we both had a proper holiday together?"
    mc"I‚Äôm starting to think that we‚Äôre kidding ourselves, and we haven‚Äôt done enough for ourselves these past few years."
    mc"We‚Äôre always working hard for someone else."
    show sc kitchen k15
    nic"[y_name], we own a wonderful apartment together."
    nic"It‚Äôs warm, cozy, and something we both wanted. Have we really not done anything for you and me?"
    mc"Well, when you put it like that."
    mc"I guess we‚Äôre doing okay for two people in their mid-twenties."
    show sc kitchen k13
    mc"(Still, is it so wrong that I want so much more?)"
    # (Nicole and the MC kiss)"
    show sc kitchen k17
    nic"Mwahh!"
    show sc kitchen k16
    nic"You‚Äôll do great today [y_name]. I have complete faith in you."
    nic"Today is the beginning of much greater things for both of us, I can feel it."
    mc"Thanks Nicky. All right, we better get going. I don‚Äôt want to be late, today of all days‚Ä¶"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)

label lb_intro_05_boss_meeting:
    # (SOW) 05 - MC meeting with his boss"
    # SCENE BEGINS"
    scene sc city c01 with dissolve
    play sound "sound effects/01/00/Thunder_sound_effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(Sigh‚Ä¶)"
    nic"Are you all right [y_name]?"
    mc"Yeah I think I‚Äôll be fine."
    mc"This damn weather. It‚Äôs like we‚Äôre living in bloody Arkham City!"
    show sc city c02
    nic"I know it‚Äôs frequently gloomy here [y_name] and it sometimes gets you down..."
    show sc city c03
    nic"But just remember what I said before, when you get this job today..."
    nic"Then we can then focus our attentions on moving to a place that‚Äôs a little sunnier."
    show sc city c06
    mc"Yeah, you‚Äôre right Nicky. I can‚Äôt let this beat me."
    show sc city c02
    nic"Before you head into the boss' office, just make sure to take a couple of deep breaths."
    mc"All right, I‚Äôll try and remember that."
    # (Nicole kisses him on the cheek)"
    show sc city c03
    nic"Good luck [y_name]. Give me a call once you‚Äôre out of the meeting."
    nic"Maybe we can have lunch together to celebrate?"
    show sc city c06
    mc"Oh right, sure we can Nicole. Anyways, I better get in there..."
    # (screen goes blank)"
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC in the bosses‚Äô office, he greets him before asking him to sit down)"
    scene sc city c08
    with dissolve
    mg"Morning [y_name]. Please, take a seat."
    mc"Yes Mister Gascoigne..."
    mc"(Hmm‚Ä¶ If I didn‚Äôt know any better, I‚Äôd say he‚Äôs not in a good mood.)"
    mc"(Hopefully that‚Äôs not a sign of things to come.)"
    show sc city c09
    mg"First off, I‚Äôd just like to say that I appreciate you coming in early this morning."
    show sc city c16
    mc"No problems boss."
    mc"You know that I will always go above and beyond for this firm, even at short notice."
    show sc city c10
    mg"Yeah your efforts have not gone unnoticed [y_name]."
    show sc city c16
    mc"(Well he sounds pretty impressed.)"
    mc"(It should be any minute now that he‚Äôll make me a senior associate with the firm.)"
    show sc city c12
    mg"Anyways, I don‚Äôt wish to keep you long [y_name]."
    mg"As I‚Äôm sure you‚Äôve been made well aware, there is a position available for an associate to move up and be made one of the senior lawyers at this firm."
    show sc city c16
    mc"(This is it.)"
    show sc city c11
    mg"(Sigh‚Ä¶)"
    mg"But unfortunately, the board have to decided to go with Grayson for that position."
    mg"I‚Äôm sorry to have to be the one to tell you."
    show sc city c15
    mc"(Grayson! They went with Grayson?? That little weasel.)"
    mc"(He‚Äôs been here a year less than I have!)"
    show sc city c13
    mc"I don‚Äôt understand boss."
    mc"You told me just last week that I had the makings of a great trial attorney someday."
    show sc city c11
    mg"I know what I said [y_name]."
    mg"But this wasn‚Äôt solely my decision."
    mg"It went to a vote with the board, and it was pretty unanimous in the end."
    mg"But if it makes you feel any better, my vote did go to you."
    show sc city c13
    mc"Thanks‚Ä¶ So what do I do now?"
    mc"Do I just continue to work here over the summer and hope that another position comes up in a few months time?"
    show sc city c11
    mg"Oh boy‚Ä¶ Sorry to make this news even worse [y_name] but, I‚Äôm going to have to let you go."
    show sc city c30 with vpunch
    mc"What?? Why?"
    show sc city c11
    mg"Again, it‚Äôs a board decision. It‚Äôs completely out of my hands."
    show sc city c31
    mc"But there must be some reason for this. I have a right to know."
    show sc city c11
    mg"Yeah you do. You‚Äôre one of our best junior associates [y_name]."
    mg"But the thing is, the firm has another up and coming junior associate that will work for nothing over the next few months and beyond."
    mg"My boss sees it as an opportunity to save the business some money, which is required now that Grayson has been made a senior associate."
    mg"Again, I‚Äôm real sorry that I‚Äôve had to do this."
    show sc city c13
    mc"I don‚Äôt know what to say. I‚Äôm at a loss for words. I really didn‚Äôt expect this when I got up this morning."
    mc"(What the hell am I going to do now??)"
    mc"(How on earth am I going to tell Nicole that I not only didn‚Äôt become a senior associate, but that I‚Äôm also out of a job??)"
    show sc city c12
    mg"Look, [y_name]‚Ä¶ Between you and me, this whole situation stinks."
    mg"I‚Äôm not happy about it, and I hate the fact that I had to be the one to deliver this news to you."
    show sc city c10
    mg"But if you need me to write you a reference, I‚Äôd be more than happy to do that for you."
    mg"And it would be from a partner from the best firm in town. This is at least something."
    show sc city c16
    mc"Yeah, that would be great."
    show sc city c12
    mg"Is there anything else you would like to discuss?"
    show sc city c13
    mc"No I‚Ä¶ I don‚Äôt think so."
    show sc city c17
    mg"Well in that case, allow me to walk you to the door."
    # (screen goes blank)"
    mg"Are you sure you‚Äôre going to be okay? That girlfriend of yours is still over at Midland & Dickens, isn‚Äôt she?"
    mc"Yeah she is. She‚Äôs doing really well actually."
    show sc city c13
    mc"(But not well enough for her to cover the mortgage on her own‚Ä¶)"
    show sc city c18
    mg"Sorry to see you go [y_name]."
    mg"But your huge contribution here I‚Äôm sure will bode well for your future in law."
    mg"You just hang in there buddy."
    mc"Thanks boss."
    show sc city c32
    play sound "sound effects/01/00/phone_ringing_effect.mp3" loop fadeout 1.0 fadein 1.0
    "(Phone rings)"
    # (the bosses phone rings, lights up)"
    mg"Uhh, excuse me for a moment, I think this is a pretty important phone call, so I‚Äôm gonna have to ask you to leave."
    show sc city c14
    mc"Oh, sure thing Sir."
    # (TB turns away from the MC, heads back to near his desk to answer the phone)"
    mg"God damn this phone for being stuck to the desk like this!"
    stop sound
    mg"Hello?"
    mg"Oh, it‚Äôs you Grayson. Yes, congratulations again son. We‚Äôre all very happy for you."
    mg"You‚Äôre gonna go far in this company."
    # (MC is about to leave)"
    show sc city c15
    mc"(Hmm‚Ä¶ It‚Äôs no wonder he wanted to get me out of his office in such a hurry.)"
    mc"(Just so he could chat to that prick Grayson.)"
    mc"(So much for my boss being sorry about having to let me go.)"
    show sc city c16
    mc"(Well, at least I know one way to get back at him for that...)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc city c33
    with dissolve
    mg"Yes Grayson, I‚Äôve been advised that your new position with the firm will start next Monday."
    mg"Excuse me for a moment, I just need to clear my throat."
    # (The boss turns and can‚Äôt find his mug)"
    mg"(Hmm.. Where did I leave my mug of tea? I could‚Äôve sworn I left it right here?)"
    # (MC is on the other side of the door)"
    show sc city c34
    mc"(It may not be a promotion, but sometimes the little things in life still manage to bring a smile to my face.)"
    # (MC lifts his hand up, and we see that he's swiped his bosses Spurs mug.)"
    show sc city c35
    mc"(Now to put this damn mug where it belongs‚Ä¶ In the trash!)"
    # (MC drops the mug in a trash can)"
    show sc city c36
    mc"(Sigh‚Ä¶ It‚Äôs going to be an even longer day now.)"
    # (the door closes)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc city c19
    mc"(Goddammit‚Ä¶)"
    show sc city c22
    mc"(I better call Nicole. She‚Äôs not going to believe this.)"
    $ renpy.sound.play("sound effects/01/01/Phone_call_sound_effect.mp3", loop=False, fadeout=1.0, fadein=1.0)
    show sc city c23
    "."
    ".."
    "..."
    stop sound
    nic"Hello?"
    show sc city c25
    mc"Hi babe..."
    nic"[y_name]! Wait, if you‚Äôre calling me already then that must mean-"
    mc"I didn‚Äôt make senior associate Nicole."
    nic"You what?? Why?"
    mc"They went with Grayson instead. Apparently it was a board decision."
    nic"They went with that little shit?! It sounds more like politics!"
    nic"I can‚Äôt believe he was chosen over you."
    nic"Okay, okay‚Ä¶ This is not the end of the world."
    nic"Let‚Äôs think about this logically. Maybe they‚Äôll have something in a few months time and-"
    mc"No Nicole! It‚Äôs not going to happen. They also let me go‚Ä¶"
    nic"Oh my god‚Ä¶ This is so not happening right now."
    nic"What the hell are we going to do??"
    mc"Well I‚Äôm going to go home Nicole."
    mc"It‚Äôs been an awful morning, and I need some time to process all of this, and then to look at my options."
    nic"All right, you go and do that. It will give me some time to calm down."
    nic"I‚Äôll um‚Ä¶ I‚Äôll see you at home tonight [y_name]."
    mc"(Nicky sounds pissed off rather than upset for me.)"
    mc"(I really could have done with some encouraging words from her.)"
    mc"Sure thing Nicky‚Ä¶"
    # (call ends)"
    # (MC stands outside the building, gloomy weather)"
    show sc city c22
    mc"(Sigh‚Ä¶)"
    mc"(What am I going to do for the rest of the day?)"
    show sc city c28
    f"[y_name], morning!"
    show sc city c20
    mc"Yeah, good morning Fletcher."
    show sc city c26
    f"Are you not heading in to work?"
    mc"No I, they just let me go."
    show sc city c27
    f"You were fired??"
    mc"Yeah, that promotion I told you about was given to Grayson."
    f"That asshole? Ohh man‚Ä¶ I‚Äôm so sorry."
    f"Most of us around the office were sure you were a lock for that position."
    f"So why did they let you go then?"
    mc"Budget cut-backs by the sounds of things."
    f"Wait, you don‚Äôt think they‚Äôre looking to fire anyone else, do you?"
    mc"I‚Äôm not sure."
    mc"But I think your position should be safe for now, and through until the end of the summer."
    mc"However, you may want to get in there if you‚Äôre running late."
    f"Yeah, I‚Äôm due to start shortly. Look, we‚Äôll catch up soon. Are we still on for FIFA tomorrow evening?"
    show sc city c19
    mc"Uhh‚Ä¶ We‚Äôll see. I still have to work out what kind of job I‚Äôm going to apply for."
    show sc city c26
    f"Yes of course."
    show sc city c29
    f"Again, really sorry to hear that man. I‚Äôll be in touch, and good luck."
    mc"Thanks Fletcher."
    # (Fletcher leaves)"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)





label lb_intro_06_nicole_job:
    scene sc apartm a01 with dissolve
    play sound "sound effects/01/00/raining_outside_sitting_inside_effect.mp3" loop fadeout 1.0 fadein 1.0
    mc"(Hmm‚Ä¶)"
    mc"(I know the weather here is like this pretty much all year round, but it‚Äôs really defining my mood right now.)"
    show sc apartm a02
    mc"(What I‚Äôd give to be able to afford to go on holiday, just to get out of town for a few weeks.)"
    show sc apartm a03
    mc"(Somewhere sunny would certainly be nice.)"
    show sc apartm a04
    mc"(Sigh‚Ä¶)"
    mc"(I could certainly do with a strong drink. I don‚Äôt care if it‚Äôs almost lunchtime, I‚Äôm making myself one.)"
    stop sound fadeout 1.0
    play sound "sound effects/01/00/Cell_Phone_Ring_Sound_Effect.mp3" loop fadeout 1.0 fadein 1.0
    show sc apartm a05
    "(Phone rings)"
    mc"(Fuck! Now what??)"
    # [Answer it]"
    stop sound
    show sc apartm a06
    mc"Hello?"
    nic"Hey it‚Äôs me. I have some good news for you, kind of."
    nic"I spoke with my boss, and he said he may be able to give you some kind of work at my firm, most likely an entry-level position."
    nic"But it won‚Äôt be available until after the summer is over."
    show sc apartm a08
    mc"That‚Äôs great Nicole but, that‚Äôs three months from now!"
    show sc apartm a09
    nic"Yeah, that‚Äôs why I said that it was kind of good news."
    nic"You will need to get some work over the summer, any kind of work until the position becomes available."
    mc"Hmm‚Ä¶ Any ideas for jobs I could apply for?"
    show sc apartm a06
    nic"Hey, I just did my part in setting up another job for you in law [y_name]!"
    nic"The least you can do is find something that will keep the money coming in for the next few months!"
    show sc apartm a08
    mc"Fine, fine‚Ä¶ You‚Äôre right. Sorry, it‚Äôs been such a nightmare of a day so far."
    show sc apartm a09
    mc"I just need some time to calm down and get myself together."
    nic"Well don‚Äôt take too long [y_name], because this is serious now."
    nic"I can‚Äôt make these repayments by myself. You have to be working."
    mc"I know..."
    mc"Look, I‚Äôm going to have some lunch and then I‚Äôll have a look online to see if there‚Äôs anything available."
    nic"Fine. Please try to find something before I get home."
    nic"It doesn‚Äôt matter what, just anything you will be qualified for."
    show sc apartm a08
    mc"Sure, no pressure."
    show sc apartm a09
    nic"Okay, I better get back to work. I‚Äôll see you tonight."
    mc"Bye Nicky, and thanks. Love you."
    nic"You too [y_name]."
    # (call ends)"
    show sc apartm a04
    mc"(Man‚Ä¶ When I woke up this morning I never would have imagined that I‚Äôd be looking for another job by lunchtime!)"
    mc"(I really don‚Äôt have a clue what kind of work I‚Äôm going to try and shoot for.)"
    mc"(Working in the fast food industry is out of the question, even if I did do that kind of work when I was a teenager.)"
    mc"(I‚Äôd rather slam my balls in a car door repeatedly than to ever do that kind of work again!)"
    mc"(Sigh‚Ä¶)"
    mc"(I have to at least have a look and see what I can find online, anything to tide me over for the next few months‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)




label lb_intro_07_mc_call_s:
