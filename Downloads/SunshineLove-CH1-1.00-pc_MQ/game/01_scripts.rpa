    scene black
    with dissolve
    scene black
    with Pause (2)


label lb_day2_painting_room:
    # (MOW) 01 - F shows the MC the room she was working on, started re-painting it"
    # - The MC is talking to his Best Friend"
    # SCENE BEGINS"
    # (F shows the MC the half-painted hotel room - make sure that most of the room is painted one colour, and there is a small patch on two walls that need to be finished)"
    scene sc day2paintingroom p01
    with dissolve
    s"So this is what I wanted to show you."
    # (MC looks around, sees that friend has been painting the room)"
    mc"Oh, so that explains the choice of attire."
    show sc day2paintingroom p04
    s"Haha, yeah."
    show sc day2paintingroom p02
    s"When you left this morning in a hurry, my first thought was to paint these rooms. I‚Äôm nearly done with this one, and I think that will do for today."
    show sc day2paintingroom p01
    mc"It looks like it will come up real good. So what prompted you to re-paint these hotel rooms [s_name]?"
    show sc day2paintingroom p03
    s"I guess that much like yourself, I knew that we needed to get a start on it at some point."
    show sc day2paintingroom p02
    s"So it looks like we‚Äôve both had very productive mornings, huh?"
    mc"Yeah, it seems that way."
    show sc day2paintingroom p03
    s"The other thing is I find that painting helps me to collect my thoughts and to compose myself again."
    show sc day2paintingroom p04
    s"It helped me to realise how badly I want the business to succeed."
    show sc day2paintingroom p02
    s"And with you here, and the help that we look like we‚Äôll be getting, I know we can do this, together."
    mc"Yeah, I believe we can too."
    show sc day2paintingroom p03
    mc"So um, would you like me to help you finish this room up? I see a spare couple of brushes over there."
    show sc day2paintingroom p02
    s"That would be great if you could."
    s"Mister Roshi has also been doing some work over on the west wing of the hotel, and once we‚Äôre done here, I‚Äôll take you over to him."
    mc"Sounds good."
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day2paintingroom p05
    with dissolve
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day2paintingroom p05","sc day2paintingroom p05x","v_pt_image_index_39")
    mc"(It was great to hear just how passionate [s_name] is about this place.)"
    hide screen scr_peeping_tom

    show sc day2paintingroom p06
    mc"(It certainly means a lot to her, and I already know that she would be devastated if she were to lose the hotel.)"
    show sc day2paintingroom p08
    s"How are you doing over there [y_name]?"
    show sc day2paintingroom p07
    mc"Oh, I'm good thanks."
    mc"But be careful and just focus on what you're painting [s_name]. You might fall if you don't keep your balance."
    show sc day2paintingroom p08
    s"Oh [y_name], I appreciate your concern but I know what I'm doing. Trust me, I've done this befo-"
    show sc day2paintingroom p10
    s"Oh shit!"
    # (friend drops her brush, we see a deep cleavage shot here as she looks down at the brush on the floor)"
    show sc day2paintingroom p11
    s"[y_name]!!"
    show sc day2paintingroom p12
    show screen scr_rewards("sc day2paintingroom p12b","v_rewards_s_15")
    show sc day2paintingroom p12
    with vpunch
    $ renpy.sound.play("sound effects/01/02/Ladder_crashing.mp3", loop=False, fadeout=1.0, fadein=1.0)
    s"Ohh!!"
    stop sound
    hide screen scr_rewards
    show sc day2paintingroom p13
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day2paintingroom p13","sc day2paintingroom p13x","v_pt_image_index_40")
    mc"(What happened just now? It was like everything was in slow motion‚Ä¶)"
    # (F strokes her brush over his nose)"
    hide screen scr_peeping_tom

    menu:
        "Told you so":
            show sc day2paintingroom p18
            mc"Well, I tried to tell you [s_name]." #-1 FRIEND POINT"
            show sc day2paintingroom p15
            $ s_points = change_stat(s_points,-1,s_name)
            s"Yeah, I know. Sorry [y_name], I can be so clumsy some times."
            show sc day2paintingroom p18
            mc"It‚Äôs fine."
            mc"Luckily I was in the right place at the right time."
        "Act concerned"(wt="Best choice"):
            show sc day2paintingroom p14
            mc"Are you okay?"
            s"Y-Yes..."
            show sc day2paintingroom p18
            mc"You were saying?"
            show sc day2paintingroom p17
            s"Haha, thanks for saving me [y_name]."
            $ s_points = change_stat(s_points,1,s_name)
            s"I can be so clumsy sometimes."


    show sc day2paintingroom p15
    s"Um, we should probably get back to work."
    # (MC looks cross-eyed at the glob of paint on his nose)"
    show sc day2paintingroom p18
    mc"Yeah, we should..."
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC and F stand there in the room, looking at the room completely painted, finished. MC still has the paint on his nose)"
    show sc day2paintingroom p19
    with dissolve
    mc"So, is this how you wanted it to look [s_name]?"
    show sc day2paintingroom p22
    s"Yep, it‚Äôs perfect."
    show sc day2paintingroom p20
    s"There are still a few more rooms I‚Äôd like to re-paint, but I‚Äôll get to them over the next couple of days. Thanks for your help."
    mc"Not a problem."
    show sc day2paintingroom p21
    mc"It‚Äôs been a while since we re-painted our apartment, but at least I‚Äôve had some practice now. So, shall we go and see Mister Roshi now?"
    show sc day2paintingroom p22
    s"I love your eagerness [y_name], but first we need to clean all of this up, as well as the brushes."
    show sc day2paintingroom p20
    s"Come on, let‚Äôs wrap up here and I‚Äôll take you to see the rooms Mister Roshi has been working on‚Ä¶"
    scene black
    with dissolve
    scene black
    with Pause (2)
    # END SCENE"
    # NEXT SCENE: MOW 02 - Friend shows the MC the rooms that Mister Roshi has worked on and has fixed - the west wing of the hotel"

label lb_day2_mr_roshi_meeting:
    # (MOW) 02 - Friend shows the MC the rooms that Mister Roshi has worked on and has fixed"
    # - The MC is talking to his Best Friend"
    # SCENE BEGINS"
    # (The MC and F have changed clothes now, wearing casual wear)"
    # (they enter the hotel room and find no one is in there)"
    scene sc day2roshiyuki y01
    with dissolve
    s"Mister Roshi, are you here?"
    # (Mister Roshi appears)"
    show sc day2roshiyuki y19
    ro"Hai‚Ä¶ I was just using restroom."
    show sc day2roshiyuki y09
    s"Have you noticed anything different with the room yet [y_name]?"
