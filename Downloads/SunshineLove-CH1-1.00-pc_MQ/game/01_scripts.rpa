    mc"I‚Äôm a little all over the place right now. Anyways, give me a call back when you get this. I really could do with hearing your voice. Love you."
    # (call ends)"
    show sc day2oceanlook l09
    mc"(Dammit‚Ä¶ I really hate leaving phone messages.)"
    jump lb_day3_mc_ocean_1

label lb_day3_mc_ocean_1:
    mc"(Nicole was all for me staying here to help [s_name] out with her business, so I should at least try to turn my focus to that‚Ä¶)"

label lb_day3_mc_ocean_2:
    mc"(Okay, I‚Äôve met a few people here in Sunshine Bay that seem like they want to help out or could be of great use to the hotel.)"
    mc"(Maybe I should get in contact with one of them? But who should I call first?)"
    mc"(Let‚Äôs look at my options here‚Ä¶)"
    stop ambient fadeout 1.0
    # (scene continues on the next document)"
    scene black
    with dissolve
    scene black
    with Pause (2)



label lb_day2_mc_call:
    # (SOW) 04 - MC makes a decision - to call cousin, to call Ashley, to call Victoria, or to The Twins"
    # *the player can one choose option here"
    # - The MC is talking to his Best Friend"
    # SCENE BEGINS"
    # (the MC still seated on the same hill, looking out at the ocean - https://thumbs.dreamstime.com/z/side-view-man-backpack-looking-sea-sitting-hill-against-sky-sunny-day-tourist-standing-top-raised-145097543.jpg )"
    scene sc day2call c01
    with dissolve
    $ v_calling = True

    $ v_char_ashley_cancall = True
    $ v_char_c_cancall = True
    $ v_char_victoria_cancall = True
    $ v_char_twins_cancall = True

    $ v_char_ashley_date = 1
    $ v_char_c_date = 1
    $ v_char_victoria_date = 1
    $ v_char_twins_date = 1
    show screen char_call_null
    mc"(All right, so I could call [s_name]‚Äôs cousin [c_name].)"
    mc"(But she did say that she‚Äôd call me if she was interested in helping us out with the hotel, and for my help interacting with people.)"
    mc"(Or I could call Ashley, to maybe get her advice and some background information on the hotel.)"
    mc"(It would be handy to know what it was like before she and [s_name] took over the rights.)"
    mc"(And I might be able to get a better understanding as to why there‚Äôs so much friction between her and [s_name].)"
    mc"(And maybe even between me and [s_name] too‚Ä¶)"
    mc"(I need to tread carefully if I do decide to see Ashley. But she did say that I could call her if I needed anything.)"
    mc"(I wonder if it would be too forward of me to call Victoria, the girl running the food truck?)"
    mc"(After our chat yesterday, I do feel like we had a similar understanding of the business and I‚Äôm sure we would have plenty to talk about.)"
    mc"(Plus I‚Äôd sure like to try some of the other menu options she has available.)"
    mc"(And then there‚Äôs the twins, Ivy and Lily. They both seemed pretty enthusiastic to work with both me and [s_name].)"
    mc"(They also seem to know how to run a business successfully, going by what I‚Äôve read about them online.)"
    mc"(Hmm‚Ä¶ This isn‚Äôt an easy decision. But the person I should call first is‚Ä¶)"
    window hide
    $ renpy.choice_for_skipping()
    call screen char_call_active
    hide screen char_call_null

    # [[c_name] / Ashley / Victoria / The Twins]"
label lb_day2_mc_call_c:
    hide screen char_call_null
    scene sc day2call c02
    play sound "sound effects/01/01/Phone_call_sound_effect.mp3" fadein 1.0
    mc"([c_name]...)"
    mc"(She probably knows [s_name] better than anyone.)"
    mc"(And if I can teach her how to be confident around other people, and how to talk to them, then I might be able to get her on board.)"
    mc"(I just need to convince her.)"
    stop sound
    show sc day2call c08
    c"Hello?"
    mc"Hello, [c_name]?"
    show sc day2call c09
    c"Hi‚Ä¶"
    # (Her face changes when she realises it‚Äôs the MC calling)"
    c"Hey, you‚Äôre‚Ä¶"
    show sc day2call c08
    jump lb_day2_mc_call_c_1

label lb_day2_mc_call_c_1:
    mc"Yeah it‚Äôs me, [y_name], [s_name]'s friend."

label lb_day2_mc_call_c_2:
    show sc day2call c07
    c"Oh, hey [y_name]!"
    show sc day2call c11
    c"Sorry, I didn‚Äôt recognise you right away! I‚Äôm still getting used to this face-calling thing."
    show sc day2call c08
    mc"That‚Äôs okay. [s_name] gave me her tablet to use while I‚Äôm here in town."
    mc"I hope you don‚Äôt mind, as she also told me that your number was listed in here already, just in case I ever needed to call you."
    show sc day2call c07
    c"Well you have‚Ä¶ And she gave me yours too! I was actually going to call you too."
    mc"You were?"
    c"Yeah, right after my next class finishes."
    show sc day2call c08
    mc"Okay‚Ä¶ So I was wondering, if you‚Äôre not doing anything afterwards, do you think we could meet up somewhere?"
    show sc day2call c07
    c"So we can talk about the hotel and various other things I take it?"
    mc"Exactly. So, how about it?"
    show sc day2call c08
    c"Is [s_name] coming with you?"
    mc"Uhh, she‚Äôs a little occupied at the hotel this morning, so it will just be me. Is that okay?"
    show sc day2call c07
    c"Sure, sounds good."
    show sc day2call c08
    mc"But where shall I meet you?"
    show sc day2call c07
    c"Check your phone after I hang up. I‚Äôll text you a time and place where you can meet me."
    mc"Okay, I shall await your text!"
    show sc day2call c10
    c"Haha! Bye [y_name], see you soon."
    show sc day2call c07
    mc"Bye [c_name]."
    # (face-calling ends)"
    show sc day2call c02b
    mc"(Great‚Ä¶ At least now I can get to know [c_name] a little better.)"
    mc"(I just have to make sure to ask her the right questions and to learn what I can about her.)"
    mc"(This should be fun‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day2_mc_c_date1
    # END SCENE"
    # NEXT SCENE: (SOW) 05 - MC visits Cousin"


label lb_day2_mc_call_ashley:
    hide screen char_call_null
    scene sc day2call c02
    # ‚ÄúAshley‚Äù"
    play sound "sound effects/01/01/Phone_call_sound_effect.mp3" fadein 1.0
    mc"(Ashley...)"
    mc"(I know that there are issues between them right now...)"
    mc"(But maybe if I learn more about why Ashley made the choices she did with regards to the hotel, then I could maybe understand where she‚Äôs coming from.)"
    mc"(I just hope she‚Äôs free today‚Ä¶)"
    stop sound
    show sc day2call c04
    # [Call her]"
    ash"Hello?"
    mc"Hello, Ashley?"
    show sc day2call c05
    ash"It is you [y_name]! I was hoping that you would call."
    show sc day2call c03
    mc"Haha, yeah it‚Äôs me. And you recognised me straight away this time!"
    ash"Well one doesn‚Äôt forget such a charming voice so easily young man. What can I do for you?"
    show sc day2call c04
    mc"Oh, well I was wondering if you‚Äôre not doing anything‚Ä¶ I‚Äôd like to take you up on your offer."
    mc"Are you free to meet up somewhere?"
    show sc day2call c05
    ash"As free as a bird. When would you like to meet?"
    show sc day2call c03
    mc"We could meet now if that‚Äôs okay?"
    ash"That works for me. Will my daughter be coming with you?"
    show sc day2call c04
    mc"Mmm‚Ä¶ No she won't. [s_name] is a little occupied at the hotel this morning, so it will just be me. Is that okay?"
    show sc day2call c03
    ash"Sure, that sounds perfect. So you have yourself a tablet I see?"
    mc"Yeah, I‚Äôm just borrowing it off [s_name] while I‚Äôm in town."
    show sc day2call c04
    mc"And she had your number in her contacts list."
    show sc day2call c06
    ash"I must say I‚Äôm surprised. I thought she would‚Äôve deleted it."
    show sc day2call c03
    ash"However, it‚Äôs good that you were able to call me."
    mc"Uh, yeah. So where shall I meet you?"
    show sc day2call c05
    ash"How about here at my house? I can text you my address shortly after our call ends."
    show sc day2call c03
    mc"Sure, that would be great."
    ash"All right, I‚Äôll see you soon [y_name]."
    mc"Will do. Bye Ashley."
    # (call ends)"
    show sc day2call c02b
    mc"(Hmm‚Ä¶ She didn‚Äôt seem too disappointed that [s_name] wasn‚Äôt coming with me to visit her.)"
    mc"(Nevertheless, it‚Äôs probably better that I‚Äôm going to see Ashley alone.)"
    mc"(Lord knows I don‚Äôt need to find myself in the middle of yet another shit-storm!)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day2_ashleydate1


label lb_day2_mc_call_victoria:
    # ‚ÄúVictoria‚Äù"
    hide screen char_call_null
    scene sc day2call c02
    play sound "sound effects/01/01/Phone_call_sound_effect.mp3" fadein 1.0
    mc"(Victoria...)"
    mc"(It‚Äôs probably a good time of day to go and visit her at the food truck, as she might still be setting it up.)"
    mc"(But I'll call her beforehand, rather than just turning up unannounced.)"
    mc"(That way I‚Äôll know for sure that I‚Äôm not imposing, or if it‚Äôs a bad time for her‚Ä¶)"
    mc"(This may be a good chance to learn more about how her business works...)"
    mc"(And to get a bit of a heads-up on how she deals with food preparation, distribution, plus supply and demand.)"
    mc"(Victoria came across as a highly intelligent woman, not to mention incredibly independent.)"
    mc"(And it sounded like she had a system already planned out even for a hotel restaurant environment.)"
    mc"(She also seems to be very close with [s_name], and maybe I can subtly ask her how they became friends.)"
    mc"(I still have this nagging feeling that I know Victoria from somewhere. Somewhere other than the sex dream I had of her with Nicole‚Ä¶)"
    mc"(It's weird...)"
    stop sound
    show sc day2call c17
    vic"Hello?"
    mc"Hello, Victoria?"
    vic"Uh, yes? Who is this?"
    jump lb_day2_mc_call_victoria_1

label lb_day2_mc_call_victoria_1:
    mc"It‚Äôs me, [y_name]. I met you at your food truck with my friend [s_name]."

label lb_day2_mc_call_victoria_2:
    show sc day2call c18
    vic"Oh right, yes, I remember."
    show sc day2call c17
    mc"Sorry to face-call you, I just thought it would be easier this way."
    show sc day2call c16
    vic"No problem. How can I help you?"
    show sc day2call c17
    mc"I was wondering if you had some time free for me to come by to see you at your work?"
    show sc day2call c16
    vic"Oh, have you and [s_name] decided to hire my services?"
    show sc day2call c17
    mc"Not exactly We‚Äôre still in the middle of discussions, but she‚Äôs a little tied up at the hotel this morning."
    mc"I just thought I‚Äôd call to let you know that I‚Äôm keenly interested in your line of work, and I‚Äôd like to learn more."
    mc"That is if you‚Äôre still willing to teach me and you have the time."
    show sc day2call c18
    vic"Oh, well that‚Äôs great to hear [y_name]."
    show sc day2call c19
    vic"Uhh, I‚Äôm just a little busy right now..."
    show sc day2call c16
    vic"But if you come by in about forty-five minutes, then I could spend about half an hour or so going through a few things with you."
    vic"Just the basics."
    mc"Sure, that would be great!"
    show sc day2call c18
    vic"All right, I guess I‚Äôll see you soon."
    show sc day2call c16
    mc"Yes, you will. Thanks, Victoria."
    vic"Bye [y_name]."
    # (call ends)"
    show sc day2call c02b
    mc"(Hmm‚Ä¶ She sounded like she was pretty flat out with her business. Hopefully I didn‚Äôt call her at a bad time and she was just being polite.)"
    mc"(If it gets too busy and it‚Äôs obvious that I‚Äôm in her way, then I could always step aside and reschedule.)"
    mc"(I‚Äôll see how things are when I get there‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day2_victoriadate1


label lb_day2_mc_call_twins:
    hide screen char_call_null
    scene sc day2call c02
    play sound "sound effects/01/01/Phone_call_sound_effect.mp3" fadein 1.0
    mc"(I think the best option would be for me to call the twins, Ivy and Lily.)"
    mc"(Aside from finding out why their business has been able to flourish ever since they began...)"
    mc"(I could subtly ask them how they can work together, given that they‚Äôre sisters.)"
    mc"(Maybe they have arguments and disagreements like me and [s_name] do?)"
    jump lb_day2_mc_call_twins_1

label lb_day2_mc_call_twins_1:
    mc"(They may also have some handy advice to offer that may help me to form a strong work partnership that I could have with [s_name].)"

label lb_day2_mc_call_twins_2:
    stop sound
    show sc day2call c12
    lily"Hello?"
    mc"Hello, is this Ivy?"
    show sc day2call c13
    lily"Uhh, no, I‚Äôm Lily. How many I help you, mister‚Ä¶?"
    show sc day2call c12
    jump lb_day2_mc_call_twins_3

label lb_day2_mc_call_twins_3:
    mc"This is [y_name], [s_name]‚Äôs friend. We spoke yesterday at the cafe."

label lb_day2_mc_call_twins_4:
    show sc day2call c14
    lily"Oh right, I thought you looked familiar. How are you doing [y_name]?"
    mc"I‚Äôm fine thanks. Yourself?"
    lily"Pretty good as well. Were just going through some preparations for a function we‚Äôre organising this weekend."
    show sc day2call c15
    lily"Never a dull moment!"
    show sc day2call c14
    mc"Sounds like it!"
    show sc day2call c12
    mc"By the way, sorry about calling you by your sister‚Äôs name. My fifty-fifty guesses never seem to come off."
    show sc day2call c15
    lily"Haha, no problems, it happens all the time."
    show sc day2call c14
    lily"I take it that you and [s_name] have decided on if you would like to hire our services for her hotel?"
    show sc day2call c12
    mc"Well, not quite. I was wondering if it would be possible for me to come and meet you and Ivy sometime today?"
    mc"I‚Äôd like to discuss a few more things with you both before making a final decision."
    lily"Hmm‚Ä¶. Yeah, I think we can fit you in."
    show sc day2call c13
    lily"But you‚Äôd have to get here within the next half an hour, as we have some clients to attend to at lunchtime today."
    show sc day2call c12
    lily"Do you think you can get here by then?"
    mc"I guess it all depends on where your office is."
    show sc day2call c14
    lily"Oh right, sure. It‚Äôs about a ten-minute drive from the hotel. So how about you meet me and Ivy here at our office?"
    lily"I can text you the address details once you get off the phone."
    mc"That would be great! All right, Lily, I‚Äôll see you and your sister very soon."
    show sc day2call c15
    lily"Looking forward to it! Bye [y_name]."
    show sc day2call c14
    mc"Bye‚Ä¶"
    # (call ends)"
    show sc day2call c02b
    mc"(Hmm‚Ä¶ She seems quite nice to talk to over the phone, as well as in person.)"
    mc"(Anyways, I better see how long it will take to walk to this office of theirs once she sends the address details through‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_day2_twins_date1





label lb_day2_mc_c_date1:
    # (SOW) 05 - MC visits Cousin"
    # - The MC is talking to his Best Friend"
    # SCENE BEGINS"
    # (MC arrives at the cafe by the beach) "
    $ v_calling = False
    $ v_char_c_cancall = False
    $ v_char_c_date = 2
    scene sc day2cdate1 c01
    with dissolve
    play ambient "sound effects/01/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
    show screen scr_rewards("sc day2cdate1 c01b","v_rewards_c_07")
    mc"(I think this is the place [c_name] asked me to meet her.)"
    c"Over here [y_name]!"
    # (Cousin waves from where she is standing/sitting)"
    mc"(Oh, there she is.)"
    hide screen scr_rewards
    show sc day2cdate1 c02
    c"Thanks for meeting me here."
    show sc day2cdate1 c03
    c"I um, I hope this place is okay?"
    # (Cousin is noticeably nervous being alone with the MC)"
    mc"Yeah, it‚Äôs nice. Thanks again for agreeing to meet with me."
    show sc day2cdate1 c05
    c"Well, self-improvement is something I always tell myself that I‚Äôm going to work on..."
    show sc day2cdate1 c04
    c"So um, I figured that I should grab that opportunity now, while you were offering the help."
    show sc day2cdate1 c03
    mc"Well how about we take a seat, and then we can go through a few things that we briefly discussed yesterday."
    show sc day2cdate1 c02
    c"Sure, that would be great."
    # (screen goes blank)"
    # (C and the MC are seated)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day2cdate1 c07
    with dissolve
    mc"So before we get started, how was your course this morning, if you don‚Äôt mind me asking?"
    show sc day2cdate1 c09
    c"Yeah it was okay."
    c"I pretty much understand almost everything a person needs to know about running a hotel."
    show sc day2cdate1 c08
    c"But as you know, talking to people isn‚Äôt exactly my strong suit."
    show sc day2cdate1 c12
    show screen scr_rewards("sc day2cdate1 c11b","v_rewards_c_08")
    c"I actually feel nervous sitting with you."
    hide screen scr_rewards
    show sc day2cdate1 c07
    mc"Well to be honest, I think you‚Äôre doing just fine."
    show sc day2cdate1 c09
    jump lb_day2_mc_c_date1_1

label lb_day2_mc_c_date1_1:
    c"Yeah, but I think that‚Äôs because you‚Äôre friends with [s_name]. I know I can trust you."

label lb_day2_mc_c_date1_2:
    mc"(At least she‚Äôs honest, unlike someone else I know‚Ä¶)"
    show sc day2cdate1 c11
    c"I know this is going to sound strange, but when we met yesterday, I felt like we already knew each other."
    show sc day2cdate1 c12
    c"Like a weird kind of connection. I normally don‚Äôt feel that with anyone. "
    c"Strange, huh?"
    show sc day2cdate1 c07
    mc"Haha, it sure is."
    mc"Well, what I think might help you [c_name] is that you should try and put those kind of thoughts in your head, whenever you meet other people for the first time."
    show sc day2cdate1 c08
    c"I could try, but I think a big part of my mind would know that it‚Äôs a lie. My brain works a little differently to most normal people."
    show sc day2cdate1 c11
    mc"If it‚Äôs okay to ask, where do you think these confidence and anxiety issues stem from?"
    show sc day2cdate1 c08
    c"I think it all started from my early childhood. I didn‚Äôt have a lot of friends, mainly because I was a bit of a nerd in high school."
    show sc day2cdate1 c12
    c"Without tooting my own horn too much, I‚Äôve always been academically gifted."
    c"I was always top of my class and I had one of the highest IQ‚Äôs in this part of the world when I was fifteen."
    show sc day2cdate1 c07
    mc"Is that right? Well that‚Äôs very commendable [c_name]. Your parents must be really proud of you."
    show sc day2cdate1 c08
    c"Yeah, about that. My mother raised me from the day I was born, and I um, I‚Äôve never met my father."
    mc"Oh, I‚Äôm really sorry to hear that."
    show sc day2cdate1 c09
    c"Nah it‚Äôs okay. I made peace with that a long time ago."
    show sc day2cdate1 c12
    c"But I think not having him around or not having a father figure at home may have affected my ability to socialise with many people."
    c"I don‚Äôt know, it‚Äôs probably a stretch."
    show sc day2cdate1 c07
    mc"Did your mother not have any male companions while you were growing up?"
    c"Yeah she did, but they weren‚Äôt exactly serious enough relationships for her to consider it worth any of these guys moving in with us."
    show sc day2cdate1 c08
    c"Or for her to properly introduce me to them."
    mc"(It sounds like she wasn‚Äôt the only one affected by her father‚Äôs absence.)"
    show sc day2cdate1 c07
    mc"Okay, well that gives me a bit more of an idea."
    mc"Look, thank you for being so open with such personal details [c_name]."
    mc"I imagine that couldn‚Äôt have been easy for you to tell me."
    show sc day2cdate1 c09
    c"It‚Äôs fine. It‚Äôs a part of my life, but I still managed to get through high school and into the college I wanted."
    show sc day2cdate1 c11
    c"And as you probably know already, half the rights of the hotel are now legally mine."
    show sc day2cdate1 c07
    mc"Yeah your aunt mentioned this to me briefly. How do you feel about that?"
    show sc day2cdate1 c09
    c"At first I was fine with her handing it over to me, as I saw it as a great investment."
    show sc day2cdate1 c08
    c"But now with it not doing so well, it‚Äôs started to become a little overwhelming."
    c"I really do want to help you and [s_name] out, and I really should do given that my name is attached to the business."
    c"But I don‚Äôt know how I‚Äôll be able to do that if I‚Äôm unable to overcome this social anxiety that I‚Äôm carrying with me wherever I go."
    show sc day2cdate1 c12
    c"Hmm‚Ä¶ Now that I have the partial rights to the hotel, and how things have turned out since then, perhaps I‚Äôm not as smart as I thought I was."
    show sc day2cdate1 c07
    mc"Haha, you shouldn‚Äôt beat yourself up over that."
    mc"You couldn‚Äôt have known that the business would take a turn for the worse."
    mc"Look, you‚Äôve made the first step, which was to ask for help, and it‚Äôs why I‚Äôm here."
    mc"I think I know what we need to do. Stand up for me."
    show sc day2cdate1 c11
    c"Huh?"
    mc"Trust me. We need to go somewhere else, some place away from here."
    show sc day2cdate1 c12
    c"Okay, but where?"
    show sc day2cdate1 c07
    mc"Well we should go somewhere with not too many people."
    mc"It should be a place that you‚Äôll feel comfortable and where we won‚Äôt be interrupted."
    mc"Ah! I got it!"
    mc"Follow me‚Ä¶"
    show sc day2cdate1 c11
    c"Oh, okay‚Ä¶"
    stop ambient fadeout 1.0
    # (C raises an eyebrow, suspicious as to where he wants to take her)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day2cdate1 c13
    with dissolve
    show screen scr_rewards("sc day2cdate1 c13b","v_rewards_c_09")
    # (MC takes C down to the beach)"
    play sound "sound effects/01/00/Beach_Ocean_Waves_-_Sound_Effect_decreased.mp3" loop fadein 1.0
    c"What are we doing here [y_name]?"
    hide screen scr_rewards
    show sc day2cdate1 c16
    mc"As I said, I wanted you to bring you somewhere where you‚Äôd feel right at home."
    mc"A place that I‚Äôm sure you regard as one of your happy places!"
    show sc day2cdate1 c20
    c"Okay, I see... Thanks."
    show sc day2cdate1 c16
    c"So now that we‚Äôre here, what did you have in mind?"
    mc"What I was hoping to do is to work on little areas for where your social anxiety starts."
    mc"And how I‚Äôd like to do that, is to give you situations and tasks that a hotel receptionist would deal with on a daily basis."
    mc"As you would know from your course and having seen the set up at the hotel..."
    mc"The kind of jobs you would be required to do would be things like talking clearly and confidently to guests, chatting with them over the phone..."
    mc"And being able to handle two or more conversations or calls at once."
    mc"That can be quite overwhelming for someone who is not prepared properly or is not in the right frame of mind."
    show sc day2cdate1 c15
    c"Okay, so what is your solution?"
    show sc day2cdate1 c16
    mc"Well what I‚Äôd like to do today is to help clear your mind of any anxieties you may have right now. To help you to find your centre."
    mc"Of course, I can‚Äôt help you fix everything in one day, but hopefully, I can make you feel better about yourself once we‚Äôre done here."
    mc"If all goes well, then we can try something different next time. So what do you say? Are you ready to give it a go?"
    show sc day2cdate1 c14
    c"Uhh sure, but what did you have in mind exactly?"
    show sc day2cdate1 c19
    mc"Well whenever I‚Äôve found myself having some self-doubt, I take the time to meditate."
    show sc day2cdate1 c17
    c"Haha, seriously?"
    show sc day2cdate1 c16
    mc"Yeah, you‚Äôd be surprised how much it can help."
    show sc day2cdate1 c21
    c"No offence [y_name], but I‚Äôve read that a lot of people meditate because they see it as a quick fix to reducing stress and anxiety."
    show sc day2cdate1 c16
    mc"No, it‚Äôs in no way a quick fix, far from it."
    mc"And you‚Äôre right, many people have the misconception that meditation is like a magic elixir."
    mc"But the primary purpose of meditation isn‚Äôt to melt your anxiety."
    mc"Instead, it‚Äôs to help you become more present right now, in this very moment."
    mc"The anxiety reduction is just a pleasant side effect. We often experience anxiety because we fixate on the past or the future."
    mc"However, when you‚Äôre meditating, you‚Äôre intentionally focused on the here and now. Does that make sense?"
    show sc day2cdate1 c14
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day2cdate1 c14","sc day2cdate1 c14x","v_pt_image_index_28")
    c"Hmm‚Ä¶ Yeah, that seems a bit clearer to me now."
    hide screen scr_peeping_tom

    show sc day2cdate1 c19
    mc"So, would you like to try some meditating with me?"
    show sc day2cdate1 c20
    c"(Sigh‚Ä¶)"
    c"Okay, I‚Äôll give it a try. I consider myself to be someone who always tries something at least once."
    c"(The least I could do is humour the guy.)"
    show sc day2cdate1 c16
    mc"Great! So I‚Äôll get you to sit down and face me, then cross your legs, and place your hands on your thighs or knees, whatever is comfortable for you."
    show sc day2cdate1 c15
    c"Sure."
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc day2cdate1 c45
    with dissolve
    play sound "sound effects/01/01/Beach_Ocean_Waves_-_Sound_Effect.mp3" loop fadeout 1.0 fadein 1.0
    show screen scr_rewards("sc day2cdate1 c45b","v_rewards_c_10")
    c"Okay, what now?"
    mc"So what I‚Äôm going to teach you here today, I‚Äôd like you to put into practise at home, or even when you come down here for a surf."
    hide screen scr_rewards
    show sc day2cdate1 c22
    mc"So‚Ä¶"
    # ***The mini-game has to be related to the service or skill they want to bring to the hotel."
    # This is an activity the cousin could do that will help her with her social anxiety issues."
    # - Three options per step. If the player gets one wrong, then they have to go back to the start again."
    # - Once they get all four right in the correct order, then they can proceed to the next scene in the game."
    # They will also gain a gold star for ‚Äúreceptionist‚Äù (more on this at another time)"
    # - The walkthrough will help players for this scene with the right combination."
    # *FIRST PART (*START HERE if the player failed to get the right combination)"
    # [Close your eyes / Keep your eyes open / Smile]"
    menu:
        "Close your eyes"(wt="Best choice"):
            $ v_c_date1_choice1 = True
            show sc day2cdate1 c22
            mc"‚Ä¶first off, close your eyes [c_name], and I‚Äôll do likewise."
            show sc day2cdate1 c26
            show screen scr_rewards("sc day2cdate1 c29b","v_rewards_c_11")
            mc"Having your eyes closed will help you to shut off one of your senses."
            hide screen scr_rewards
            show sc day2cdate1 c22
            mc"Meditation helps with anxiety and it also helps to shut off an overactive brain."
            mc"It sometimes can feel like your mind is like a hamster on a wheel; constantly running, but not really getting anywhere, am I right?"
            show sc day2cdate1 c24
            c"Yes, most definitely!"
            show sc day2cdate1 c29
            mc"All right, so that‚Äôs the first step."
        "Keep your eyes open":
            show sc day2cdate1 c22
            mc"‚Ä¶first off, keep your eyes open, and look directly at me."
            show sc day2cdate1 c23
            c"Uhh, okay‚Ä¶"
            # (C keeps her eyes open)"
            show sc day2cdate1 c27
            mc"Just focus on me for now, nothing else."
            c"Sure, I can do that."
            c"(This is strange.)"
            show sc day2cdate1 c22
            mc"Great. Now, slowly close your eyes for me, as you will need to shut down that overactive brain of yours."
            show sc day2cdate1 c29
            c"Okay‚Ä¶"
        "Smile":
            show sc day2cdate1 c22
            mc"‚Ä¶first off, smile! Meditating is meant to be an enjoyable experience, so let‚Äôs make it look like we‚Äôre at least enjoying ourselves!"
            show sc day2cdate1 c24
            c"Uhh, okay‚Ä¶"
            # (C keeps her eyes open)"
            show sc day2cdate1 c28
            mc"Just focus on me for now, nothing else."
            c"Sure, I can do that."
            c"(This is strange. And am I still meant to be smiling? I feel like an idiot!)"
            # (Cousin is still smiling, looks silly)"
            show sc day2cdate1 c24
            mc"Great. Now close your eyes for me, as you will need to shut down that overactive brain of yours."
            show sc day2cdate1 c29
            c"Okay‚Ä¶"
    # (scene continues)"
    show sc day2cdate1 c29
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc day2cdate1 c29","sc day2cdate1 c29x","v_pt_image_index_29")
    mc"Right, so now I want you to imagine you‚Äôre sitting behind the desk at the hotel."
    mc"You have two or three phone lines going at the same time. What are you going to do?"
    hide screen scr_peeping_tom

    show sc day2cdate1 c31
    c"I uhh‚Ä¶ I don‚Äôt know."
    # (Cousin has a panic-stricken look on her face)"
    # *SECOND PART"
    # [Keep your eyes closed / Open your eyes / Breathe naturally]"
    show sc day2cdate1 c30
    menu:
        "Keep your eyes closed":
            mc"Keep your eyes closed."
            mc"Forget about the desk, forget about the multiple phone‚Äôs ringing that you need to attend to."
            mc"They‚Äôre not there, neither are you. None of it is. Okay?"
            show sc day2cdate1 c31
            c"Uhh, okay‚Ä¶"
            show sc day2cdate1 c30
            c"(Is there a point to any of this?)"
        "Open your eyes":
            show sc day2cdate1 c29
            mc"Open your eyes for a second [c_name]."
            # (Cousin opens her eyes)"
            show sc day2cdate1 c26
            mc"Tell me what you see?"
            show sc day2cdate1 c22
            c"Uhh, I see you. I see the ocean."
            c"And the lighthouse behind you in the distance."
            show sc day2cdate1 c26
            mc"Exactly! So you‚Äôve already forgotten about the desk or the multiple phone calls you need to attend to."
            mc"They‚Äôre not there, neither are you. None of it is. Okay?"
            show sc day2cdate1 c27
            c"Uhh, okay‚Ä¶"
            c"(Is there a point to any of this?)"
            mc"Now close your eyes again."
            # (C closes her eyes)"
            show sc day2cdate1 c29
            c"Okay..."
        "Breathe naturally"(wt="Best choice"):
            $ v_c_date1_choice2 = True
            show sc day2cdate1 c29
            mc"Just breathe naturally [c_name], and make no effort to control your breaths."
            show sc day2cdate1 c30
            mc"You see, when we have something that overwhelms us, we get anxious because we buy into our thoughts and feelings."
            mc"Yet our thoughts don‚Äôt warrant this undivided attention."
            mc"Again, it‚Äôs just our minds spinning a slew of worries and what-ifs."
            mc"Meditating helps us to stop over-attending to our thoughts and feelings and allows us to get off the wheel..."

            mc"To catch our breath, and to get some perspective."
            mc"With practise you‚Äôll learn that when these situations arrive, to close your eyes, take a deep breath, and regain your centre."
            mc"And then when you‚Äôve found it, what would normally be an overwhelming task will become simple, in time."
            show sc day2cdate1 c31
            c"Okay, my eyes are closed, and take normal breaths."
            mc"How are you feeling now?"
            show sc day2cdate1 c29
            c"A little better. So what next?"
    # (scene continues)"
    mc"For this last part, I want you to keep the same frame of mind."
    mc"Ultimately, meditation helps us to slow things down, to get some perspective, and to think more objectively and with less of a knee-jerk reactivity."
    mc"And that in the long-run helps a person to be or feel less anxious."
    mc"So this time, I want you to picture that you have an important business client at your front counter."
    show sc day2cdate1 c30
    mc"They‚Äôre angry with the state of their room, and they want to speak to a manager."
    mc"What are you going to do?"
    c"I‚Ä¶ Uhh..."
    show sc day2cdate1 c29
    mc"Let me help you out with that. This is what you would need to do."

    # *THIRD PART"
    # [Get the manager/ Maintain focus / Open your eyes]"
    menu:
        "Get the manager":
            show sc day2cdate1 c29
            mc"You‚Äôre going to take a deep breath, look him or her in the eye, and tell them that you‚Äôll get the manager right away."
            show sc day2cdate1 c30
            c"Uhh, I don‚Äôt know if I would be able to handle that kind of pressure or responsibility [y_name]?"
            mc"Just go with me on this. Call the manager."
            c"All right, I‚Äôm calling them."
            c"(This doesn‚Äôt feel right. I just can‚Äôt see myself doing that. But I can‚Äôt tell [y_name] this‚Ä¶)"
            show sc day2cdate1 c26
            c"And they‚Äôre taking care of the problem for me, so I don‚Äôt have to."
            show sc day2cdate1 c22
            mc"Great! You‚Äôve found a resolution!"
            # (Cousin meekly smiles)"
            show sc day2cdate1 c24
            c"Hmm..."
        "Maintain focus"(wt="Best choice"):
            $ v_c_date1_choice3 = True
            show sc day2cdate1 c29
            mc"Continue focusing your attention on your breathing, and on how your body moves with each inhalation and exhalation."
            mc"Feel the movement of your body as you breathe."
            mc"Simply focus your attention on your breath without controlling its pace or intensity."
            show sc day2cdate1 c31
            mc"If your mind wanders, return your focus back to your breathing."
            c"Okay, I think I‚Äôve got it‚Ä¶"
            show sc day2cdate1 c30
            mc"Great. Now answer for me."
            show sc day2cdate1 c28
            c"Yes sir. I understand your concerns. Please hold on for a moment while I get the manager."
            show sc day2cdate1 c27
            c"(Woah‚Ä¶)"
            show sc day2cdate1 c24
            mc"Very good [c_name]."
            # GO DOWN TO: ‚ÄúIf the player chose the right combination, this scene will happen next‚Äù  (IF THE PLAYER GOT ALL THREE ANSWERS CORRECT)"
        "Open your eyes":
            show sc day2cdate1 c29
            mc"Open your eyes again for me [c_name]."
            # (Cousin opens her eyes)"
            show sc day2cdate1 c26
            mc"Tell me what you see?"
            show sc day2cdate1 c23
            c"Uhh, I see you. I see the ocean. And the lighthouse behind you in the distance."
            mc"Are you still feeling anxious?"
            show sc day2cdate1 c23
            c"About what?"
            mc"About anything?"
            show sc day2cdate1 c27
            c"Uhh, maybe just a little‚Ä¶"
            c"(Is there a point to any of this?)"
            show sc day2cdate1 c22
            mc"Oh, well in that case. Close your eyes again for me."
            mc"(I think I may have missed a step somewhere‚Ä¶)"
            # (C closes her eyes)"
    # (scene continues)"
    # ‚ÄúIf the player chose a wrong step, this scene will happen next‚Äù"
    if v_c_date1_choice1 == False or v_c_date1_choice2 == False or v_c_date1_choice3 == False:
        show sc day2cdate1 c27
        mc"So, how do you feel now?"
        show sc day2cdate1 c23
        c"Honestly, about the same as I started."
        mc"Really? Oh‚Ä¶"
        mc"(I must have done something different in the steps to what I was taught about meditating)."
        show sc day2cdate1 c22
        mc"Well, would you like to try again?"
        show sc day2cdate1 c24
        c"Uhh, sure, why not? I have time."
        mc"Great‚Ä¶"
        scene black
        with dissolve
        scene black
        with Pause (2)
        scene sc day2cdate1 c29
        with dissolve

    else:
        $ c_points = change_stat(c_points,3,c_name)

    show sc day2cdate1 c29
    mc"All right, you‚Äôre doing great [c_name]. Now keep breathing as you are, and keep your eyes closed."
    # [Hold her hands / Don‚Äôt do it]"
    menu:
        "Hold her hands":
            # (MC places his hands upon cousins)"
            # (screen shakes)"
            $ c_points = change_stat(c_points,-1,c_name)
            show sc day2cdate1 c36
            with vpunch
            c"Wait, what are you doing?"
            show sc day2cdate1 c34
            mc"Sorry, I didn‚Äôt mean to alarm you."
            show sc day2cdate1 c35
            c"Yeah, but maybe it would be best if you give me some warning next time so you don‚Äôt startle me."
            show sc day2cdate1 c27
            c"(Damn, just when I was starting to feel like I was getting somewhere.)"
            show sc day2cdate1 c34
            mc"My apologies‚Ä¶"
            # GO TO: ‚ÄúIf the player chose a step wrong, this scene will happen next‚Äù"
        "Don‚Äôt do it"(wt="Best choice"):
            $ c_points = change_stat(c_points,1,c_name)
            show sc day2cdate1 c29
            mc"Okay, so when you do this in your own time [c_name]..."
            mc"I‚Äôd like you to do this meditation practice for two to three minutes, and then try it for longer periods."
            mc"Can you do that?"
            c"Yeah, I think I can."
            # (Her eyes are still closed)"
            mc"Okay, you can open your eyes now [c_name]."
            # (C opens her eyes)"
            show sc day2cdate1 c26
            mc"So, how do you feel now?"
            show sc day2cdate1 c25
            c"Honestly, a hell of a lot better!"
            show sc day2cdate1 c24
            if persistent.v_xray_enabled:
                show screen scr_peeping_tom("sc day2cdate1 c24","sc day2cdate1 c24x","v_pt_image_index_30")
            mc"That‚Äôs good to hear. Now as I said, I want you to practise these steps whenever you have time to."
            hide screen scr_peeping_tom

            show sc day2cdate1 c22
            mc"When you‚Äôre comfortable..."
            mc"I want you to put your mind into what you would consider a tough situation to deal with, and talk yourself through the steps we went through just now."
            mc"Find your centre, focus on your breathing, clear your mind. Got it?"
            show sc day2cdate1 c24
            c"Yeah, I feel like I do. Thanks [y_name]."
            show sc day2cdate1 c28
            c"I gotta say, I was a little skeptical at first, but it does feel like it really helped, even though it was a short session."
            mc"Well we‚Äôll do some more work on this again if you‚Äôre interested?"
            show sc day2cdate1 c24
            c"After that, I‚Äôm definitely keen!"
            show sc day2cdate1 c22
            c"I have to ask though, how do you know so much about this?"
            mc"I learned a lot about it through my partner Nicole actually."
            show sc day2cdate1 c26
            c"So it was your girlfriend that inspired you to do this?"
            show sc day2cdate1 c22
            mc"Yeah, it was. Like myself, Nicole has also studied law as well, and she knew full-well the pressures of the industry."
            mc"So she took some time during the week for meditation and relaxation exercises, that she would do whenever she was away from work."
            mc"She asked me to join her for some sessions when she first started going to them, but I chose not to despite her insistence."
            mc"Within a week or two of her attending, I noticed the positive effect it had on her..."
            mc"And it was then that I realised why she was really pushing for me to join her."
            mc"And I had been going to sessions with her, up until a few weeks before I came out here."
            show sc day2cdate1 c24
            c"Wow, she seems like a pretty smart woman who really cares about you a lot."
            mc"Yeah, I guess she does."
            mc"(Dammit, that actually makes me feel even worse that I forgot to call her last night.)"
            show sc day2cdate1 c22
            mc"And there‚Äôs another reason why I decided to take up mediation as well [c_name]."
            mc"I‚Äôve also had some symptoms of social anxiety in the past."
            show sc day2cdate1 c27
            c"Really? You? But you seem so calm and confident."
            c"And you said before that you and your partner worked at a law firm, did you not?"
            show sc day2cdate1 c22
            mc"Yes I did, but for a long time it didn‚Äôt feel like working in a law firm would be the kind of profession that I‚Äôd be involved with."
            mc"When my mother passed away, I actually went quite numb, I found it hard to communicate with my Dad..."
            mc"And I rarely said more than a few words to anyone for several months."
            mc"I guess it probably explains why [s_name] and I didn‚Äôt get along straight away when she and Ashley moved in."
            mc"But over time, I worked on it. And I found meditation to be a bigger help when I was old enough to understand how it worked."
            mc"I also used my mother's passing as motivation."
            mc"To me it was the biggest reason for why I should practise relaxation exercises."
            mc"I just didn‚Äôt want to be someone who couldn‚Äôt talk to people or end up shutting myself off from the outside world."
            mc"And besides, the more people you talk to, then the more you learn about them and other things, good and bad."
            show sc day2cdate1 c23
            c"Hmm‚Ä¶ Everything I‚Äôve learned so far in life has come from my mother, books or online."
            mc"Well imagine what you could learn from other people, simply by talking to them?"
            show sc day2cdate1 c26
            c"Yeah, I see what you‚Äôre saying. I just need some more work on it."
            show sc day2cdate1 c22
            mc"Yeah, just do a bit at a time. Don‚Äôt worry, you‚Äôll get there. And as my Dad taught me, anything that you want to be good at is all down to practise."
            show sc day2cdate1 c24
            c"Thanks again for meeting with me [y_name]."
            mc"It was my pleasure. Glad to be of some help."
            # (MC stands up while C is still sitting down, cross-legged in her pose)"
            show sc day2cdate1 c28
            c"So, are you heading back to the hotel now?"
            show sc day2cdate1 c22
            mc"Yeah, I was thinking about it. You‚Äôre going for a surf now aren‚Äôt you?"
            show sc day2cdate1 c24
            c"Yeah I am. Would you like to walk with me back to the hotel then?"
            mc"Sure, I‚Äôd be happy to‚Ä¶"
            show sc day2cdate1 c46
            mc"Here, allow me to help you up."
            # (MC offers her his hands)"
            show sc day2cdate1 c47
            c"Oh, thanks, that would be nice."
            # (C reaches out her hands to the MC)"
            show sc day2cdate1 c48
            mc"Easy does it, and‚Ä¶"
            # (MC lifts her up slightly, then C‚Äôs hands slip)"
            show sc day2cdate1 c49
            c"Oh, I‚Äôm slipping!"
            # (C falls back down on her back and the MC falls forward on top of her)"
            show sc day2cdate1 c50
            mc"Oh shit!"
            show sc day2cdate1 c51
            mc"(So am I!!)"
            # (screen shakes - we see the MC laying on top of Cousin, face-to-face)"
            show sc day2cdate1 c59
            show screen scr_rewards("sc day2cdate1 c59b","v_rewards_c_12")
            show sc day2cdate1 c59
            with vpunch
