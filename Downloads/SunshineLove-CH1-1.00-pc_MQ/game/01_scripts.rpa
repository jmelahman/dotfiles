    show sc day2ashdate1 a31
    ash"My door is always open to you."
    hide screen scr_rewards
    show sc day2ashdate1 a32
    ash"Even if you need a place to stay for the night while you‚Äôre here in Sunshine Bay."
    ash"Give me a call."
    mc"Oh, thanks for the offer Ashley."
    # (they hug)"
    show sc day2ashdate1 a31
    ash"You‚Äôre welcome handsome‚Ä¶"
    # (Ashley kisses him on the cheek, but close to his lips, then whispers)"
    menu:
        "Kiss her back"(wt="Best choice"):
            #‚Äù +1 ASHLEY POINT
            #(The MC kisses Ashley on the cheek)
            $ ash_points = change_stat(ash_points,1,"Ashley")
