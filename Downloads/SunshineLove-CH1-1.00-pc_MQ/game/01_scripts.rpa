                        show sc day1eve e34
                        $ s_points = change_stat(s_points,1,s_name)
                        s"Don‚Äôt be so modest [y_name]. You really made a good impression on [c_name]." #+1 FRIEND POINT"
                    "I do":
                        show sc day1eve e34
                        mc"Hmm, perhaps I do, haha!"
                # (scene continues)"
