    mc"Sure, that sounds like a great idea‚Ä¶"
    stop sound fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)



label lb_day1_big_conflict_ashley:
    play ambient "sound effects/01/00/Beach_Ocean_Waves_-_Sound_Effect_decreased.mp3" loop fadein 1.0
    scene sc day1beachashley a01
    with dissolve
    s"So I was thinking that once we‚Äôve finished with work for the day, that tonight we could-"
    ash"[s_name]?"
    # (Friend‚Äôs eyes light up as she sees her mother)"
    if renpy.loadable("extras.animations") and persistent.v_anim_enabled:
        window hide
        scene wip_01_ashley_intro  at tt_top
        pause
        window show
    else:
        show sc day1beachashley a05
    s"Mom???"
    # ROLLING WIP OF ASHLEY"
    show sc day1beachashley a03
    s"(Why the hell is she here?)"
