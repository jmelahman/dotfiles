label lb_w3eow_roshi_elevator:
    # Week 3 (EOW) Scene 09 - Broken bay door motor or service elevator"
    scene sc w3eowroshi r01
    with dissolve
    play ambient "sound effects/01/01/Birds_in_trees_sounds_effects1.mp3" fadein 1.0
    mc"(Hmm‚Ä¶ It‚Äôs all quiet again, similar to the first day I was here.)"
    mc"(All the police officers that were here seem to have gone.)"
    mc"(I wonder what Trisha‚Äôs boss said to the police chief to get rid of them so quickly?)"
    show sc w3eowroshi r03
    mc"(Whatever he said is sure to piss Connie‚Äôs Dad off. I‚Äôm sure someone will be in the firing line due to that.)"
    show sc w3eowroshi r02
    mc"(Hopefully, it‚Äôs not us!)"
    show sc w3eowroshi r01
    mc"(Anyway, I better go and get my tools and the supplies that I bought the other day for the elevator before Mister Roshi arrives.)"
    mc"(I haven‚Äôt seen him for a while, so hopefully, he‚Äôs well enough to do the job‚Ä¶)"
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (screen goes blank)"
    # (MC heads to the service elevator, he looks it over, doors open while it‚Äôs not operating)"
    scene sc w3eowroshi r04
    with dissolve
    mc"(Okay, I should probably give the inside a good clean. It looks like it could do with one.)"
    ro"You know, wise man once say, ‚Äúman who stands and thinks too long allows life to pass him by‚Ä¶‚Äù"
    # (MC turns to see Mister Roshi, who is carrying his toolkit)"
    show sc w3eowroshi r05
    mc"Oh, hey mister Roshi. I didn‚Äôt hear you come in."
    show sc w3eowroshi r07
    ro"Silence is true friend who never betrays."
    show sc w3eowroshi r08
    ro"So, you looking at having elevator fixed?"
    show sc w3eowroshi r05
    mc"Well, we were hoping to have it repaired before the party tomorrow. [s_name] is in town getting a few things at the mall."
    show sc w3eowroshi r07
    ro"Best we get to work then."
    show sc w3eowroshi r05
    mc"What would you like me to do?"
    show sc w3eowroshi r08
    ro"You clean walls and floor of elevator while Roshi replace lightbulbs and inspect metal levels to stop creaking noise."
    show sc w3eowroshi r05
    mc"Okay, I bought some cleaning supplies the other day."
    # (Roshi puts his toolkit down, and takes a look at the elevator buttons that has their lights put)"
    mc"Do you think we can get this all fixed today?"
    show sc w3eowroshi r06
    ro"Hai‚Ä¶ However, must take time to do job correctly."
    show sc w3eowroshi r07
    ro"Because man who make mistake in elevator, may be wrong on so many levels."
    ro"Understand?"
    mc"Uh, yeah, I think I do."
    mc"(Was that meant to be a joke? It‚Äôs kind of hard to tell.)"
    # [Ask how he‚Äôs feeling / Talk about Yuki]"
    # (MC asks these questions as he and Mister Roshi are working)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w3eowroshi r12
    with dissolve



label lb_w3eow_roshi_elevator_menu:
    if v_w3eow_roshi_feeling and v_w3eow_roshi_yuki:
        jump lb_w3eow_roshi_elevator_menu_ending
    menu:
        "Ask how he‚Äôs feeling" if v_w3eow_roshi_feeling == False:
            $ v_w3eow_roshi_feeling = True
            show sc w3eowroshi r10
            mc"So Mister Roshi‚Ä¶ How are you feeling?"
            mc"I heard that you had to go to the hospital recently."
            show sc w3eowroshi r13
            ro"Roshi okay. Not getting any younger but heart still beating."
            show sc w3eowroshi r11
            mc"Is your back feeling better? When we first met you said that it was quite sore after putting up the curtains."
            show sc w3eowroshi r12
            ro"Yes, back feeling strong. Good bed rest certainly helps."
            show sc w3eowroshi r09
            ro"How about your back young man? Can it handle heavy lifting?"
            show sc w3eowroshi r11
            mc"Uh, I guess so. Why, does it look like I can‚Äôt?"
            show sc w3eowroshi r12
            ro"Posture not good at times. Roshi notice you hunched over like troll."
            mc"Really? It‚Äôs that bad?"
            show sc w3eowroshi r12
            ro"Man who stand up straight can see further into distance and not miss sunset."
            mc"Haha, that‚Äôs certainly true."
            mc"(He certainly isn‚Äôt short of a quote or two.)"
            jump lb_w3eow_roshi_elevator_menu
        "Talk about Yuki" if v_w3eow_roshi_yuki == False:
            $ v_w3eow_roshi_yuki = True
            show sc w3eowroshi r11
            mc"So uh, have you spoken to Yuki this morning? I haven‚Äôt seen her for a few days."
            show sc w3eowroshi r12
            ro"Hai‚Ä¶ Daughter come check on Roshi every day."
            ro"Good daughter, would make great life partner for some fortunate man one day."
            mc"I don‚Äôt doubt that."
            show sc w3eowroshi r13
            ro"She remind me of her mother. Hope she be okay when Roshi is gone."
            show sc w3eowroshi r11
            mc"Oh come on Mister Roshi, I‚Äôm sure you‚Äôve got several more years left in you, right?"
            ro"Roshi always believe that he has had two lives."
            ro"And the second one begins when I realise that I only have one."
            mc"(Hmm‚Ä¶ I‚Äôm not sure what he means by this or if that answered my question at all!)"
            show sc w3eowroshi r11
            ro"Are you good friends with Yuki?"
            if v_w2_k_yuki_plane_lessons:
                # ‚ÄúAdd lines if the MC went flying with Yuki‚Äù"
                mc"I‚Äôd like to think we are, yes. She took me flying in her seaplane the other week."
                show sc w3eowroshi r12
                ro"You enjoy?"
                mc"Oh yes, very much so."
                mc"I can see why she loves flying, it was quite exhilarating being that high up in the air."
                show sc w3eowroshi r13
                ro"My daughter must like you very much, as she never takes anyone flying with her."
                show sc w3eowroshi r12
                mc"Oh, really? She never told me that."
                mc"(Hmm‚Ä¶ I wonder why that is?)"
                show sc w3eowroshi r12
                ro"So, you learn how to fly plane as well?"
                # ‚ÄúAdd these lines if the player chose to fly the plane‚Äù"
                show sc w3eowroshi r11
                mc"Yeah, kind of. She let me fly the plane for a few minutes."
                mc"It‚Äôs honestly one of the best experiences I‚Äôve ever had..."
                mc"And if Yuki hadn‚Äôt have offered, then I probably wouldn‚Äôt have asked her."
                # (scene continues)"
                show sc w3eowroshi r13
                ro"You should go up again."
                show sc w3eowroshi r12
                ro"Yuki would love to be able to teach others to fly one day for a living."
                ro"You could be a good test subject."
                # [I don‚Äôt know / I‚Äôd like that]"
                menu:
                    "I don‚Äôt know":
                        show sc w3eowroshi r11
                        mc"I don‚Äôt know..."
                        show sc w3eowroshi r10
                        $ yuki_points = change_stat(yuki_points,-2,"Yuki")
                        mc"It was fun, but I think she could find someone better to practise with than me." #-2 YUKI POINTS"
                    "I‚Äôd like that"(wt="Best choice"):
