label lb_beginning_of_version_0_06:
    if v_w3_c_path is None:
        if v_w3mow_c_date:
            scene main_screen_alpha
            menu:
                "Your saved game needs to be upgraded. Did [y_name] and [c_name] share a kiss at the beach house?"
                "Yes":
                    $ v_w3_c_path = True
                "No":
                    $ v_w3_c_path = False
        else:
            $ v_w3_c_path = False

label lb_w3_eow_mc_s_bed:
    $ v_audio_easteregg = True
    scene sc w3eowmorning m01
    with dissolve
    mc"(Mmm‚Ä¶ That was one hell of a sleep.)"
    show sc w3eowmorning m03
    mc"(I still can‚Äôt believe what [s_name] and I did last night. But am I going to live to regret it?)"
    mc"(Maybe we took things too far.)"
    mc"(Sigh‚Ä¶)"
    show sc w3eowmorning m02
    mc"(Did I let it happen because I was drunk, tired, or maybe even‚Ä¶ Lonely?)"
    show sc w3eowmorning m04
    mc"(Hmm‚Ä¶ I don‚Äôt know how things could possibly get wor-)"
    # (screen shakes)"
    # (MC looks to his left and freaks out when he sees that S is still asleep next to him - she is laying in the same position she did when she fell asleep)"
    show sc w3eowmorning m05
    with vpunch
    mc"(What on earth is [s_name] still doing in my bed?!?)"
    mc"(She was supposed to go back to her room after we‚Ä¶ Fooled around.)"
    mc"(Shit! I‚Äôll need to wake her up and-)"
    # (MC hears a voice murmur, which is Cousin)"
    "Mmm‚Ä¶"
    mc"(Wait! Where did that sound come from?)"
    # (MC looks to the other side and sees Cousin sleeping next to him too - she is laying in the same position she did when she fell asleep)"
    # (screen shakes)"
    show sc w3eowmorning m06
    with vpunch
    mc"(What the fuck?!?)"
    show sc w3eowmorning m08
    mc"(Why the hell is [c_name] in my bed as well???)"
    show sc w3eowmorning m06
    mc"(Okay, okay‚Ä¶ Calm down...)"
    show sc w3eowmorning m07
    mc"(I‚Äôm probably just dreaming. This is just a dream, it has to be.)"
    show sc w3eowmorning m09
    mc"(I‚Äôm sure if I just close my eyes for a few seconds, then as soon as I re-open them, both girls will disappear.)"
    mc"(Okay, I‚Äôm gonna try that‚Ä¶)"
    # (MC closes his eyes, the screen stays blank while MC thinks things over)"
    scene black
    mc"(Oh man, why on earth would I dream up a scenario where I‚Äôm in bed with both [s_name] and [c_name] at the same time?)"
    mc"(Is it because I‚Äôve spent a lot of time with both of them recently?)"
    mc"(Or is it because I've had a special moment with each of them during the past couple of nights?)"
    mc"(Maybe I need to distance myself from [s_name] and [c_name] for the next few days, just so that I don‚Äôt have any further fantasies like this one.)"
    mc"(All right, I‚Äôm going to open my eyes, and hopefully put this bizarre dream behind me.)"
    # (MC re-opens his eyes, looks to his left)"
    scene sc w3eowmorning m05
    mc"(Oh crap! [s_name] is still there!)"
    # (MC looks to his right)"
    show sc w3eowmorning m06
    mc"(And so is [c_name]!!!)"
    show sc w3eowmorning m07
    mc"(I gotta get out of here without waking the girls. The last thing I need is for either of them to freak out.)"
    show sc w3eowmorning m06
    c"Mmm‚Ä¶"
    # (Cousin turns towards the MC in her sleep and lays a hand across his chest)"
    mc"(Oh damn! Please don't wake up...)"
    show sc w3eowmorning m10
    s"Uh-hmm‚Ä¶"
    # (S turns towards the MC in her sleep and lays a hand across his crotch)"
    mc"(Are you fucking kidding me???)"
    # (expanded shot of the MC, S and Shortcake in the bed together)"
    # (MC has a panic-stricken look on his face, while S has her hand on his crotch, cousin has her hand on his chest - both girls still asleep)"
    show sc w3eowmorning m07
    mc"(Okay‚Ä¶ I can‚Äôt make any sudden movements.)"
    show sc w3eowmorning m10
    mc"(Shit‚Ä¶ I‚Äôm going to have to try and wake [s_name] up without disturbing [c_name].)"
    mc"(It‚Äôs the only way to get out of this.)"
    show sc w3eowmorning m11
    mc"(I better move her hand off of me first though.)"
    # (MC takes S‚Äô hand and moves it off his crotch)"
    show sc w3eowmorning m12
    mc"(Okay, now to try and wake her up.)"
    # (MC looks at S and softly whispers to her)"
    mc"[s_name]‚Ä¶"
    mc"[s_name]......"
    # (S‚Äô eyes flutter open, she‚Äôs smiling)"
    show sc w3eowmorning m13
    s"Mmm..."
    show sc w3eowmorning m14
    s"Morning [y_name]."
    show sc w3eowmorning m17
    s"Mmm..."
    show sc w3eowmorning m15
    mc"Shhh‚Ä¶."
    mc"Keep it down [s_name]. Just whisper."
    # (MC removes his hand)"
    s"What for [y_name]?"
    mc"We have a huge problem [s_name]. Look who‚Äôs laying next to me!"
    # (S looks over and sees Cousin asleep, surprised look on her face)"
    show sc w3eowmorning m06
    s"Why on earth is [c_name] in your bed??"
    show sc w3eowmorning m16
    mc"I have no idea."
    show sc w3eowmorning m15
    mc"More to the point, why are you still in my bed?"
    show sc w3eowmorning m18
    mc"You said you would go back to your room after I fell asleep."
    show sc w3eowmorning m19
    s"I um‚Ä¶ I must have fallen asleep too."
    show sc w3eowmorning m06
    s"Shit‚Ä¶ "
    s"Do you think [c_name] saw us in bed together?"
    show sc w3eowmorning m16
    mc"Hmm‚Ä¶ I‚Äôm not sure."
    show sc w3eowmorning m15
    mc"I don‚Äôt think so, because her being here wouldn‚Äôt make much sense then, would it?"
    show sc w3eowmorning m16
    s"I suppose not."
    show sc w3eowmorning m15
    mc"Anyway, we better get out of here without waking her, and get our stories straight before [c_name] wakes up."
    show sc w3eowmorning m06
    s"We better do this quickly just in case she does."
    mc"Just give me a second here."
    # (MC removes cousin‚Äôs hand upon his chest)"
    show sc w3eowmorning m16
    s"(Hmm‚Ä¶ Why did [c_name] have her hand on [y_name]‚Äôs chest? Did she do that on purpose?)"
    show sc w3eowmorning m15
    mc"Okay, looks like we are good to move out of the bed."
    # (S slides out of bed, stands on the side)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w3eowmorning m20
    with dissolve
    s"What time is it?"
    # (MC slides out of bed)"
    mc"It‚Äôs a little after seven, so [c_name] could wake up any minute now."
    show sc w3eowmorning m21
    s"How on Earth are we going to ask her how and why she ended up sleeping in your bed?"
    show sc w3eowmorning m20
    mc"We should discuss this in the kitchen while we‚Äôre making breakfast."
    show sc w3eowmorning m21
    s"You‚Äôre right. Let‚Äôs hope that Connie isn‚Äôt up yet‚Ä¶"
    # (MC and S leave the room together, leaving cousin asleep in the bed)"
    scene black
    with dissolve
    scene black
    with Pause (2)

label lb_w3eow_mc_breakfast:
    # Week 3 (EOW) Scene 02 - MC has breakfast with S, C, and Connie"
    scene sc w3eowmorning m22
    with dissolve
    mc"Man, that was way too close."
    mc"We have to be a lot more careful in the future [s_name]."
    s"Yeah, I agree."
    show sc w3eowmorning m27
    s"So what do you think we should say to [c_name] when she wakes up and we see her?"
    show sc w3eowmorning m23
    mc"I think it‚Äôs best that we don‚Äôt say anything."
    show sc w3eowmorning m26
    mc"Whatever way we look at it, when she sees us then she‚Äôs going to know that we‚Äôre aware that she slept in my bed."
    mc"So we should let her try and explain what she believe happened."
    show sc w3eowmorning m24
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w3eowmorning m24","sc w3eowmorning m24x","v_pt_image_index_w3_26")
    s"That‚Äôs a good idea. Maybe it was just an honest mistake."
    hide screen scr_peeping_tom
    show sc w3eowmorning m23
    mc"I hope so, as any other reason I can think of isn‚Äôt exactly forthcoming!"
    show sc w3eowmorning m29
    s"[y_name]? About last night."
    mc"[s_name], you don‚Äôt have to-"
    # (MC is cut off by S)"
    show sc w3eowmorning m27
    s"No, I need to. I just wanted to say I‚Äôm sorry."
    show sc w3eowmorning m23
    mc"Sorry? For what?"
    show sc w3eowmorning m22
    s"I‚Äôm sorry if I made you feel uncomfortable or made you do something you didn‚Äôt want to."
    show sc w3eowmorning m29
    s"That was wrong of me to put you in that situation."
    # [Agree with her / Disagree]"
    show sc w3eowmorning m22
    menu:
        "Agree with her":
            show sc w3eowmorning m23
            mc"Uh, well, some things can‚Äôt be helped, you know?"
            show sc w3eowmorning m29
            s"Yeah, I know, But it won‚Äôt happen again, I promise."
            s"That is if you don‚Äôt want it to?"
        "Disagree"(wt="Best choice"):
            show sc w3eowmorning m23
            $ s_points = change_stat(s_points,2,s_name)
            mc"[s_name], it‚Äôs not entirely your fault. I was there too so I‚Äôm equally culpable." #+2 S POINTS"
            show sc w3eowmorning m29
            s"Thanks [y_name]. Look, I promise it won‚Äôt happen again."
            s"That is if you don‚Äôt want it to?"
            # (scene continues)"
    show sc w3eowmorning m23
    mc"I think it would be best if we don‚Äôt for now [s_name]."
    mc"Things are a little crazy for both of us at the present time, and we agreed to put our focus and energy into the hotel, right?"
    show sc w3eowmorning m29
    s"You‚Äôre absolutely right."
    # (S bows her head, a little disappointed)"
    # (MC places his hands upon hers)"
    show sc w3eowmorning m23
    mc"Look, I‚Äôm not saying we can‚Äôt have fun again, but we just have to be careful and pick the right time and place, okay?"
    show sc w3eowmorning m24
    s"Okay, sure, that sounds good."
    jump lb_w3eow_mc_breakfast_1

label lb_w3eow_mc_breakfast_1:
    pass

label lb_w3eow_mc_breakfast_2:
    # (scene continues)"
    show sc w3eowmorning m23
    mc"As I said last night, we‚Äôll talk about it more some other time."
    # (Cousin enters the kitchen, stands at the door)"
    show sc w3eowmorning m34
    c"Uh, morning guys."
    show sc w3eowmorning m34
    s"Oh, hey [c_name]. How did you sleep?"
    show sc w3eowmorning m35
    c"I uh, okay I guess. However, I‚Äôm a little bit confused."
    show sc w3eowmorning m39
    mc"Is it because you slept in my bed last night [c_name]?"
    show sc w3eowmorning m37
    c"Oh my God! So you do know then?"
    show sc w3eowmorning m36
    c"I‚Äôm so embarrassed."
    # (Cousin covers her face)"
    show sc w3eowmorning m39
    mc"It‚Äôs okay [c_name], you have nothing to worry about."
    show sc w3eowmorning m38
    c"I don‚Äôt? Why?"
    mc"Because I didn‚Äôt sleep in my bed last night, I slept out here."
    show sc w3eowmorning m39
    c"Wait, I don‚Äôt understand."
    show sc w3eowmorning m26
    mc"Let me explain... I woke up in the middle of the night, and I sat outside alone for a while, listening to the ocean waves."
    show sc w3eowmorning m39
    mc"I was out there for around about thirty minutes I think."
    mc"When I came back inside and entered my room, I found you lying in my bed. I tried to wake you, but you were fast asleep."
    mc"So I thought it would be best just to leave you there and for me to sleep on the sofa instead."
    show sc w3eowmorning m28
    s"(Hmm‚Ä¶ [y_name] is really selling this lie!)"
    show sc w3eowmorning m36
    c"Oh [y_name]! That was so kind of you. I hope you slept okay."
    show sc w3eowmorning m39
    mc"Yep, like a baby."
    show sc w3eowmorning m45
    s"So how do you think you ended up sleeping in [y_name]‚Äôs bed instead of your own [c_name]?"
    show sc w3eowmorning m44
    c"Hmm‚Ä¶ I remember getting up in the middle of the night and it was pretty dark through the hallway."
    c"I guess I must have stumbled into the wrong bedroom by accident."
    show sc w3eowmorning m45
    s"(Hmm‚Ä¶ She‚Äôs right, this house is pretty dark at night. Maybe it really was an accident.)"
    show sc w3eowmorning m34
    s"(Still, it was a little suspicious the way she was cuddled up to [y_name] when I woke up.)"
    show sc w3eowmorning m39
    mc"That makes sense. Anyway, no harm was done. So are you hungry?"
    show sc w3eowmorning m41
    c"Yes! I‚Äôm starving."
    show sc w3eowmorning m46
    s"Please, come and join us for breakfast."
    # (Cousin smiles and sits next to S)"
    show sc w3eowmorning m43
    c"Thanks."
    show sc w3eowmorning m40
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w3eowmorning m40","sc w3eowmorning m40x","v_pt_image_index_w3_27")
    mc"(So [c_name] ending up in my bed was just an innocent mistake.)"
    if v_w3_c_path:
        # ‚ÄúAdd this line if the MC and Cousin kissed the night before‚Äù"
        mc"(I know we kissed last night, but I don‚Äôt think that would be a reason for her to hop into bed with me!)"
    mc"(Now that it‚Äôs been discussed and sorted out, we can have breakfast and start discussing our plans for the day‚Ä¶)"
    # (screen goes blank)"
    hide screen scr_peeping_tom
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w3eowmorning m48
    with dissolve
    # (Connie enters the kitchen, stands at the door)"
    con"Morning everyone! How are we all?"
    show sc w3eowmorning m46
    s"Morning Connie!"
    show sc w3eowmorning m47
    c"How did you sleep?"
    show sc w3eowmorning m48
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w3eowmorning m48","sc w3eowmorning m48x","v_pt_image_index_w3_28")
    con"Really well, thanks."
    hide screen scr_peeping_tom
    show sc w3eowmorning m45
    s"Are you hungry?"
    show sc w3eowmorning m48
    con"Yeah, I could definitely eat."
    # (Connie sit with Cousin and S)"
    show sc w3eowmorning m49
    show screen scr_rewards("sc w3eowmorning m49b","v_rewards_connie_6")
    con"So, how did you guys sleep?"
    mc"Uh‚Ä¶ Very well."
    show sc w3eowmorning m50
    con"The bed in my room was so comfortable!"
    hide screen scr_rewards
    show sc w3eowmorning m51
    con"I imagine that your Mom bought all the mattresses from the same place, which meant you guys also had a great sleep, right [s_name]?"
    show sc w3eowmorning m31
    s"Oh, I guess so."
    show sc w3eowmorning m50
    con"Did you sleep well [y_name]? You look like you did."
    mc"Um, well‚Ä¶"
    # [Tell the truth / Lie]"
    menu:
        "Tell the truth":
            show sc w3eowmorning m49
            mc"Well actually, I slept out on the sofa and [c_name] slept in my bed."
            show sc w3eowmorning m53
            c"(Oh, why did [y_name] tell her that for?)"
            $ c_points = change_stat(c_points,-2,c_name)
            c"(Now she probably thinks that something sexual is going on between us!)" #-2 COUSIN PTS"
            show sc w3eowmorning m49
            con"Oh, how did that happen?"
            mc"It‚Äôs a long story. But the sofa was pretty comfortable."
            con"I see."
            show sc w3eowmorning m52
            con"(That certainly sounds more than a little odd...)"
            show sc w3eowmorning m54
            con"(Is something going on between the two of them?)"
        "Lie"(wt="Best choice"):
            mc"(Hmm‚Ä¶ There‚Äôs no need for Connie to know everything that happened overnight.)"
            show sc w3eowmorning m49
            mc"Yes, I slept rather well thanks."
            show sc w3eowmorning m53
            $ c_points = change_stat(c_points,2,c_name)
            c"(Phew! I‚Äôm so glad he didn‚Äôt tell Connie how I accidentally slept in his bed.)" #+2 COUSIN PTS"
            c"(If he had done that, then she probably would have thought that something sexual was going on between us!)"
            # (scene continues)"
    # (Connie pours herself some orange juice)"
    show sc w3eowmorning m50
    con"So what‚Äôs the plan for all of you today?"
    mc"Well after we‚Äôve finished having breakfast, then [s_name] will probably pack whatever she needs to..."
    show sc w3eowmorning m49
    mc"And then we'll drop [c_name] home on the way back to the hotel."
    show sc w3eowmorning m52
    con"Do you guys have to leave so soon?"
    show sc w3eowmorning m30
    s"I‚Äôm afraid so."
    s"We have to return to the hotel so we can relieve the staff member who was watching our reception area overnight."
    s"And our on-site maintenance guy Mister Roshi is fixing the elevator today..."
    s"And he‚Äôll no doubt require a second pair of hands to assist him."
    show sc w3eowmorning m32
    s"But feel free to use the pool here Connie, and there‚Äôs still plenty of food and drink available to you."
    show sc w3eowmorning m51
    con"Thanks again, you guys. I really don‚Äôt know what to say."
    show sc w3eowmorning m33
    s"It‚Äôs no problem at all."
    show sc w3eowmorning m55
    c"Has your Mom or Dad tried to call you since last night?"
    show sc w3eowmorning m57
    con"My Mom did, but I didn‚Äôt answer. I didn‚Äôt want to give her a chance to try and convince me to come home."
    show sc w3eowmorning m49
    mc"Don‚Äôt worry Connie."
    mc"[s_name] and I will start getting everything organised for your party tomorrow..."
    mc"So you can just sit back and relax here for the day."
    mc"And as we discussed, you can start messaging your friends that you want to attend your party later tonight."
    show sc w3eowmorning m32
    s"But make sure to tell them that if they‚Äôre going to attend, to send you a simple reply that says ‚ÄúI‚Äôll be there‚Äù."
    s"As soon as they reply with that message..."
    s"Then let your friends know that you‚Äôll message them tomorrow at midday with full details of where the party will be hosted."
    show sc w3eowmorning m59
    con"Why midday?"
    show sc w3eowmorning m32
    s"It‚Äôs so there‚Äôs less chance that your Dad or anyone can stop your friends from attending."
    s"As far as he knows, the party is still going ahead at his hotel, right?"
    s"So all you have to do tonight is tell your friends is that there will be a change of venue..."
    s"And tomorrow you can tell them that the new venue is at our hotel."
    s"You got it?"
    show sc w3eowmorning m51
    con"Yeah, that should be easy to remember."
    show sc w3eowmorning m49
    mc"Don‚Äôt worry Connie. If you get stuck, then you can call me or [s_name] and we‚Äôll help you."
    show sc w3eowmorning m50
    con"Okay, sounds good [y_name]."
    mc"(I sure hope this plan works.)"
    mc"(It feels a little rushed and maybe not as well thought out as it should be.)"
    mc"(However, we can‚Äôt have Connie let her friends know where her party is going to be when she messages them tonight...)"
    mc"(Just in case it gets back to her father.)"
    mc"(At least if she tells them at short notice, then once the party is in full swing, there‚Äôs nothing he or his people can do about it.)"
    mc"(We‚Äôll just have to presume that Connie‚Äôs friends will turn up tomorrow as she said, and her party will go off without a hitch‚Ä¶)"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (S, cousin, and the MC prepare to leave the house, say goodbye to Connie)"
    scene sc w3eowmorning m62
    with dissolve
    play sound "sound effects/01/00/Beep_beep_sound_effect.mp3"
    s"Okay, it looks like the Uber is here."
    # (S hugs Connie)"
    s"We‚Äôll see you soon Connie."
    show sc w3eowmorning m60
    con"Thanks again for letting me stay here and for organising my party. The three of you are incredible!"
    show sc w3eowmorning m63
    s"Haha, don‚Äôt thank us yet! But honestly, it's no trouble at all."
    # (Cousin hugs Connie)"
    show sc w3eowmorning m61
    c"Bye Connie. We‚Äôll see you at your party tomorrow!"
    show sc w3eowmorning m64
    con"I can‚Äôt wait to see what it will look like, and I‚Äôm looking forward to celebrating my party with you all."
    # (MC hugs Connie)"
    show sc w3eowmorning m66
    mc"Bye Connie. Remember, don‚Äôt answer the door for anyone."
    mc"And between now and when we come to pick you up tomorrow, be sure to stay off social media."
    show sc w3eowmorning m62
    s"And you should switch the Find Your Phone setting to ‚Äúoff‚Äù, so your phone can‚Äôt be traced."
    show sc w3eowmorning m60
    con"Good idea, I‚Äôll do that shortly."
    show sc w3eowmorning m66
    mc"Okay, looks like we‚Äôre all set. Let‚Äôs go girls."
    show sc w3eowmorning m62
    s"We‚Äôll message or call you in the morning when we‚Äôre on the way to pick you up."
    show sc w3eowmorning m65
    mc"Bye Connie."
    con"Bye guys! Good luck today!"
    scene black
    with dissolve
    scene black
    with Pause (2)








