    mc"The elevator is running perfectly Mister Roshi!"
    mc"The lights are fixed and I can‚Äôt hear any creaking noises."
    show sc w3eowroshi r07
    ro"Roshi is happy too."
    # (Roshi smiles)"
    if persistent.v_textbox_dialogue:
        $ persistent.v_textbox_dialogue = False
        call screen scr_01_04_task_completed
        $ persistent.v_textbox_dialogue = True
    else:
        call screen scr_01_04_task_completed

    $ v_task_01_04 = True
    # (‚ÄúTASK COMPLETED‚Äù NOTIFICATION ON SCREEN)"
    mc"Let me just clean the ceiling a bit here."
    show sc w3eowroshi r20
    # (MC reaches up to wipe the ceiling of the elevator, takes his eyes off MR for a moment)"
    mc"I might as well make sure every little crevice has been cleaned. Is that okay with you Mister Roshi?"
    ro"‚Ä¶"
    mc"Mister Roshi??"
    show sc w3eowroshi r21
    ro"Uhh‚Ä¶"
    # (Mister Roshi lays on the floor and clutches at his chest)"
    # (MC shocked look)"
    mc"Mister Roshi!! Are you all right??"
    # (MC rushes to his aid)"
    ro"Yes, but Roshi have bad pain in chest."
    mc"Oh! Um, let me call your daughter."
