label lb_w2_mc_kristina_call:
    # Day 4 (SOW) 04 - MC calls Kristina regarding decorating the events hall"
    # SCENE BEGINS"
    # (MC enters the kitchen to look for friend, and she‚Äôs on her way out as he gets there. She says they will talk when she gets back)"
    scene sc w2kitchen k02
    with dissolve
    mc"[s_name], are you in here?"
    show sc w2kitchen k04
    s"Oh, hey [y_name]. I was just on my way out."
    show sc w2kitchen k02
    mc"Where are you off to?"
    s"I have to pick up materials that I ordered for some of the rooms."
    mc"Did you want me to come with you?"
    show sc w2kitchen k04
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2kitchen k04","sc w2kitchen k04x","v_pt_image_index_w2_04")
    s"No, that‚Äôs okay, I can handle it. You sit down and make yourself some breakfast. I‚Äôll be back before you know it."
    mc"(Why do I get feeling she‚Äôs trying to avoid me, especially after what happened this morning?)"
    hide screen scr_peeping_tom
    show sc w2kitchen k02
    mc"So what shall I do after I‚Äôve had breakfast?"
    show sc w2kitchen k04
    s"Just relax for now."
    show sc w2kitchen k02
    s"Actually, you said last night that you were thinking of contacting Ivy and Lily‚Äôs sister [k_name] to possibly help out with re-designing the events hall, didn't you?"
    s"Maybe you could give her a call while I‚Äôm out to see if she‚Äôs interested."
    mc"Oh, I guess I could do that."
    # (Friend kisses F on the cheek)"
    s"I‚Äôll be back soon, then we can talk, okay?"
    mc"Right, sure thing [s_name]."
    show sc w2kitchen k03
    s"Bye [y_name]."
    # (A behind shot of friend as she leaves the room)"
    show sc w2kitchen k05
    mc"(It sounded like [s_name] was aware of the tension in the room, and wanted to get out of here as quickly as possible.)"
    mc"(Maybe it was a wise decision, as it gives both of us time to collect our thoughts.)"
    show sc w2kitchen k10
    play sound "sound effects/01/01/Phone_call_sound_effect.mp3" loop fadein 1.0
    mc"(Okay, perhaps I should call [k_name] to see if she‚Äôs available to help us. I may as well find out now rather than delaying any longer.)"
    # (MC pick up his phone)"
    show sc w2kitchen k06
    stop sound
    k"Hello?"
    mc"Hi, is this [k_name]?"
    show sc w2kitchen k09
    k"Yes, that‚Äôs me. May I ask who is calling?"
    show sc w2kitchen k06
    mc"Yeah hi, it‚Äôs [y_name]. I came to visit you at the church yesterday."
    show sc w2kitchen k08
    k"Oh yes, how could I forget? I had a strong feeling that I‚Äôd hear again from you really soon."
    show sc w2kitchen k07
    mc"You did?"
    k"Oh yeah. Sometimes when you ask for things to happen, then he will provide."
    mc"(He?)"
    mc"Uhh, okay."
    k"So what can I do for you?"
    show sc w2kitchen k06
    mc"It‚Äôs about what we discussed yesterday, about you studying interior design at college and your interest in possibly redecorating our main hall."
    mc"Are you still interested?"
    show sc w2kitchen k09
    k"Hmm, it depends."
    show sc w2kitchen k06
    mc"On what exactly?"
    show sc w2kitchen k07
    k"Well, I‚Äôm more than happy to do that for you, or to at least come and take a look. But what are you willing to do for me in return [y_name]?"
    mc"Uh, I don‚Äôt get what you mean."
    show sc w2kitchen k06
    mc"What is it that you‚Äôd like? Money?"
    show sc w2kitchen k07
    k"I don‚Äôt want to be paid. However, maybe you could show me a good time in town sometime soon?"
    show sc w2kitchen k06
    mc"Oh, are you serious?"
    show sc w2kitchen k09
    k"Deadly. Girls like myself who dedicate so much time to the church don‚Äôt have much of a social life, nor do guys want to ask me."
    show sc w2kitchen k07
    k"And seeing as you‚Äôre new in town, I thought that you might see things differently to the locals of Sunshine Bay."
    k"So what do you think? I do the work for you, and you and I do something together. It seems like a fair trade."
    show sc w2kitchen k06
    mc"Oh, so would it be like a date?"
    show sc w2kitchen k09
    k"No, of course not! My faith does not allow me to date people who are non-believers. This would strictly be a casual night out."
    show sc w2kitchen k07
    k"And a chance for me to be able to let my hair down, so to speak."
    mc"(Hmm‚Ä¶ Lily said that she was of the belief there was a party girl inside of her sister that was just waiting to get out.)"
    show sc w2kitchen k06
    mc"(Could it be true though? Hmm‚Ä¶)"
    mc"(I don‚Äôt know about agreeing to this deal that [k_name]‚Äôs offered me. Then again, it might be worth the risk.)"
    # [Make a deal / Refuse her deal]"
    menu:
        "Make a deal"(wt="You will be ON the [k_name] path"):
            $ v_w2_k_deal = True
            #(You will have a night out with Kristina)"
            mc"All right, we have a deal."
            mc"Perhaps we could meet here on Wednesday, during the day, to further discuss the kind of work that we‚Äôd need you to do."
            show sc w2kitchen k07
            k"Sounds good. I‚Äôm free most afternoons, maybe I could come to the hotel after lunchtime?"
            mc"That should work in with our work schedule."
            k"And we can also decide what night works for you and me to have some fun together?"
            show sc w2kitchen k08
            $ k_points = change_stat(k_points,5,k_name)
            k"Professionally speaking that is." #+5 KRISTINA PTS"
            show sc w2kitchen k07
            mc"Oh, sure thing."
            if v_day3_fantasy_k:
                # ‚ÄúIf the player chose KRISTINA to fantasise about the night before‚Äù"
                mc"(The way she‚Äôs talking about having fun together, I can‚Äôt help but think back to that fantasy I had of [k_name] last night.)"



        "Refuse her deal"(wt="The [k_name] is now CLOSED"):
            #(You will NOT have a night out with Kristina)"
            show sc w2kitchen k06
            mc"Actually, I don‚Äôt think that would be such a good idea [k_name]. I just believe that business and pleasure should be kept separate."
            show sc w2kitchen k09
            mc"I‚Äôm sure it would be fun, but this is not how I think we should be going about things if we‚Äôre going to work together."
            mc"So I‚Äôm going to have to decline your offer."
            k"It‚Äôs all right, you have your beliefs and I respect that."
            show sc w2kitchen k07
            k"However, I‚Äôm still going to help you and [s_name] with your decorating and designing of your events hall."
            mc"You will? How come?"
            k"Because it‚Äôs also my belief that every time a person does a good deed, they shine the light a little farther into the dark."
            k"And the thing is, when you're gone, that light is going to keep shining on, pushing the shadows back."
            show sc w2kitchen k08
            k"And for that reason, I still want to help."
            show sc w2kitchen k07
            mc"Sure! That would really be great if you could."
            show sc w2kitchen k06
            mc"Perhaps we could meet here on Wednesday, during the day, to further discuss the kind of work that we‚Äôd need you to do."
            show sc w2kitchen k07
            k"Sounds good. I‚Äôm free most afternoons, maybe I could come to the hotel after lunchtime?"
            mc"That should work in with our work schedule."
            # (scene continues)"
    show sc w2kitchen k08
    k"All right [y_name], I shall see you on Wednesday."
    show sc w2kitchen k07
    mc"You will. Bye [k_name], and thanks again."
    k"You‚Äôre welcome. Have a great day."
    # (call ends)"
    play sound "sound effects/03/01/Door_Knock_Sound_Effect_Reduced.mp3"
    show sc w2kitchen k05
    # Knock, knock, knock (Door knocking audio to be added)"
    stop sound
    mc"(Oh, someone‚Äôs at the door. I better go and see who it is.)"
    scene black
    with dissolve
    scene black
    with Pause (2)




label lb_w2_sow_c_surfing:
    # Day 4 (SOW) 05 - Shortcake and Surfing"
    # SCENE BEGINS"
    # (MC goes to answer the door)"
    scene sc w2csurf c01
    with dissolve
    play ambient "sound effects/03/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
    c"Hey [y_name]."
    mc"Oh, hey [c_name]."
    show sc w2csurf c01
    c"How are you? Is [s_name] about?"
    mc"Oh, you just missed her. She said that she had something to do but she should be back very soon. "
    show sc w2csurf c04
    c"Cool. Anyway, I‚Äôm just going for a quick surf because I don‚Äôt have any classes today."
    show sc w2csurf c01
    mc"It‚Äôs certainly a great morning for it, again."
    show sc w2csurf c02
    mc"Um, I guess you can help yourself to the storage room as your boards are still in there."
    show sc w2csurf c03
    c"Hey, what are you up to at the moment? Are you doing anything important?"
    show sc w2csurf c02
    mc"Me? Well, I‚Äôm just about to finish having my breakfast, and then I‚Äôm going to head into the main office to go over a few things."
    mc"How come?"
    show sc w2csurf c03
    c"Oh, no reason."
    show sc w2csurf c02
    mc"Oh come on, there‚Äôs obviously something you wanted to ask me. Spill it!"
    show sc w2csurf c03
    c"Well‚Ä¶ I was thinking that maybe you could join me out there?"
    mc"What, you mean out there in the surf?"
    show sc w2csurf c01
    c"Yeah! It‚Äôs a lot of fun and pretty easy once you get the hang of it."
    c"I have a spare board in storage that you can use."
    mc"(Hmm‚Ä¶ I really should be doing some work around the hotel for [s_name] while she‚Äôs gone.)"
    mc"(However, this may be the only chance that I get to do something fun with [c_name]. And it‚Äôs the one thing that I know she‚Äôs really confident doing.)"
    mc"(It might be a way for me to find out why she‚Äôs so comfortable with surfing and not so comfortable or confident with just about everything else.)"
    mc"All right, count me in."
    show sc w2csurf c04
    c"Great! I‚Äôm just going to get changed, so I‚Äôll meet you down by the beach with the boards."
    show sc w2csurf c01
    mc"No problems. I‚Äôll see you down there in about ten minutes."
    # (Cousin leaves)"
    mc"(Wait a minute. What am I doing? I don‚Äôt know how to surf?)"
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2csurf c06
    with dissolve
    play ambient "sound effects/01/01/Beach_Ocean_Waves_-_Sound_Effect.mp3" loop fadein 1.0
    mc"(Sigh‚Ä¶)"
    mc"(This will either go great, or it could end up being a disaster!)"
    # (screen goes blank)"
    # (down at the beach)"
    # (MC heads down to the beach, and sees Cousin with the two boards standing upright in the sand)"
    # (She‚Äôs in a different bikini to the one the last time. Cousin is waxing her surfboard when the MC arrives - IMPORTANT)"
    # (MC still wears a shirt and board shorts)"
    show sc w2csurf c07
    c"Hey [y_name], over here!"
    show sc w2csurf c08
    # ROLLING WIP OF COUSIN IN HER BIKINI"
    mc"Oh, hey [c_name]."
    show sc w2csurf c14
    c"I grabbed that board for you. So we can head out whenever you‚Äôre ready."
    show sc w2csurf c09
    mc"Okay..."
    show sc w2csurf c11
    mc"I just have to put some lotion on first."
    # (MC removes his shirt)"
    show sc w2csurf c12
    c"(Oh my‚Ä¶)"
    # (Cousin sees the MC without his shirt on, gets a little aroused by seeing him like this)"
    show sc w2csurf c18
    mc"So how does it look out there?"
    # (MC starts putting lotion on his chest)"
    c"Huh?"
    show sc w2csurf c17
    c"Oh, the surf! Yeah, it looks like it‚Äôs an ideal day for surfing."
    show sc w2csurf c10
    mc"Great! Look, I don‚Äôt really know much about surfing [c_name], but I‚Äôve always been interested to learn."
    mc"So I was hoping that maybe you could show me a few things, as I‚Äôm not overly experienced like you are."
    show sc w2csurf c15
    c"Neither am I."
    # (Cousin distracted from looking at the MC with no top on)"
    mc"Excuse me?"
    show sc w2csurf c17
    c"Oh! What I meant was, I am."
    show sc w2csurf c16
    c"I can show you a thing or two for sure. For surfing I mean."
    show sc w2csurf c17
    c"(What the hell is wrong with me? Why do I feel so nervous around him all of a sudden?)"
    # (A close-up of Cousin‚Äôs nipples straining through her bikini top)"
    show sc w2csurf c15
    mc"(She‚Äôs acting really strange. I hope she‚Äôs okay with me joining her out in the surf today.)"
    show sc w2csurf c13
    c"So before we take our boards out into the ocean, there are a few things I need to discuss with you first."
    c"Because you‚Äôre only new at this, I think we should start you off with some smaller waves."
    show sc w2csurf c14
    c"We‚Äôre in a safe part of the beach which is important as well. The ocean isn‚Äôt too rough which will also help."
    show sc w2csurf c10
    mc"Yeah, it seems pretty calm at the moment."
    show sc w2csurf c14
    c"I also thought it would be a good idea to get you to use one of my longboards."
    show sc w2csurf c20
    c"These boards won‚Äôt allow you to progress too much today, but it‚Äôs also an ideal board to use if you‚Äôre not overly fussed about being an expert surfer."
    show sc w2csurf c14
    c"But we can talk more about that if you‚Äôre still interested in doing more surfing after we‚Äôre done."
    mc"Yeah, I guess we‚Äôll see."
    show sc w2csurf c13
    mc"I noticed that you were rubbing down your surfboard with something a little earlier on."
    show sc w2csurf c16
    c"Oh, I was waxing it actually. It‚Äôs really important to do that before you go out for a surf, as it gives you a better grip and traction."
    c"The last thing I want is for you to go sliding off your board on your first attempt to surf!"
    show sc w2csurf c20
    c"I‚Äôve waxed down your board for you already."
    show sc w2csurf c13
    mc"Oh, thanks [c_name]. What else do I need to know?"
    show sc w2csurf c14
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2csurf c14","sc w2csurf c14x","v_pt_image_index_w2_05")
    c"It‚Äôs important to know where the best place is to lay on your board."
    c"If you‚Äôre too far forward, then the nose of your board will go underwater, and that will make you fly over the top of it."
    c"If you‚Äôre too far back, then the nose will rise too far up, meaning you won‚Äôt be able to catch any waves."
    c"So you need to be somewhere in between."
    mc"In other words, stick in the middle?"
    c"More or less. Once you‚Äôve found the sweet spot on your board, then it‚Äôs time to get out there!"
    c"So for beginner surfers such as yourself [y_name], all you should be looking at doing today is being in waist-deep water."
    c"That‚Äôs as far as you need to go."
    hide screen scr_peeping_tom
    show sc w2csurf c16
    c"Come on, let‚Äôs head into the ocean with our boards."
    show sc w2csurf c14
    mc"All right, sounds good."
    mc"(Oh boy‚Ä¶ I wonder if I‚Äôm going to enjoy this, or regret it‚Ä¶)"
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (MC and cousin lay on their boards in the surf)"
    scene sc w2csurf c30
    with dissolve
    c"Mmm‚Ä¶ Don‚Äôt you just love being out here, relaxing in the ocean, with this warm, summer breeze?"
    show sc w2csurf c21
    mc"Oh yeah, it really is something."
    show sc w2csurf c31
    mc"I can kind of see why you try and get out here every chance that you get!"
    show sc w2csurf c24
    c"I honestly can‚Äôt get enough of it."
    show sc w2csurf c32
    mc"Now that we‚Äôre here, what sort of wave should a beginner surfer like me be looking for?"
    show sc w2csurf c28
    c"You should keep your eye out for a foray, mushy kind of wave to start off with."
    show sc w2csurf c22
    c"The reason for this is because it‚Äôs the easiest kind of wave to catch, and it‚Äôs also the most forgiving."
    c"And once you nail a white water takeoff, that‚Äôs what the foamy stuff is called, then later on, you can progress to catching a much bigger wave, before it‚Äôs broken, and then riding straight down the face of it."
    show sc w2csurf c24
    c"Are you ready to try and catch your first wave [y_name]?"
    show sc w2csurf c33
    mc"(Sigh‚Ä¶)"
    mc"Sure, let‚Äôs give it a go."
    show sc w2csurf c24
    c"Awesome!"
    show sc w2csurf c28
    c"Okay, first off, turn your board slightly so the nose is facing the beach."
    # (C and the MC do this) "
    c"Next, give yourself about five metres when you see a wave coming toward you."
    c"This will allow you enough time to jump onto your board, find your position, and then start paddling."
    c"You‚Äôll be looking for big, long strokes. Your hands should be cupped while kicking your feet, and make sure you get as much speed as possible."
    c"Once the wave picks you up, don‚Äôt stop paddling and kicking. For now, I just want you to belly board as far as you can go. Got it?"
    show sc w2csurf c32
    mc"Yes, that all sounds easy enough."
    # (MC does this action, following Cousin‚Äôs instructions)"
    show sc w2csurf c34
    mc"(Okay‚Ä¶ Here we go!!!)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2csurf c35
    with dissolve
    mc"(Whoah!! What a rush!)"
    show sc w2csurf c28
    c"(He‚Äôs doing it!)"
    show sc w2csurf c35
    mc"(This is awesome!)"
    # (screen goes blank)"
    # (MC comes back to cousin, standing waist-deep next to cousin)"
    scene sc w2csurf c31
    with dissolve
    mc"How was that?"
    show sc w2csurf c24
    c"Very good for a first time [y_name]. Are you sure you‚Äôve never surfed before?"
    show sc w2csurf c22
    mc"No, never."
    c"All right, well I might be able to teach you how to stand on your board before we head back in. That is, if you‚Äôre still interested?"
    c"So, are you in?"
    # [No, that will do / Sure, let‚Äôs do it]"
    menu:
        "No, that will do":
            show sc w2csurf c23
            mc"Actually, I think that‚Äôs enough for me today. I‚Äôm going to head back to shore."
            mc"But don‚Äôt let me stop you from enjoying yourself out here."
            show sc w2csurf c25
            $ c_points = change_stat(c_points,-5,c_name)
            c"Oh, okay." #-5 COUSIN POINTS"
            c"I‚Äôll just catch a few more waves and then I'll meet up with you after."
            show sc w2csurf c34
            mc"No problems. Have fun [c_name]."
            scene black
            with dissolve
            scene black
            with Pause (2)
            # END SCENE"
        "Sure, let‚Äôs do it"(wt="Best choice"):
            mc"Yep, I want more of that!"
            show sc w2csurf c24
            c"Haha, easy there [y_name]. You ain‚Äôt seen nothing yet."
            show sc w2csurf c28
            c"Okay, so this time, I‚Äôm going to talk you through how to do a popup."
            show sc w2csurf c23
            c"You can normally practise this on the sand, but because we‚Äôre short on time, let‚Äôs see if you can manage to do one while we‚Äôre here in the water."
            mc"All right, what do I need to do?"
            show sc w2csurf c22
            if persistent.v_xray_enabled:
                show screen scr_peeping_tom("sc w2csurf c22","sc w2csurf c22x","v_pt_image_index_w2_06")
            c"So using the same sequence for catching a wave that I just showed you, at the correct point..."
            c"You‚Äôre going to stop paddling, and then move your hands to the rails of your board, and also lift your chest up."
            c"This creates room for your legs to come up and onto the board."
            c"Once they‚Äôre on, you‚Äôre going to want to bring your stronger foot forward, and your other foot behind, with them both about shoulder-width apart."
            hide screen scr_peeping_tom
            show sc w2csurf c23
            c"Do you know which foot is stronger than the other?"
            # [Cocky answer / Confident answer]"
            menu:
                "Cocky answer":
                    show sc w2csurf c31
                    mc"Oh yeah, my stronger foot is almost what some would consider as ‚Äúworld-class‚Äù, just like last year‚Äôs Ballon d'Or winner!"
                    show sc w2csurf c27
                    c"Ballon d'Or? What's that?"
                    show sc w2csurf c33
                    mc"Uh, never mind."
                    show sc w2csurf c26
                    $ c_points = change_stat(c_points,-2,c_name)
                    c"(What on earth was he talking about?)" #-2 COUSIN POINTS"
                "Confident answer"(wt="Best choice"):
                    show sc w2csurf c31
                    mc"Oh yeah, I know which one it is. I‚Äôm mainly left-footed."
                    show sc w2csurf c24
                    c"Really? Me too! Well, it‚Äôs the foot I always put forward first on my board, without thinking about it much."
                    show sc w2csurf c23
                    mc"Did you know that around eight percent of the world‚Äôs population are left-footed?"
                    $ c_points = change_stat(c_points,3,c_name)
                    c"They are? Really?"
                    mc"Honestly! So I guess that puts you and me in a very unique group of people [c_name]."
                    show sc w2csurf c24
                    c"Haha, I guess it does." #+3 COUSIN POINTS"
                    # (scene continues)"
            show sc w2csurf c22
            c"When both of your feet are on the board, then you can take your hands off, and make sure to get into a low, crouched position."
            c"From there, look and point your board towards the beach, because that‚Äôs where you should be heading."
            show sc w2csurf c23
            c"Does that all make sense?"
            show sc w2csurf c31
            mc"Yes, perfect sense."
            show sc w2csurf c23
            c"Do you have any questions before we give this a try?"
            mc"Yes. What do I do if I fall off?"
            show sc w2csurf c22
            c"I‚Äôm glad you asked."
            show sc w2csurf c27
            c"So if you fall off and you‚Äôre underwater, make sure to place your hands above your head when you‚Äôre coming back up to the surface."
            c"This is a precaution, just in case the board is floating directly above your head."
            c"Does that make sense?"
            show sc w2csurf c31
            mc"Perfect sense."
            show sc w2csurf c22
            c"Awesome. Okay, watch me first, and then you can try."
            mc"No problems."
            scene black
            with dissolve
            scene black
            with Pause (2)
            scene sc w2csurf c46
            with dissolve
            mc"([c_name] has this confident look in her eyes that is unlike any that I‚Äôve seen from her previously.)"
            show sc w2csurf c47
            if persistent.v_xray_enabled:
                show screen scr_peeping_tom("sc w2csurf c47","sc w2csurf c47x","v_pt_image_index_w2_07")
            mc"(She looks like she‚Äôs done this a thousand times before.)"
            hide screen scr_peeping_tom
            show sc w2csurf c49
            show screen scr_rewards("sc w2csurf c49b","v_rewards_c_21")
            mc"(There she goes!)"
            hide screen scr_rewards
            show sc w2csurf c48
            mc"(Wow‚Ä¶ Now THAT was majestic!)"
            scene black
            with dissolve
            scene black
            with Pause (2)
            scene sc w2csurf c22
            with dissolve
            c"Did you watch that closely [y_name]?"
            # (C still surfing in the same position)"
            mc"Yeah, I think I got it."
            # (C comes back down, back to the basic original laying down position)"
            show sc w2csurf c24
            c"All right, there should be another decent-sized wave here in the next few minutes. How about you try and catch the next one?"
            show sc w2csurf c22
            mc"Uh, sure. No sweat!"
            show sc w2csurf c34
            mc"(Okay, deep breath, let‚Äôs see if I remember everything here.)"
            scene black
            with dissolve
            scene black
            with Pause (2)
            show sc w2csurf c36
            with dissolve
            # (the MC starts paddling towards the oncoming wave)"
            mc"(So far, so good...)"
            show sc w2csurf c37
            mc"(Now to raise my chest up a little higher.)"
            show sc w2csurf c28
            c"(He‚Äôs almost halfway there. This next part should be interesting.)"
            show sc w2csurf c37
            mc"(Okay, now which one is my stronger foot again?)"
            # [Right foot / Left foot / Take a guess]"
            menu:
                "Right foot":
                    #‚Äù (wrong choice)"
                    show sc w2csurf c40
                    mc"(I don‚Äôt have much time to think, because that wave is coming this way pretty fast!)"
                    # (MC puts his right foot forward in front of him)"
                    show sc w2csurf c41
                    mc"(Oh, hang on a second! Why did I put my right foot forw-)"
                    show sc w2csurf c29
                    c"[y_name]!!"
                    # (MC slips, he goes head-first into the ocean and his board goes flying in the opposite direction)"
                    show sc w2csurf c42
                    with vpunch
                    mc"SHIIIIIIIT!!"
                    # (wave crashing audio to be added here)"
                    # (screen goes blank)"
                    # (scene starts with the MC‚Äôs head above water, with his board behind him)"
                    show sc w2csurf c29
                    c"[y_name]! Are you all right?"
                    show sc w2csurf c43
                    $ c_points = change_stat(c_points,-5,c_name)
                    mc"Yeah, I‚Äôm fine." #-5 COUSIN POINTS"
                    show sc w2csurf c26
                    c"What happened?"
                    show sc w2csurf c43
                    mc"I‚Äôm not too sure. I thought I did it exactly how you showed me."
                    mc"I don‚Äôt know, maybe my feet placement wasn‚Äôt right or something."
                    show sc w2csurf c26
                    c"(Why didn‚Äôt he use his stronger foot like he said he would?)"
                    c"It‚Äôs okay, you‚Äôre still learning."
                    show sc w2csurf c45
                    mc"Perhaps I could give it another go?"
                    show sc w2csurf c26
                    c"Uh, actually, maybe we should head back."
                    c"I mean, [s_name] could have returned to the hotel already and she might be looking for you."
                    show sc w2csurf c43
                    mc"Yeah, you‚Äôre probably right. I‚Äôm sorry I didn‚Äôt listen to you [c_name]."
                    show sc w2csurf c26
                    c"It‚Äôs fine [y_name], really. Come on, let‚Äôs paddle back to the shore."
                    # (cousin starts paddling ahead of the MC)"
                    show sc w2csurf c43
                    mc"(Damn, what the hell happened? It‚Äôs like I had two right feet once I got onto the board‚Ä¶)"
                "Left foot"(wt="Best choice"):
                    show sc w2csurf c39
                    mc"(I know for sure that my left foot is the stronger of the two.)"
                    # (MC puts his left foot forward in front of him)"
                    mc"(That‚Äôs the first bit, now for the hard part!)"
                    show sc w2csurf c38
                    mc"(Holy crap! I‚Äôm doing it!!)"
                    # (MC riding a small wave)"
                    show sc w2csurf c28
                    c"YAY!! Great going [y_name]!"
                    show sc w2csurf c44
                    mc"This is the greatest thrill of my life! I'm the king of the world! Woo hoo! Woo hoo! I-"
                    # (MC slips, he goes head-first into the ocean and his board goes flying in the opposite direction)"
                    show sc w2csurf c50
                    mc"WOAH!!"
                    # (wave crashing audio to be added here)"
                    scene black
                    with dissolve
                    scene black
                    with Pause (2)
                    scene sc w2csurf c22
                    with dissolve
                    c"[y_name]! Are you all right?"
                    # (cousin smiling, impressed with the MC)"
                    show sc w2csurf c31
                    mc"Better than ever! So, did I do good?"
                    show sc w2csurf c24
                    $ c_points = change_stat(c_points,5,c_name)
                    c"That was amazing [y_name], I‚Äôm really impressed." #+5 COUSIN POINTS"
                    show sc w2csurf c22
                    c"Say, are you sure you‚Äôre not a pro-surfer?"
                    # (Cousin looks at him skeptically with that question)"
                    show sc w2csurf c31
                    mc"Hahaha! No, I can assure you I‚Äôm not."
                    mc"Hey, do you think I could try that one more time?"
                    show sc w2csurf c23
                    c"Oh, I‚Äôd honestly love to keep doing this with you [y_name], but maybe we should head back now."
                    show sc w2csurf c25
                    c"I mean, [s_name] could have returned to the hotel already and she might be looking for you."
                    mc"Yeah, I guess you‚Äôre right."
                    show sc w2csurf c22
                    c"Come on, let‚Äôs head back to shore and then we can quickly discuss what other surfing moves you might want to learn next time!"
                    # (Final shot of MC and cousin laying flat on their boards, heading back to shore)"
                    # (screen goes blank)"
                "Take a guess":
                    show sc w2csurf c40
                    mc"(Screw it! Both of my feet are as solid as a rock!)"
                    # (MC puts his right foot forward in front of him)"
                    show sc w2csurf c41
                    mc"(Oh, hang on a second!)"
                    show sc w2csurf c29
                    c"[y_name]!!"
                    # (MC slips, he goes headfirst into the ocean and his board goes flying in the opposite direction)"
                    show sc w2csurf c42
                    with vpunch
                    mc"SHIIIIIIIT!!"
                    # (wave crashing audio to be added here)"
                    # (screen goes blank)"
                    # (scene starts with the MC‚Äôs head above water, with his board behind him)"
                    show sc w2csurf c26
                    c"[y_name]! Are you all right?"
                    show sc w2csurf c43
                    $ c_points = change_stat(c_points,-5,c_name)
                    mc"Yeah, I‚Äôm fine." #-5 COUSIN POINTS"
                    show sc w2csurf c26
                    c"What happened?"
                    show sc w2csurf c43
                    mc"I‚Äôm not too sure. I thought I did it exactly how you showed me."
                    mc"I don‚Äôt know, maybe my feet placement wasn‚Äôt right or something."
                    show sc w2csurf c26
                    c"(Why didn‚Äôt he use his stronger foot like he said he would?)"
                    c"It‚Äôs okay, you‚Äôre still learning."
                    show sc w2csurf c43
                    mc"Perhaps I could give it another go?"
                    show sc w2csurf c26
                    c"Uh, actually, maybe we should head back."
                    c"I mean, [s_name] could have returned to the hotel already and she might be looking for you."
                    show sc w2csurf c43
                    mc"Yeah, you‚Äôre probably right. I‚Äôm sorry I didn‚Äôt listen to you [c_name]."
                    show sc w2csurf c26
                    c"It‚Äôs fine [y_name], really.  Come on, let‚Äôs paddle back to the shore."
                    # (cousin starts paddling ahead of the MC)"
                    show sc w2csurf c43
                    mc"(Damn, what the hell happened? It‚Äôs like I had two right feet once I got onto the board‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)



label lb_w2_sow_after_surf:
    # Day 4 (SOW) 06 - Shortcake and MC resting on the beach before they go back to the hotel"
    # SCENE BEGINS"
    # (Cousin and the MC on the beach, drying down with towels)"
    scene sc w2csurftalk t04
    with dissolve
    c"So, do you feel any better after going for your first surf since arriving in Sunshine Bay?"
    show sc w2csurftalk t02
    mc"You know I have to admit, I totally understand why you enjoy it so much. It‚Äôs really quite refreshing."
    mc"(With the small amount of time that I have, I better ask [c_name] some quick questions, just to get to know more about her while it‚Äôs just the two of us.)"
    mc"So what exactly is it about surfing that you love so much [c_name]?"
    c"Oh, well, I guess I see it as my own way of escaping the real world."
    show sc w2csurftalk t06
    c"For a long time growing up, everything I had to do always seemed to be so serious."
    c"With school work, it was always expected of me by my teachers and my Mom to be top of my class and to get good grades."
    c"There was no other choice."
    show sc w2csurftalk t02
    c"Because of a friend in high school, I took up surfing a few years ago."
    show sc w2csurftalk t07
    c"The main thing I love about being out there on my board, is that I find it to be incredibly challenging at times because you often have to think on your feet."
    show sc w2csurftalk t02
    c"You don‚Äôt always know what the waves are going to do."
    c"It makes things even harder if my focus isn‚Äôt entirely there by the time I start paddling out."
    show sc w2csurftalk t01
    c"But the biggest reason I love it so much is that it‚Äôs just me out there. I don‚Äôt need to be with other people to go surfing."
    show sc w2csurftalk t08
    c"I can be out in the ocean, drifting on the water, in peace, and alone with my thoughts."
    show sc w2csurftalk t01
    mc"That sounds like a nice feeling to have. Kind of like yoga in a sense."
    show sc w2csurftalk t02
    mc"So you like to be challenged from time to time, huh?"
    show sc w2csurftalk t04
    c"Yeah, I really do."
    show sc w2csurftalk t03
    c"But it has to be something that I won‚Äôt get bored of after five minutes."
    show sc w2csurftalk t01
    c"With surfing, I was instantly hooked as soon as I rode my first wave."
    show sc w2csurftalk t08
    c"I haven‚Äôt felt anything like that since, and it‚Äôs also the reason why I try and go as often as possible."
    c"I want that feeling all of the time."
    show sc w2csurftalk t02
    mc"I know you say that you like going out there alone, but don't you have any surfing friends who you sometimes go with?"
    show sc w2csurftalk t03
    c"I‚Äôve seen the same groups of surfers down here every so often, but I never talk to them."
    mc"How come? I mean, you already have something in common with them."
    show sc w2csurftalk t02
    mc"To me, it would seem like the perfect opportunity to make friends based on how much you enjoy the same thing."
    show sc w2csurftalk t06
    c"I guess‚Ä¶ But again, that comes back to me not being confident approaching other people."
    c"And I much prefer my own company."
    show sc w2csurftalk t02
    mc"Okay, I get it. I think you should highly consider it though."
    mc"I mean, you were able to easily have a conversation with me about surfing..."
    mc"And up until half an hour ago, I knew very little about how to catch a wave, or even how to do a belly board surfing."
    show sc w2csurftalk t05
    c"So what are you suggesting [y_name]?"
    show sc w2csurftalk t02
    mc"Play to your strengths. I mean they‚Äôre out there for the exact same reason you are. "
    mc"So if the opportunity arises to talk with another surfer, then tell them what you love most about it."
    mc"And ask them what they love about it too. Or you could show them what your favourite surfing move is."
    mc"You‚Äôd be surprised how people react when they hear someone talk so enthusiastically about what they enjoy doing."
    mc"I mean, why do you think I accepted to come and join you down here this morning?"
    show sc w2csurftalk t05
    c"Um, why?"
    show sc w2csurftalk t02
    mc"Because I was genuinely interested to find out why you love surfing so much."
    mc"And even though our time in the ocean was brief, I totally get why you do this."
    mc"Surfing has become like an addiction for you, the best type of addiction one can have."
    # (C smiles)"
    # [Ask about her friend / Ask about [s_name] ]"


    show sc w2csurftalk t01
    menu:
        "Ask about her friend":
            show sc w2csurftalk t02
            mc"So this friend of yours, the one that got you into surfing. Do you still hang out with her?"
            show sc w2csurftalk t06
            c"(Sigh‚Ä¶)"
            c"No, not so much."
            show sc w2csurftalk t03
            c"We‚Äôre still friends, and we chat online every now and then, but I haven‚Äôt seen her since she moved to Seaside."
            show sc w2csurftalk t02
            mc"Is that far from here?"
            show sc w2csurftalk t03
            c"For me it is. And it‚Äôs definitely too far to travel by scooter."
            mc"I see."
            mc"(Hmm‚Ä¶ Maybe while I‚Äôm here in town, I could look at introducing [c_name] to some of the nicer people that I‚Äôve met. Yuki for instance.)"
            mc"(They‚Äôre about the same age, both pretty intelligent, and I think they‚Äôd get on really well.)"
            menu:
                "Ask about [s_name]":
                    show sc w2csurftalk t02
                    mc"What about [s_name]? Did you two hang out much when you were growing up?"
                    show sc w2csurftalk t05
                    c"Yes and no. I mean, we‚Äôre close but not like sisters, close."
                    show sc w2csurftalk t02
                    mc"Why do you think that is?"
                    show sc w2csurftalk t03
                    c"I think it‚Äôs because we‚Äôve always been very different from each other."
                    show sc w2csurftalk t06
                    c"Once [s_name] graduated from high school and soon after went to college, she became more of a social party-oriented girl, whereas I was the more studious type."
                    c"It didn‚Äôt help that I was still in high school at the time either."
                    c"I guess she didn‚Äôt want to be seen hanging out with someone like me who wasn‚Äôt in college."
                    show sc w2csurftalk t02
                    mc"([c_name] had it pretty rough while she was growing up.)"
                    mc"(Her Mom and teachers didn‚Äôt properly nurture her by the sound of things.)"
                    mc"([s_name] may not have given her the time of day once she started college, and there‚Äôs no mention of her father, or even a father-figure in her life, at all.)"
                    mc"(Maybe my upbringing wasn‚Äôt so bad by comparison.)"
                    # (scene continues)"
                "Social activities":
                    show sc w2csurftalk t02




    show sc w2csurftalk t02
    mc"What about other social activities?"
    mc"Surely you did some kind of social or extracurricular activities while you were in high school?"
    show sc w2csurftalk t03
    c"I used to have tennis lessons after school when I was younger, and I was part of the chess club and the debate team too."
    c"But when I was in my final year of high school, I dropped all of these activities to focus on getting good grades."
    show sc w2csurftalk t06
    c"Actually, it was my Mom who recommended that I stop taking any extra classes as she wanted me to get the best grades possible before graduating from high school."
    show sc w2csurftalk t02
    mc"So if the choice had have been up to you, would you have continued doing these extra activities during your final year?"
    show sc w2csurftalk t01
    c"Yeah, I believe that I would have."
    show sc w2csurftalk t07
    c"I had a couple of people I could talk to during my tennis lessons like my coach and another girl who I practised with."
    show sc w2csurftalk t03
    c"But with the debate team, we never talked about anything aside from the task we were given."
    show sc w2csurftalk t01
    c"I do remember enjoying their company though."
    show sc w2csurftalk t02
    mc"Why do you think Trisha wanted you to turn all your focus towards your studies during that final year?"
    c"I guess she was hoping that I'd follow in her footsteps, and that I would someday apply for an important job like the one that she has."
    c"That‚Äôs another thing where [s_name] and I are very different."
    mc"Oh? How so?"
    show sc w2csurftalk t09
    c"Her Mom, Ashley, has always been somewhat protective of [s_name] as you well know, even though it may not seem like it at the present time."
    c"Whereas my mother has always expected way too much of me and often spoke to me like I was someone who worked for her, rather than her own daughter."
    c"Sometimes I felt really alone and completely vulnerable because of this."
    show sc w2csurftalk t03
    mc"Oh boy, that‚Äôs not a nice feeling to have. But I know how you feel."
    c"You do?"
    show sc w2csurftalk t02
    mc"Yeah, sort of. My Dad never showed me the kind of interest or affection that I really needed after my Mom died."
    mc"And because he used to go out to sea with the Navy quite often, and for several weeks at a time, I hardly ever saw him when I was growing up."
    mc"I mean it was kind of nice when Ashley and [s_name] moved in with us, but he never taught me any life or social skills to be able to handle living with them."
    mc"Which I think is the reason why [s_name] and I rarely interacted with each other when we were living together."
    show sc w2csurftalk t05
    c"(Oh‚Ä¶ It sounds like his father neglected him, just like my mother has done with me.)"
    show sc w2csurftalk t02
    mc"And in another similar way, my Dad was pretty disappointed when I told him I had no interest in joining the Navy like him."
    mc"But sometimes you gotta go your own way, you know?"
    c"Yeah, I agree."
    show sc w2csurftalk t05
    c"([y_name] and I have a lot more in common than I first thought.)"
    show sc w2csurftalk t07
    c"(Maybe it‚Äôs another reason why I feel so comfortable talking to him. He kind of gets where I‚Äôm coming from.)"
    show sc w2csurftalk t02
    c"I couldn‚Äôt help but notice that you‚Äôve asked me a lot of questions about my life [y_name]. Any reason why?"
    mc"Well I‚Äôm really interested to know more about you [c_name]."
    mc"You‚Äôll have to forgive me, but it‚Äôs kind of a lawyer trait to ask a lot of questions and to want to know everything about everyone."
    show sc w2csurftalk t01
    c"That‚Äôs fair enough."
    show sc w2csurftalk t09
    c"Okay, so in your expert opinion, did you find me in any way interesting?"
    show sc w2csurftalk t02
    mc"Yes, most definitely! And after what I‚Äôve just learned about you, I‚Äôm really hoping that you‚Äôd like to come by the hotel sometime soon to learn more about the business."
    mc"I really do believe it would be a good experience for you."
    mc"What do you think?"
    show sc w2csurftalk t09
    c"I‚Ä¶ I want to, but I need you and [s_name] to know that a future in hospitality or attaining a hotel management degree isn‚Äôt what I had in mind."
    show sc w2csurftalk t01
    c"But I am willing to help you both out because it sounds like you really need it."
    mc"We certainly do. And that‚Äôs all we can ask of you [c_name]."
    show sc w2csurftalk t02
    mc"(I really should get going, just in case [s_name] has returned to the hotel.)"
    show sc w2csurftalk t03
    c"So I was thinking, would you like to do this again sometime soon?"
    mc"Oh, you mean surfing together?"
    show sc w2csurftalk t01
    c"Yeah, you really enjoyed it, didn‚Äôt you?"
    mc"Yes, absolutely. I mean us lefties have gotta stick together, right?"
    show sc w2csurftalk t04
    c"Haha, yes we do!"
    show sc w2csurftalk t07
    c"(I like the fact that [y_name] isn‚Äôt in a hurry to leave, as I really do enjoy his company.)"
    show sc w2csurftalk t01
    c"Okay, well the next time I come down here for a surf, I‚Äôll see if you‚Äôre free to come and join me, and then we can go from there."
    show sc w2csurftalk t04
    c"I‚Äôll try and teach you how to do a bottom turn, a tail slide, and maybe even the tube ride!"
    show sc w2csurftalk t01
    mc"Okay, I have no idea what you just said, but I‚Äôm keenly interested to find out!"
    show sc w2csurftalk t04
    play sound "sound effects/01/02/female_laughing_giggling.mp3"
    c"Haha, you‚Äôre funny [y_name]."
    stop sound
    show sc w2csurftalk t05
    c"Anyways, we should probably get going. You don‚Äôt want to keep [s_name] waiting."
    show sc w2csurftalk t01
    mc"Yes, you're right. Come on, let's get going then."
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2csurftalk t11
    with dissolve
    play ambient "sound effects/01/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
    mc"So um, are you not coming in to see [s_name] before you leave?"
    show sc w2csurftalk t10
    c"Unfortunately I can‚Äôt, but I promise to come up and visit you both very soon."
    show sc w2csurftalk t11
    mc"So, does that mean that you‚Äôre definitely interested in learning more about the hotel business?"
    show sc w2csurftalk t10
    c"I guess it does, yeah."
    show sc w2csurftalk t12
    c"Well, as long as you‚Äôre willing to continue teaching me."
    mc"Oh I will, especially if you can turn me into a pro-surfer!"
    show sc w2csurftalk t13
    c"Haha! I don‚Äôt know about that, but it sounds like we have a deal."
    # [Shake her hand / Kiss her on the cheek]"
    menu:
        "Shake her hand":
            show sc w2csurftalk t14
            mc"Deal!"
            # (they shake on it)"
        "Kiss her on the cheek"(wt="Best choice"):
            play sound "sound effects/01/02/Male_kissing_girl_on_the_cheek.mp3"
            show sc w2csurftalk t15
            show screen scr_rewards("sc w2csurftalk t15b","v_rewards_c_22")
            mc"Mwah!"
            stop sound
            mc"Deal!"
            # (the MC kisses her on the cheek)"
            $ c_points = change_stat(c_points,2,c_name)
            c"(Oh my!)" #+2 COUSIN PTS"
            hide screen scr_rewards
    # (scene continues)"
    show sc w2csurftalk t12
    c"Okay, I‚Äôm off. I‚Äôll talk to you soon [y_name]."
    mc"Bye [c_name]."
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_w2_sow_nicole_work








label lb_w2_sow_nicole_work:
    # Day 4 (SOW) 07 - Nicole at work - given a high profile divorce case"
    # SCENE BEGINS"
    # (Nicole sitting in her office on the phone)"
    # (a line from Primal Fear)"
    scene sc w2nicoleoffice o08
    with dissolve
    nic"Uh-huh. Well you see, that‚Äôs where you and I disagree counsellor."
    nic"Unlike you, I believe in the notion that people are innocent until proven guilty."
    show sc w2nicoleoffice o05
    nic"I believe in that notion because I choose to believe in the basic goodness of people."
    show sc w2nicoleoffice o08
    nic"I choose to believe that not all crimes are committed by bad people."
    nic"And I try to understand that some very, very good people do some very bad things."
    show sc w2nicoleoffice o09
    "‚Ä¶"
    show sc w2nicoleoffice o25
    nic"Oh yeah, well you better look out the next time we meet in court, counsellor. Good day!"
    # (Nicole slams the phone down)"
    show sc w2nicoleoffice o01
    nic"(Sigh‚Ä¶ Asshole.)"
    nic"(I could do with just about anything to take my mind off that jerk from Ditcher, Quick and Hyde lawyers‚Ä¶)"
    # (Nicole‚Äôs Boss - NB - knocks on her door)"
    play sound "sound effects/01/01/Door_Knock_Sound_Effect_Free.mp3"
    "(Knock, knock, knock)"
    stop sound
    show sc w2nicoleoffice o12
    nb"Hey Nicole, do you have a second?"
    show sc w2nicoleoffice o13
    nic"Sure thing boss, what do you need?"
    show sc w2nicoleoffice o12
    nb"Janet Venable has come down with the flu and I need you to continue on with the case she had just started looking at."
    nic"Janet? Doesn‚Äôt she normally handle divorce cases?"
    nb"Precisely. Here it is, it‚Äôs a very high profile case, which is why I thought it would be best that you take it over."
    nb"Any other cases that you‚Äôve been working on, will be taken off you and given to other associates to allow you to completely focus on this one."
    show sc w2nicoleoffice o11
    nic"Uh‚Ä¶"
    nb"Is that a problem for you Nicole?"
    nic"No Sir."
    show sc w2nicoleoffice o01
    nic"(Dammit, a divorce case? That‚Äôs the last thing I want to be working on right now.)"
    show sc w2nicoleoffice o12
    nb"Anyway, you won‚Äôt have much time to look it over before the client arrives to go over this with you."
    nic"How much time do I have exactly?"
    nb"They‚Äôll be here this afternoon, just after lunch. I know that's not much time for you to prepare, but I need you to read through the documents in that file as quickly as possible."
    show sc w2nicoleoffice o11
    nic"Are you sure you can‚Äôt get someone else to take this case boss?"
    nb"I‚Äôm sorry Nicole, but you‚Äôre the best person I‚Äôve got and I know you‚Äôll be able to handle this better than anyone."
    nb"Now get to it, the clocks ticking."
    # (the boss leaves)"
    show sc w2nicoleoffice o01
    nic"(Why did this have to happen now? I‚Äôm going to be having a meeting very shortly with someone who will be looking to separate from their partner.)"
    nic"(This is really not ideal, especially with [y_name] being miles away and with our relationship not exactly being on steady ground before he left.)"
    nic"(It sounds like really bad mojo.)"
    # (Nicole looks down at the file as the screen goes blank)"
    # (scene returns with Nicole still going through the paperwork)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2nicoleoffice o20
    with dissolve
    nic"(Okay, I think I‚Äôve got the gist of this case now.)"
    show sc w2nicoleoffice o21
    nic"(Sigh‚Ä¶)"
    nic"(It‚Äôs a wonder that these two were married for so long. What the hell was it that kept them together all this time?)"
    # (Nicole‚Äôs intercom goes off, is spoken to by her receptionist)"
    show sc w2nicoleoffice o23
    "Miss Nicole?"
    # (Nicole speaks to the intercom, to her receptionist)"
    nic"Yes Lizzie?"
    "Mrs. Johnson is here to see you now."
    show sc w2nicoleoffice o24
    nic"Um, sure. Send her on in."
    "Yes Miss Nicole."
    show sc w2nicoleoffice o21
    nic"(It will be interesting to hear this woman‚Äôs side of the story, in her own words.)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2nicoleoffice o12
    with dissolve
    play sound "sound effects/01/01/Door_Knock_Sound_Effect_Free.mp3"
    "(Knock, knock, knock)" #(audio to be added)"
    stop sound
    "Excuse me, Nicole is it?"
    show sc w2nicoleoffice o13
    nic"Yes, and you would be Mrs. Johnson?"
    show sc w2nicoleoffice o19
    mer"That I am. But you can call me Meredith."
    nic"Sure. Please take a seat Meredith."
    # (Meredith sits on the other side of the desk to Nicole, who is writing down notes as Meredith talks)"
    show sc w2nicoleoffice o04
    nic"Would you like my receptionist to get you something to drink before we begin?"
    show sc w2nicoleoffice o18
    mer"No I‚Äôm fine. I‚Äôd like to get straight to business right away."
    show sc w2nicoleoffice o04
    nic"As you wish."
    show sc w2nicoleoffice o16
    mer"So your boss tells me that you‚Äôre one the best young attorneys in the city. Is that true?"
    show sc w2nicoleoffice o04
    nic"I‚Äôd like to think I can mix it with the best of them, yeah."
    show sc w2nicoleoffice o18
    mer"That‚Äôs great to hear."
    show sc w2nicoleoffice o16
    mer"I take it that you‚Äôve gone through my case files already?"
    show sc w2nicoleoffice o02
    nic"Yes, as much as I could."
    nic"First of all, I just wanted to check with you if the figure that I have here is correct before I ask you some more questions."
    nic"My understanding is you‚Äôre looking at half of you and your husband‚Äôs combined fortune, plus splitting most of your assets, fifty-fifty."
    nic"Is that right?"
    show sc w2nicoleoffice o15
    mer"That‚Äôs correct. He can keep the car, but I‚Äôm definitely getting our dog whether he likes it or not."
    show sc w2nicoleoffice o02
    nic"Okay, I‚Äôll make a note of that."
    nic"If you don‚Äôt mind, I‚Äôd like to get a little bit more detail and background from you, to be able to help me understand how things have come to this."
    show sc w2nicoleoffice o16
    mer"What did you need to know?"
    show sc w2nicoleoffice o02
    nic"How did you decide that divorce was the best option for you both?"
    show sc w2nicoleoffice o16
    mer"Um, how is that in any way relevant?"
    show sc w2nicoleoffice o02
    nic"I know it may seem a little unorthodox..."
    show sc w2nicoleoffice o04
    nic"But knowing more about you and your husband‚Äôs relationship prior to these divorce proceedings may give me some ideas on how to get the things that you are requesting in your divorce settlement."
    show sc w2nicoleoffice o15
    mer"But how are some of my personal details relevant?"
    show sc w2nicoleoffice o02
    nic"Mrs. Johnson, um, I mean Meredith. In most divorce cases of this nature, each side may use various ‚Äúweapons‚Äù against each other shall we say."
    nic"Some will use almost anything and everything that can in order to get the upper hand."
    nic"So the more I know about you and your husband and the last stages of your marriage, then the better I can prepare myself so I‚Äôm always two steps ahead."
    show sc w2nicoleoffice o01
    nic"So, did he ever cheat on you or were there ever any suspicions of adultery on his part?"
    show sc w2nicoleoffice o16
    mer"No, not that I‚Äôm aware of. The longer we stayed together, the more I realised how much we‚Äôd drifted apart."
    show sc w2nicoleoffice o15
    mer"We didn‚Äôt want the same things, and because of a few ‚Äúsuggestions‚Äù from my husband, that confirmed to me that his heart wasn‚Äôt really in our marriage anymore."
    mer"And many more arguments eventuated because of this."
    show sc w2nicoleoffice o02
    nic"Hold up, you said that there were suggestions from your husband. What did you mean by that?"
    show sc w2nicoleoffice o15
    mer"I think he knew that our marriage was in trouble, and he was trying to take the easy way out so he could see other women."
    show sc w2nicoleoffice o01
    nic"I‚Äôm sorry, but, how do you mean?"
    show sc w2nicoleoffice o15
    mer"He first floated the idea of us both having a more open relationship, kind of like what the Smiths had with each other, allegedly."
    mer"At first, I thought he was joking. But then when he mentioned us taking a break for a while, that‚Äôs when I knew something was up with him."
    mer"I foolishly fought to keep our marriage alive, we went to counselling together, but soon after the arguments started up again."
    mer"My husband and I went for several weeks without having sex, which soon turned into months, many, many more months."
    mer"I thought for sure he was cheating on me as soon as he brought up the idea of us taking a break again, and more specifically when he floated the idea about us both being allowed to have hall passes."
    mer"That‚Äôs when I really lost my temper with him."
    show sc w2nicoleoffice o02
    nic"Yes, I read that in the report. So, did you have any hard proof that your husband was seeing someone else?"
    show sc w2nicoleoffice o15
    mer"No, unfortunately, I never found anything."
    show sc w2nicoleoffice o16
    mer"As much as I hate to admit it, I often think just how different things might have been if I‚Äôd accepted his offer for us to take a break the first time he suggested it to me."
    mer"It might have been just the thing that not only saved our marriage but maybe even made us realise how much we would have missed each other."
    show sc w2nicoleoffice o02
    nic"So, you would‚Äôve been okay with him seeing or dating other women? And he would‚Äôve been all right with you being with other men?"
    show sc w2nicoleoffice o15
    mer"I‚Äôm honestly not sure. But after fifteen years of being married to the guy, things were bound to get stale."
    mer"We had plenty of opportunities to work on our marriage and we just couldn‚Äôt make it work."
    show sc w2nicoleoffice o02
    nic"So you‚Äôre saying that there‚Äôs no chance of you two reconciling?"
    show sc w2nicoleoffice o15
    mer"No, there‚Äôs definitely no going back now."
    mer"There have been too many harsh words said to each other, stuff that you definitely can‚Äôt take back."
    mer"The animosity continued to build up so that every time we had a hiccup in our relationship, the old accusations would come out."
    mer"It‚Äôs like we are both on our own personal hair triggers whenever we were near each other."
    show sc w2nicoleoffice o01
    nic"I‚Äôm really sorry to hear that."
    show sc w2nicoleoffice o02
    nic"Okay, I think I have what I need now to proceed with your case Meredith."
    show sc w2nicoleoffice o18
    mer"Thanks for seeing me on such short notice."
    show sc w2nicoleoffice o04
    nic"That‚Äôs okay. Us attorneys are expected to be on call pretty much any time of day."
    show sc w2nicoleoffice o02
    nic"Meredith, I‚Äôd like you to come back in later this week, so we can decide what is the best way to proceed with this case."
    nic"I‚Äôm more than happy to take it, but I‚Äôm going to need a couple of days to go through everything I have here and also what we have just discussed."
    nic"But if you think of anything between now and when my receptionist calls you for a follow-up meeting, please let her know."
    show sc w2nicoleoffice o15
    mer"I will, for sure. I just want this nightmare to be wrapped up as quickly and painlessly as possible."
    show sc w2nicoleoffice o04
    nic"I‚Äôll do what I can. Will there be anything else?"
    show sc w2nicoleoffice o19
    mer"No, you‚Äôve been more than helpful Nicole."
    # (Meredith shakes Nicole‚Äôs hand)"
    mer"I feel very confident having you as my attorney."
    nic"Thank you, that sure means a lot."
    mer"I‚Äôll show myself out. Thanks again."
    nic"Good day to you Meredith."
    # (Meredith leaves)"
    # (Nicole sits in her seat behind her desk, feet up on the desk)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2nicoleoffice o21
    with dissolve
    nic"(Sigh‚Ä¶)"
    nic"(This doesn‚Äôt sound like it will be an easy case. It‚Äôs no wonder my boss wanted me to take it over from Janet.)"
    nic"(What makes two people stay together for so long, just to end up resenting each other or even doing stuff behind their partner‚Äôs backs?)"
    nic"(It was interesting to note that Meredith had regrets about not considering the offer her partner had made to her, which was to take a break from each other when the chance was there.)"
    nic"(Could it really have saved their marriage? I guess they‚Äôll never know now.)"
    nic"(And now I‚Äôm starting to wonder if being away from [y_name] for the entire summer will be enough to possibly strengthen or even save our relationship once he returns?)"
    nic"(What if he meets someone else while he‚Äôs away? What if I meet someone else while he‚Äôs gone?)"
    nic"(I‚Äôm sure he wouldn‚Äôt cheat on me, nor would I on him, but what if now is the perfect opportunity for us to both test the waters with somebody else?)"
    nic"(I need to have a long, hard think about this. And maybe get a second opinion‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    jump lb_w2_sow_s_brodie_call







label lb_w2_sow_s_brodie_call:
    # Day 4 (SOW) 08 - Friend at home thinking about her morning with MC"
    # - Brodie calls her and she picks up the phone"
    # SCENE BEGINS"
    # (Friend in the kitchen, wonders where the MC is. His phone is in the kitchen)"
    scene sc w2brodiecall b01
    with dissolve
    show screen scr_rewards("sc w2brodiecall b03b","v_rewards_s_24")
    s"(Hmm... I wonder where [y_name] is?)"
    hide screen scr_rewards
    show sc w2brodiecall b12
    s"(His phone is still in his bedroom, so he couldn‚Äôt have gone too far.)"
    show sc w2brodiecall b01
    s"(Maybe he went for a morning walk. Could he still be thinking about what happened this morning?)"
    show sc w2brodiecall b02
    s"(I‚Äôm sure he didn‚Äôt mean it, and one can‚Äôt control what happens while they‚Äôre asleep.)"
    show sc w2brodiecall b03
    s"(It was pretty funny that he woke up with a bit of ‚Äúmorning glory‚Äù, while he cuddled up next to me.)"
    show sc w2brodiecall b01
    s"(What was all that about?)"
    show sc w2brodiecall b05
    s"(I don‚Äôt recall [y_name] being like this when we were younger.)"
    s"(Then again, we were only kids back then...)"
    show sc day3pool p57
    with flash
    s"(We didn‚Äôt always get on, but there were some good times that we shared.)"
    show sc sairport a17
    with flash
    s"(And seeing him again after so long apart was one of the best feelings I‚Äôve had in such a long time.)"
    show sc day3schat s12
    with flash
    s"(To be fair to [y_name], he‚Äôs been pretty patient with me, even despite all of the problems that I‚Äôve brought him into, ever since he arrived in town.)"
    show sc day3game g67
    with flash
    s"(It‚Äôs only been a few days, but it‚Äôs been really great having him around. I just hope I don‚Äôt give him any reason to want to leave. I have to make sure I don‚Äôt do anything stupid for that to happen.)"
    show sc day3cuddle c26
    with flash
    s"(Why do I keep thinking back to this morning? Is it supposed to mean something more?)"
    s"(No! That‚Äôs ridiculous!)"
    s"(Although, it did feel nice to share a bed with him. I haven‚Äôt had a good night‚Äôs sleep like that in a fair while.)"
    # (Flashback ends, Friend has a dreamy look on her face)"
    show sc w2brodiecall b04
    with flash
    s"(Mmm‚Ä¶ If only every night after I go to sleep could be like that.)"
    play sound "sound effects/01/00/Cell_phone_vibration.mp3" loop fadein 1.0
    "(Phone rings)"
    show sc w2brodiecall b06
    s"Huh?"
    # (Friend picks up her phone, sees Brodie calling)"
    show sc w2brodiecall b13
    s"(Ugh‚Ä¶ He just won‚Äôt give up.)"
    s"(Sigh... I can‚Äôt keep avoiding him forever...)"
    stop sound
    show sc w2brodiecall b06
    s"(Maybe he‚Äôs come to his senses and is calling to apologise.)"
    show sc w2brodiecall b07
    s"(Sigh‚Ä¶)"
    # (Friend answers the phone)"
    show sc w2brodiecall b08
    s"Hello?"
    brod"[s_name]. Thank you so much for answering. I‚Äôve been dying to talk to you."
    show sc w2brodiecall b09
    s"Yeah, I‚Äôve been very busy, but, we do have a lot to discuss."
    show sc w2brodiecall b08
    s"I presume that after all the times that you‚Äôve tried to call me in the past twenty-four hours, there‚Äôs something important you want to tell me?"
    show sc w2brodiecall b11
    brod"Yeah I do."
    show sc w2brodiecall b10
    s"(Great. If we can clear the air now, then we can get back to being a normal couple again.)"
    show sc w2brodiecall b11
    brod"My father wants to give you an open cheque. He said that you can decide how much you want for the hotel."
    show sc w2brodiecall b09
    s"I‚Äôm sorry, are you serious?"
    show sc w2brodiecall b08
    brod"Haha, I knew that you‚Äôd be impressed. Any amount you want, just name your price."
    show sc w2brodiecall b14
    s"Oh, you‚Äôve got to be fucking kidding me!"
    show sc w2brodiecall b15
    brod"What? I thought that this is what you wanted."
    show sc w2brodiecall b14
    s"You really don‚Äôt get it, do you? It‚Äôs not about the money, it never has been."
    s"I‚Äôm not interested in your father‚Äôs money."
    s"The hotel is not for sale! Why can‚Äôt you and your Dad get that through your thick skulls??"
    show sc w2brodiecall b08
    brod"But [s_name], I‚Äôm just trying to look out for you and your best interests. What if things don‚Äôt go the way you hope they will?"
    brod"What if you end up losing the hotel? You‚Äôd wished you took my father‚Äôs offer."
    brod"If you do it now, then at least you‚Äôre guaranteed to end up with something."
    brod"And I can assure you that you won‚Äôt get anywhere near as good a deal as he‚Äôs offering you."
    show sc w2brodiecall b14
    s"I can‚Äôt do this with you anymore Brodie."
    show sc w2brodiecall b08
    brod"Do what?"
    s"All of this back and forth. You not listening to me, or not knowing what I want."
    show sc w2brodiecall b09
    s"I think we need to take a long break from each other."
    show sc w2brodiecall b08
    brod"Wait, are you breaking up with me?"
    s"No, I didn‚Äôt say that."
    s"I just think we should take a break for a while, because if we keep going the way we are, then we‚Äôll end up really resenting each other."
    s"And I don‚Äôt want that."
    s"I‚Äôm so stressed out and you‚Äôre not helping matters for me with all this talk about money and your father‚Äôs offers."
    s"I just need some time and space Brodie."
    brod"I, I understand. So it‚Äôs just a break, rather than a breakup."
    show sc w2brodiecall b09
    s"Yeah, that‚Äôs it. Look, I gotta go, please don‚Äôt call me again."
    s"I‚Äôll call you when, or if I decide that we should give our relationship another try, okay?"
    show sc w2brodiecall b08
    brod"Sure thing [s_name]."
    brod"(Sigh‚Ä¶)"
    brod"And for what it‚Äôs worth, I‚Äôm really sorry for not understanding your needs. I truly am."
    brod"Goodbye [s_name]."
    s"Bye Brodie."
    # (call ends)"
    show sc w2brodiecall b07
    s"(Oh‚Ä¶ He sounded pretty upset right before he hung up. But I think I did the right thing.)"
    s"(Am I seriously considering ending things with Brodie for good though?)"
    show sc w2brodiecall b06
    s"(At least now I don‚Äôt have to be concerned about his father coming to buy the hotel.)"
    s"(And I still have [y_name]‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)









label lb_sow_mc_s_nightout_discussion:
    # Day 4 (SOW) 09 - MC discusses his night out with the Twins with Friend"
    scene sc w2kitchena a01
    with dissolve
    mc"Hey [s_name]."
    # (Friend is agitated)"
    s"Hey [y_name]. Where have you been? Did you go for a swim??"
    mc"Uh, yeah I did."
    s"By yourself?"
    mc"Uh, no, not exactly. Your cousin [c_name] showed up while you were out, and asked me if I wanted to join her for a surf."
    show sc w2kitchena a04
    s"Right... You know, the least you could‚Äôve done was left me a note to let me know where you were."
    show sc w2kitchena a03
    mc"Oh, sorry [s_name]. I honestly didn‚Äôt think I‚Äôd be gone for all that time. Have you been waiting long?"
    show sc w2kitchena a07
    s"About fifteen minutes now. So you were surfing with [c_name] the whole time??"
    show sc w2kitchena a03
    mc"No, we had a long discussion after we came out of the ocean as well. Sorry, I guess I completely lost track of time."
    s"What did you two talk about?"
    mc"I just asked [c_name] more about her life, her studies, and if she was still interested in working with us here at the hotel."
    s"And is she?"
    mc"You know what, I think she is. And I‚Äôve kind of made a deal with her."
    show sc w2kitchena a08
    s"A deal? What deal?"
    mc"The deal is she comes to work and learns the business from us, and she gives me some surfing lessons."
    show sc w2kitchena a01
    mc"What do you think?"
    s"Well she must be a pretty good teacher if you‚Äôre willing to spend some more time with her."
    mc"So you‚Äôre okay with this?"
    show sc w2kitchena a07
    s"F-fine. Just as long as it doesn‚Äôt interfere with the work that we need to do here."
    show sc w2kitchena a04
    s"We‚Äôre going to need [c_name]‚Äôs intellect and knowledge to help us run this hotel, and if it means you spending time with her outside of work, then I guess it‚Äôs okay."
    show sc w2kitchena a03
    mc"(Hmm‚Ä¶ Something seems off with [s_name]. If I didn‚Äôt know any better, I‚Äôd say she was angry with me for spending time with her cousin.)"
    mc"(And maybe even a little bit jealous.)"
    # (scene continues)"
    show sc w2kitchena a01
    mc"Is everything okay with you [s_name]? Did I do something wrong?"
    show sc w2kitchena a06
    s"(Sigh‚Ä¶)"
    s"No, it‚Äôs not you [y_name]. I um, I just spoke with Brodie."
    mc"Oh, you did?"
    show sc w2kitchena a04
    s"Yeah, he called me while you were down at the beach."
    show sc w2kitchena a03
    s"Actually, he‚Äôs tried calling me several times since the other night, but I felt the need to answer my phone when he called this time."
    mc"Okay. So what did he want?"
    show sc w2kitchena a04
    s"At first I thought he was calling to apologise, and I believed for the sake of our relationship, it was only right that I give him that chance."
    s"I mean, we‚Äôve been together for a few years now, and I didn‚Äôt want to throw things away with Brodie so easily."
    show sc w2kitchena a03
    s"Do you know what I mean?"
    mc"Yeah, of course I do."
    show sc w2kitchena a01
    mc"As you know, me and Nicole have been together for almost five years, and that‚Äôs a lot of memories and great times to give up over one silly argument."
    mc"So, did he apologise?"
    show sc w2kitchena a06
    s"No, no he didn‚Äôt. He called to let me know that his father has offered me an open cheque, to name my price for this hotel."
    mc"Oh geez, he didn‚Äôt!"
    show sc w2kitchena a07
    s"Yeah, he most certainly did."
    show sc w2kitchena a03
    mc"(So that‚Äôs why she looked upset. How stupid is this Brodie guy??)"
    mc"I‚Äôm really sorry to hear that [s_name]."
    mc"So did you give it to him this time, and tell him to stick his Dad‚Äôs cheque where the sun don‚Äôt shine?"
    show sc w2kitchena a04
    s"Not in those exact words, no. However, I told Brodie that I thought we should take a break."
    show sc w2kitchena a06
    mc"A break? You mean, a break from seeing each other?"
    s"Yeah. I didn‚Äôt know what else to do. He was driving me crazy with all this talk about money, my hotel, and my future."
    s"I just couldn‚Äôt take it anymore. It was stressing me out big time and I just needed to be free from all of it."
    show sc w2kitchena a03
    s"Do you think I did the right thing?"
    # [You sure did / It‚Äôs hard to say]"
    menu:
        "You sure did"(wt="Best choice"):
            #+2 FRIEND POINTS"
            $ s_points = change_stat(s_points,2,s_name)
            show sc w2kitchena a01
            mc"You certainly did. It‚Äôs obvious that it‚Äôs been on your mind a lot."
            mc"If you know that choosing to do this will make things easier for both of you for the time being, then it certainly seems like you did the right thing."
            mc"And who knows? Perhaps you two could end up better off from the time apart?"
            show sc w2kitchena a08
            s"Is that what Nicole said to you when you decided to come down here to help me?"
            show sc w2kitchena a01
            mc"Uh, yeah she did. How did you know?"
            s"I kind of put two and two together from that little speech of yours."
            s"But you and Nicole have never decided to take a break from each after all that time you two have been together though, right?"
            mc"No, never. I mean things have been pretty stressful over the past six months, we‚Äôve had the odd argument as most couples do."
            mc"But there‚Äôs never been any kind of sign that she‚Äôs wanted to take a break in our relationship. And I‚Äôve never once considered it either."
            mc"However, it‚Äôs completely different for everyone."
        "It‚Äôs hard to say":
            show sc w2kitchena a01
            mc"Hmm‚Ä¶ It‚Äôs hard to for me to say, as I‚Äôve never been in a position like this before."
            show sc w2kitchena a03
            s"But you and Nicole are kind of on a break as well, aren‚Äôt you?"
            mc"Well I wouldn‚Äôt call it a break exactly."
            show sc w2kitchena a01
            mc"Nicole never called it that, although she did say that our relationship could end up being better off if we're apart for the entire summer."
            show sc w2kitchena a07
            s"Do you really believe that?"
            show sc w2kitchena a01
            mc"Yeah I do, somewhat."
            mc"I mean things have been pretty stressful over the past six months, we‚Äôve had the odd argument as most couples do."
            mc"But there‚Äôs never been any kind of sign that she‚Äôs wanted to take a break in our relationship. And I‚Äôve never once considered it either."
            mc"However, it‚Äôs completely different for everyone."
            # (scene continues)"
    show sc w2kitchena a02
    s"Yeah, I guess you‚Äôre right."
    show sc w2kitchena a01
    mc"Are you going to be okay?"
    show sc w2kitchena a06
    s"I think so. Look, I just want to get back to work. I need to keep occupied and maybe even distracted."
    mc"Sounds like a good idea."
    show sc w2kitchena a10
    s"Thanks for understanding and for listening [y_name]."
    show sc w2kitchena a13
    s"At least I know I can rely on you for both of those things."
    # (Friend places her hand upon the MC‚Äôs)"
    mc"Sure, any time."
    mc"([s_name] seems to have forgotten all about what happened this morning. Maybe I should as well.)"
    show sc w2kitchena a11
    mc"So, what jobs did you have for me to do today?"
    show sc w2kitchena a10
    s"Before we get to that, I need you to get a few things from the store for me."
    mc"Uh, okay. What do you need?"
    show sc w2kitchena a11
    s"Well, I have list of things that I've written down. Victoria suggested that we need to get a new set of knives for the main kitchen, correct?"
    mc"Yeah she did. So you need me to get them?"
    show sc w2kitchena a10
    s"That‚Äôs one thing. Also some squeeze bottles, and a few other things that need replacing in the kitchen."
    show sc w2kitchena a11
    s"Would that be okay?"
    mc"Sure, whatever you need me to do [s_name]. So what are you going to do while I‚Äôm about?"
    show sc w2kitchena a10
    s"I just spoke with Jazmin, and as she was about to check out, she asked if she could take a look inside the health centre."
    mc"Oh, how come?"
    s"She‚Äôd like to offer her thoughts and opinions on the room..."
    s"And to give me some ideas for what improvements can be made in order to draw more people to the centre."
    s"And that includes people who aren‚Äôt staying at the hotel."
    show sc w2kitchena a11
    mc"That‚Äôs nice of her. So does she know where she‚Äôs going to stay tonight?"
    s"I feel kind of bad for asking her to leave, especially after what happened yesterday, and now offering to help me with the health centre. So I said she could stay for a few more nights."
    mc"I guess that makes sense."
    mc"Okay, well I‚Äôm going to quickly take a shower, get changed, and I‚Äôll go and get these things for you."
    show sc w2kitchena a10
    s"I‚Äôll leave the list next to your bedside table."
    mc"Thanks."
    show sc w2kitchena a12
    s"Maybe when you get back we can discuss what we could do for dinner tonight?"
    show sc w2kitchena a10
    s"Maybe not a board game this time. "
    mc"(Oh shit! We‚Äôre meant to do something with Ivy and Lily this evening. Dammit, I better mention this to [s_name].)"
    show sc w2kitchena a11
    mc"[s_name], there‚Äôs something I forgot to tell you. Lily and Ivy invited us to some fancy event tonight."
    show sc w2kitchena a12
    s"Oh, well that‚Äôs cool. I can go with you to see them instead."
    show sc w2kitchena a11
    s"Did you already agree for us to join them for it?"
    if v_day3_twins_imin is None:
        scene main_screen_alpha
        menu:
            "Your saved game needs to be upgraded. Did [y_name] agree to go to dinner with Ivy and Lily without asking [s_name] first?"
            "Yes":
                $ v_day3_twins_imin = True
            "No":
                $ v_day3_twins_imin = False
        scene sc w2kitchena a11
    if v_day3_twins_imin:
        mc"Yeah, I did."
        mc"I‚Äôm sorry, Lily kind of put on the spot and I figured that this would be the ideal opportunity for me to get to know both of them, outside of work."
        mc"But we don‚Äôt have to go if you don‚Äôt want to."
        show sc w2kitchena a17
        s"(Hmm‚Ä¶ I wonder why Lily would ask [y_name] and not mention this to me.)"
        s"(Maybe they‚Äôre using the same approach that they normally do when they take on new clients.)"
        show sc w2kitchena a16
        s"(I know Ivy and Lily can be quite forward with people, especially males.)"
        s"(So I can‚Äôt blame [y_name] for accepting their invitation already.)"
        show sc w2kitchena a17
        s"(Well, at least they can‚Äôt full-on hit on him, especially because they know that he has a girlfriend. However, that hasn't stopped them before.)"
        show sc w2kitchena a10
        s"No, I think we should still go [y_name]."
        mc"Are you sure?"
        s"Yeah, I‚Äôm positive."
        s"They obviously have some important details to go over with you and at the same time, they will be looking to learn as much about you as they can."
        s"It‚Äôs a trust thing with Ivy and Lily you see."
        show sc w2kitchena a12
        s"They‚Äôll definitely show you a fun night out [y_name], that I can assure you of."
        show sc w2kitchena a10
        mc"All right, if you say so."
        mc"(Hmm‚Ä¶ I wonder what exactly she means by a ‚Äúfun night out‚Äù?)"
    else:
        mc"I haven‚Äôt given them an answer yet, as I wanted to talk to you about it first."
        mc"I wanted to make sure that you‚Äôd be okay with it."
        mc"But we don‚Äôt have to go if you don't want to."
        show sc w2kitchena a17
        s"(Hmm‚Ä¶ I wonder why Lily would ask [y_name] and not mention this to me.)"
        s"(Maybe they‚Äôre using the same approach that they normally do when they take on new clients.)"
        show sc w2kitchena a16
        s"(I know Ivy and Lily can be quite forward with people, especially males.)"
        s"(So I'm actually pretty impressed that [y_name] hasn't accepted their invitation already.)"
        show sc w2kitchena a17
        s"(Well, at least they can‚Äôt full-on hit on him, especially because they know that he has a girlfriend.)"
        show sc w2kitchena a10
        $ s_points = change_stat(s_points,2,s_name)
        s"No, I think we should still go [y_name]." #+2 FRIEND POINTS"
        mc"Are you sure?"
        s"Yeah, I‚Äôm positive."
        s"They obviously have some important details to go over with you and at the same time, they will be looking to learn as much about you as they can."
        s"It‚Äôs a trust thing with Ivy and Lily you see."
        show sc w2kitchena a12
        s"They‚Äôll definitely show you a fun night out [y_name], that I can assure you of."
        show sc w2kitchena a10
        mc"All right, if you say so. I‚Äôll send Lily a text message shortly to let her know that we‚Äôll be joining them tonight."
        mc"(Hmm‚Ä¶ I wonder what exactly she means by a ‚Äúfun night out‚Äù?)"
    # (scene continues)"
    show sc w2kitchena a11
    s"Okay, you have your tasks for the day."
    show sc w2kitchena a10
    s"No need to hurry back [y_name], feel free to take your time."
    s"And call me if you need anything, okay?"
    mc"Yes, I promise I will."
    # (Friend hugs the MC, kisses him on the cheek)"
    show sc w2kitchena a13
    s"Mmm‚Ä¶ You smell like the beach."
    show sc w2kitchena a12
    s"You might want to do something about that before you go shopping."
    mc"Haha, I‚Äôm off to take a shower right now!"
    scene black
    with dissolve
    scene black
    with Pause (2)



label lb_w2_sow_mc_errand:
    # Day 4 (SOW) 10 - MC runs an errand for friend"
    scene sc w2vickyknife k01
    with dissolve
    play ambient "sound effects/02/01/Calm_Department_Store_Ambience.mp3" loop fadein 1.0
    mc"(Oh dammit! I don‚Äôt even know what the hell I‚Äôm looking for!)"
    # (Vicky interrupts the MC, sticking her hand out to suggest a specific knife for him)"
    # (We don‚Äôt see her face, just her hand and arm pointing at one of the knives)"
    show sc w2vickyknife k02
    "Want to hear a quality joke about knives?"
    mc"Huh?"
    show sc w2vickyknife k07
    vic"On second thoughts, maybe you shouldn‚Äôt hear it. It could be too edgy for you."
    # (MC turns and sees Victoria)"
    show sc w2vickyknife k04
    mc"Oh, hey Vicky! Fancy seeing you here!"
    show sc w2vickyknife k05
    mc"Horrible joke by the way."
    show sc w2vickyknife k10
    vic"Yeah, I really need to work on my surprise introductions."
    # [Do nothing / Shake her hand / Kiss her on the cheek]"
    show sc w2vickyknife k04
    menu:
        "Do nothing":
            $ vic_points = change_stat(vic_points,-1,"Victoria")
            show sc w2vickyknife k05
            #‚Äù -1 VICKY POINTS"
        "Shake her hand":
            show sc w2vickyknife k33
            vic"(Hmm‚Ä¶ Are we still at shaking hands?)"
            # (MC shakes her hand)  0 POINTS LOSS"
            # (scene continues below)"

        "Kiss her on the cheek"(wt="Best choice"):
            $ vic_points = change_stat(vic_points,2,"Victoria")
            show sc w2vickyknife k32
            # (MC kisses her on the cheek)  +2 VICKY POINTS"
            # (scene continues)"
            play sound "sound effects/01/02/Male_kissing_girl_on_the_cheek.mp3"
            mc"Mwah!"
            stop sound
    show sc w2vickyknife k05
    mc"So what are you doing here?"
    show sc w2vickyknife k04
    vic"I needed a few things for the food truck, mainly some more plastic cutlery and serviettes, as my stocks were running low."
    vic"I have someone watching the truck for me while I‚Äôm away from it."
    show sc w2vickyknife k05
    mc"That‚Äôs nice. You must love being able to get out of there when you can, huh?"
    show sc w2vickyknife k07
    vic"Oh yeah, for sure."
    show sc w2vickyknife k10
    vic"Let me guess, you‚Äôre here looking for a new set of knives and a few other things for the hotel kitchen after our discussion yesterday?"
    show sc w2vickyknife k05
    mc"Yes, exactly. I‚Äôm just having a little trouble deciphering between the differing knives sets."
    show sc w2vickyknife k04
    vic"It can be a little intimidating for someone who hasn‚Äôt worked much in kitchens. I probably should have made a few suggestions for you."
    show sc w2vickyknife k05
    vic"Did [s_name] have a set in mind for the kitchen?"
    mc"No, she didn‚Äôt. She just gave me some money and asked me to get some things on a list she wrote up for me."
    vic"Let me take a look at that if I may?"
    # (MC hands her the list, and she looks it over)"
    show sc w2vickyknife k12
    vic"I see. Okay, she‚Äôs put the squeeze bottles on there I see. They‚Äôre in aisle three, so make sure to pick up a few of them."
    show sc w2vickyknife k11
    vic"As for your knives set, I‚Äôd recommend the Mercenary Culmination Genesis six-piece, forged knife block set."
    show sc w2vickyknife k05
    mc"What‚Äôs so great about it?"
    show sc w2vickyknife k07
    vic"I‚Äôm glad that you asked!"
    show sc w2vickyknife k04
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2vickyknife k04","sc w2vickyknife k04x","v_pt_image_index_w2_08")
    vic"Aside from having a lifetime warranty, it has an ergonomic Santoprene handle that offers superior comfort and a non-slip grip, even with wet hands."
    vic"These knives will also not break down from exposure to kitchen oils and they are able to withstand hot and cold temperatures."
    mc"You sure know your knives, I better watch out!"
    hide screen scr_peeping_tom
    show sc w2vickyknife k07
    vic"Haha! And another great thing about these knives is that they resist rust, corrosion, and discolouration."
    show sc w2vickyknife k04
    vic"It‚Äôs great that [s_name] gave you more than enough money for these. She obviously wants top quality."
    mc"I suspect so."
    show sc w2vickyknife k17
    vic"Anyways, I really should get going. I just thought I‚Äôd say hi when I saw you in here."
    show sc w2vickyknife k17
    mc"I‚Äôm really happy that you did. Bye Vicky."
    show sc w2vickyknife k18
    vic"Have a great day [y_name], I‚Äôll talk to you soon."
    # (MC goes to walk away)"
    show sc w2vickyknife k19
    vic"Actually, one last thing."
    mc"Yes Vicky?"
    show sc w2vickyknife k21
    vic"I was wondering if you still wanted to hang out sometime?"
    mc"Oh, sure. Um, what did you have in mind?"
    show sc w2vickyknife k20
    vic"Well, I have some free tickets to a show in town."
    vic"A friend of mine who works at the venue supplied me with them, because I did some of their catering and helped promote their shows through my food truck."
    mc"Wow, that‚Äôs pretty cool."
    mc"(I wonder what kind of show it will be? Hmm‚Ä¶ It‚Äôs best not to ask, and let it be a surprise on the night.)"
    show sc w2vickyknife k21
    vic"So, are you interested?"
    # [I still am / I‚Äôd love to]"
    menu:
        "I still am":
            show sc w2vickyknife k21
            mc"Yes, I still am. It sounds like it could be a fun night out."
        "I‚Äôd love to"(wt="Best choice"):
            $ vic_points = change_stat(vic_points,2,"Victoria")
            show sc w2vickyknife k21
            mc"Oh, right. Yes, I am. I‚Äôd love to join you for that." #+2 VICKY PTS"
    # (scene continues)"
    show sc w2vickyknife k22
    vic"Awesome!"
    show sc w2vickyknife k20
    mc"So what night were you thinking of going?"
    show sc w2vickyknife k21
    vic"Oh, well I‚Äôm busy tonight and tomorrow night, but maybe sometime midweek we could go to this show together?"
    mc"Yeah, I‚Äôm sure I can make myself available for just about any night."
    show sc w2vickyknife k22
    vic"And we‚Äôre going just as friends though, right?"
    show sc w2vickyknife k21
    mc"Yes, just as friends."
    show sc w2vickyknife k17
    vic"Okay great. I‚Äôll message you in the week to see if and when you‚Äôre available."
    mc"I‚Äôll keep an eye out for your text!"
    # (scene continues)"
    vic"Bye [y_name]."
    # (after Victoria leaves)"
    show sc w2vickyknife k02
    mc"(I‚Äôll have to try and make myself available for when she contacts me.)"
    mc"(I wonder what [s_name] will think when or if I tell her that I‚Äôll be doing something with Vicky.)"
    mc"(She did tell me to hang out with people in town who I‚Äôm either going to be working with or that are willing to help us at the hotel.)"
    mc"(And Vicky perfectly fits that description.)"
    show sc w2vickyknife k01
    mc"(Anyways, I better get these things for [s_name], and then get out of here.)"
    stop ambient fadeout 1.0
    # (screen goes blank)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    show sc w2vickyknife k13
    with dissolve
    # (MC outside the kitchenware store with the things her purchased, maybe he‚Äôs carrying to huge bags)"
    play ambient "sound effects/02/01/small_town_sounds.mp3" loop fadein 1.0
    mc"(Damn, all of this stuff that [s_name] asked me to get for the hotel is a lot heavier than I thought it would be.)"
    # ‚ÄúIf the player went shopping with Ashley the day before‚Äù"
    if v_day3_ashley_clothing_store:
        show sc w2vickyknife k14
        mc"(Hmm‚Ä¶ I sure could have done with that scooter [s_name] has back at the hotel.)"
        mc"(A scooter? Wait. Ashley said she had one that I could borrow while I‚Äôm staying in town.)"
        mc"(The problem with that is, I still don‚Äôt know how to ride one. But perhaps I could get Ashley to show me the basics.)"
        mc"(I mean, how hard could it be? It‚Äôd be easier than driving a car I presume.)"
        show sc w2vickyknife k15
        mc"(I wonder if she‚Äôs home? If she is, I could get it from her now.)"
        mc"(Oh! She also promised me that she would answer all of my questions about what happened, when she and [s_name] moved out of our home nine years ago.)"
        mc"(Okay, I‚Äôm not going to deliberate with this any longer. Hopefully, when I call Ashley she answers.)"
        play sound "sound effects/01/01/Phone_call_sound_effect.mp3" loop fadein 1.0
        show sc w2vickyknife k31
        "..."
        stop sound
        show sc w2vickyknife k28
        ash"Hello?"
        mc"Uh, Ashley?"
        show sc w2vickyknife k30
        ash"Hello [y_name]. I‚Äôve been expecting your call."
        show sc w2vickyknife k27
        mc"You have?"
        show sc w2vickyknife k30
        ash"Of course!"
        show sc w2vickyknife k27
        ash"I mean we did agree to meet at my place today, and you need to come and get that scooter that I said you could borrow, remember?"
        mc"Um, yeah you did."
        mc"(I think it will be better to ask her to show me how to ride it when I get there.)"
        show sc w2vickyknife k28
        ash"So when shall I expect you?"
        mc"I‚Äôm at the mall now, so I can be there in fifteen minutes."
        show sc w2vickyknife k27
        ash"I look forward to seeing you. Just let yourself in, I‚Äôll leave the front door unlocked."
        mc"Oh, sure thing."
        show sc w2vickyknife k30
        ash"Bye [y_name], see you soon."
        show sc w2vickyknife k27
        mc"Bye Ashley."
        # (call ends)"
        show sc w2vickyknife k15
        mc"(Sigh‚Ä¶ Okay, time to get some answers from Ashley that I‚Äôve been dying to find out for such a long time now.)"
        stop ambient fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
        jump lb_w2_sow_ashley_house
    else:
        # ‚ÄúIf the player went shopping with Yuki the day before‚Äù"
        play ambient "sound effects/02/01/small_town_sounds.mp3" loop fadein 1.0
        show sc w2vickyknife k15
        mc"(Hmm‚Ä¶ I sure could have done with that scooter [s_name] has back at the hotel.)"
        mc"(A scooter? Wait! Yuki said she had one for me that I could borrow while I‚Äôm staying in town.)"
        mc"(The problem with that is, I still don‚Äôt know how to ride one. But perhaps I could get Yuki to show me the basics.)"
        mc"(I mean, how hard could it be? It‚Äôd be easier than driving a car I presume.)"
        mc"(I wonder if she‚Äôs home? If she is, I could get it from her now.)"
        show sc w2vickyknife k31
        play sound "sound effects/01/01/Phone_call_sound_effect.mp3" loop fadein 1.0
        "..."
        stop sound
        show sc w2vickyknife k23
        yuki"Hello?"
        mc"Uh, Yuki?"
        show sc w2vickyknife k26
        yuki"Oh [y_name], it‚Äôs great to hear from you!"
        show sc w2vickyknife k23
        mc"You too. So I was wondering if I could take you up on your offer?"
        mc"The one about the spare scooter that you said that you have."
        show sc w2vickyknife k24
        yuki"Oh, I‚Äôd really love to help you out [y_name], but I was just about to head out. And I‚Äôll be out all day."
        mc"No problems, I thought I‚Äôd give you a call because I was in town."
        show sc w2vickyknife k25
        yuki"How about I ring you back or send you a message to let you know of a time that will better suit?"
        mc"Sure, that‚Äôd be great."
        show sc w2vickyknife k26
        yuki"Oh and [y_name]..."
        yuki"Try and allow for some extra free time when you do come over to my place, as there‚Äôs something I really want to show you."
        show sc w2vickyknife k25
        mc"Oh, okay."
        mc"(I wonder what it could be?)"
        yuki"Bye [y_name], I‚Äôll be in touch."
        mc"I look forward to hearing from you. Bye Yuki."
        # (call ends)"
        show sc w2vickyknife k15
        mc"(I forgot to ask Yuki if she has time to show me how to ride that scooter, but it‚Äôs probably better for me to ask her when I go over to her place.)"
        mc"(All right, well I best head back to the hotel so I don‚Äôt keep [s_name] waiting.)"
        stop ambient fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
        jump lb_w2_sow_jazmin_room












label lb_w2_sow_ashley_house:
    # Day 4 (SOW) 11 - MC visits Ashley's house"
    # SCENE BEGINS"
    # (MC at Ashley‚Äôs front door)"
    $ v_w2_ashley_house = True
    scene sc w2ashleyhouse a01
    with dissolve
    mc"(Well, here I am again, and Ashley said I could let myself in this time.)"
    # (MC opens the front door, and walks through)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2ashleyhouse a02
    with dissolve
    show screen scr_rewards("sc w2ashleyhouse a02b","v_rewards_ashley_22")
    mc"(Okay, where is she?)"
    mc"Hello?"
    mc"(It‚Äôs quiet. A little too quiet.)"
    mc"Is anybody here?"
    # (Ashley shouts from the bathroom)"
    ash"OH!! DAMMIT!"
    mc"ASHLEY? IS THAT YOU??"
    # (Ashley shouts from the bathroom)"
    ash"I‚ÄôM IN THE BATHROOM [y_name!u]! I COULD REALLY DO WITH YOUR HELP!"
    mc"(Ahh crap! I hope she hasn‚Äôt slipped and fallen over in the shower. I better go and investigate‚Ä¶)"
    hide screen scr_rewards
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (scene starts with the sound of dripping water, coming from the shower head)"
    # (Ashley stands in the shower, trying to fix the taps)"
    # (She wears a white tank top and shorts)"
    scene sc w2ashleyhouse a03
    with dissolve
    mc"Uh, Ashley?"
    ash"Oh, hey [y_name]."
    show sc w2ashleyhouse a05
    mc"What‚Äôs going on?"
    show sc w2ashleyhouse a06
    ash"Sorry, I didn‚Äôt mean to worry you, it‚Äôs just that my shower head has been playing up all morning."
    show sc w2ashleyhouse a08
    ash"It‚Äôs been dripping all night, and when I do have it turned on, there‚Äôs not as much water coming out of it."
    mc"Hmm, that‚Äôs very unusual."
    show sc w2ashleyhouse a09
    ash"Yeah, it‚Äôs been driving me crazy, so I was in here trying to fix it."
    show sc w2ashleyhouse a10
    ash"Do you know anything about this kind of thing?"
    show sc w2ashleyhouse a08
    mc"Yeah I‚Äôve had this issue before."
    show sc w2ashleyhouse a12
    mc"Here, let me take a look at it and see if I can remember how I fixed my shower head."
    # MINI-GAME HERE"
    show sc w2ashleyhouse a31
    # (Ashley steps out of the shower and the MC steps inside it)"
    mc"I see that you have a tool kit here and some towels which I can place over the drain. So that‚Äôs a good start."
    show sc w2ashleyhouse a19
    mc"But what we‚Äôll need to do first is to turn off the water main to the house."
    show sc w2ashleyhouse a22
    mc"You know where that is, right?"
    show sc w2ashleyhouse a23
    ash"Yeah, I think I do. Hang on, I‚Äôll just go and shut it off."
    show sc w2ashleyhouse a18
    mc"Okay, great. Call out when you‚Äôve done that."
    # (Ashley leaves the bathroom)"
    show sc w2ashleyhouse a15
    mc"(Okay, so from memory I have to remove the shower head from the pipe with my hands or use the wrench if it‚Äôs too tight.)"
    # (Ashley shouts from the other room)"
    show sc w2ashleyhouse a19
    ash"I‚ÄôVE TURNED THE WATER OFF [y_name!u]!"
    show sc w2ashleyhouse a30
    mc"THANK YOU!"
    show sc w2ashleyhouse a29
    mc"(Okay, hopefully this comes off easy.)"
    menu:
        "Unscrew the shower head":
            # (Shower head comes off)"
            show sc w2ashleyhouse a17
            mc"(And I‚Äôm off and running.)"
    show sc w2ashleyhouse a32
    show screen scr_rewards("sc w2ashleyhouse a32b","v_rewards_ashley_24")
    mc"(Now, what am I meant to be looking for here?)"
    # (Ashley returns)"
    hide screen scr_rewards
    show sc w2ashleyhouse a35
    ash"I see that you‚Äôve got the shower head off already. Found anything yet?"
    # [Use a tool / O-shape / Give up]"
    show sc w2ashleyhouse a32
    menu:
        "Use a tool":
            show sc w2ashleyhouse a33
            mc"(I think I used a crescent wrench that last time I did this.)"
            mc"(But was that before, or after I removed the shower head?)"
            show sc w2ashleyhouse a36
            mc"No, nothing as yet. But I‚Äôll keep looking."
            # (GO DOWN TO STEP 2)"
            jump lb_w2_sow_ashley_house_step2
        "O-shape"(wt="Best choice"):
            $ v_w2_ashley_step1 = True
            show sc w2ashleyhouse a33
            mc"(Okay, there should be a small plastic washer or a rubber O-shaped ring.)"
            show sc w2ashleyhouse a34
            mc"(Bingo, this is it.)"
            # (MC holds it in between tow fingers)"
            show sc w2ashleyhouse a15
            mc"(Hmm‚Ä¶ It does look as though it needs replacing.)"
            show sc w2ashleyhouse a19
            mc"The washers look pretty worn out, so I‚Äôm going to need to change them with new ones."
            show sc w2ashleyhouse a18
            mc"Fortunately, you have some replacement ones here that are ready to go."
            show sc w2ashleyhouse a24
            ash"Well that was lucky!"
            show sc w2ashleyhouse a23
            mc"Yeah, it sure was."
            # (GO DOWN TO STEP 2)"
            jump lb_w2_sow_ashley_house_step2
        "Give up":
            # (GO DOWN TO > GIVE UP)"
            jump lb_w2_sow_ashley_house_giveup



label lb_w2_sow_ashley_house_step2:
    show sc w2ashleyhouse a22
    ash"So what are you meant to do next?"
    mc"Uh, so from memory, I‚Äôm supposed to clean the shower head."
    mc"I‚Äôm pretty sure that when there‚Äôs a decreased flow of water, then it‚Äôs recommended to give it a good clean."
    show sc w2ashleyhouse a26
    ash"I guess a lot of dirt or sediment end up inside the shower head over time, right?"
    show sc w2ashleyhouse a18
    mc"Precisely!"
    # [Inspect it]"
    # (MC looks closely at it)"
    show sc w2ashleyhouse a15
    mc"(Hmm‚Ä¶ It looks pretty clean. Maybe I should ask Ashley when this was last looked at.)"
    show sc w2ashleyhouse a22
    mc"Hey Ashley, when was the last time someone looked at this or installed it?"
    ash"Uh, maybe a few months ago. It was a friend of mine who said he knew all about shower heads."
    ash"How come?"
    mc"Well, the inside of the shower head looks pretty clean."
    mc"Normally any dirt or grime would be noticeable, but there‚Äôs none that I can see here."
    mc"So I think I‚Äôm okay to continue."
    show sc w2ashleyhouse a23
    ash"If you think that‚Äôs best, then please."
    mc"(Hopefully I haven‚Äôt missed anything.)"
    show sc w2ashleyhouse a15
    mc"(All right, what‚Äôs next?)"
    # [Tape it up / Don‚Äôt use tape / Give up]"
    menu:
        "Tape it up"(wt="Best choice"):
            $ v_w2_ashley_step2 = True
            show sc w2ashleyhouse a33
            mc"So before I reattach the shower head, I just have to tape the threads onto the pipe stem with some Teflon tape."
            # (MC does this) "
            # (Tape goes over the pipe stem)"
            show sc w2ashleyhouse a34
            mc"There, that looks pretty good."
            jump lb_w2_sow_ashley_house_step3
            # (GO DOWN TO STEP 3)"
        "Don‚Äôt use tape":
            show sc w2ashleyhouse a34
            mc"Okay, I think this looks just about ready to go now. It just need to be screwed back in."
            # (GO DOWN TO STEP 3)"
            jump lb_w2_sow_ashley_house_step3
        "Give up":
            # (GO DOWN TO > GIVE UP)"
            jump lb_w2_sow_ashley_house_giveup

label lb_w2_sow_ashley_house_step3:
    show sc w2ashleyhouse a17
    mc"I should be able to screw the shower head back on, and I‚Äôll have to make sure it‚Äôs on pretty tight."
    show sc w2ashleyhouse a28
    ash"It sounds like you know what you‚Äôre doing there [y_name]."
    show sc w2ashleyhouse a18
    mc"Haha, I sure hope so, otherwise I‚Äôm going to look pretty stupid if this doesn‚Äôt end up working!"
    show sc w2ashleyhouse a24
    play sound "sound effects/01/02/female_laughing_giggling.mp3"
    ash"Hahaha!"
    stop sound
    # [Tighten almost all the way / Tighten all the way]"
    show sc w2ashleyhouse a15
    menu:
        "Tighten almost all the way":
            show sc w2ashleyhouse a29
            mc"(I‚Äôll tighten it, but I should leave it a little loose so it‚Äôs simple enough to unscrew for the next person.)"
            # (MC hand tightens it)"
        "Tighten all the way"(wt="Best choice"):
            $ v_w2_ashley_step3 = True
            show sc w2ashleyhouse a29
            mc"(It will need to be tightened until l can‚Äôt turn it anymore. And then I should use the pliers to give it one final slow turn.)"
            # (MC hand tightens it)"
            # [Use the pliers]"
            # (MC uses the pliers to tighten the shower head on)"
            # (scene continues)"
    show sc w2ashleyhouse a22
    mc"All right, it should be good to go."
