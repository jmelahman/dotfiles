label lb_w2_sow_twins_dinner:
    # Day 4 (SOW) 14 - MC and Friend meet the Twins for dinner and drinks"
    # - Opening event, Wedding Pre Party"
    # - add these lines/scenes, ONLY if the player went to Ashley‚Äôs house that afternoon"
    # - add these lines/scenes, ONLY if the player is on the Yuki path and left a message on her answering service right before this scene"
    # SCENE BEGINS"
    # (MC and friend arrive at the hotel, they sit in the foyer/lounge waiting area, waiting for Ivy)"
    scene sc w2twinsdate t03
    with dissolve
    play ambient "sound effects/02/01/People_Talking_in_Background_Ambience.mp3" loop fadein 1.0
    mc"This looks like a pretty swanky hotel."
    show sc w2twinsdate t03
    s"Yeah, I know for a fact that they‚Äôve grown in popularity in recent years, and are renowned for the huge functions that they host."
    # (Ivy and Lily greets them)"
    show sc w2twinsdate t12
    ivy"Hey guys, so glad you two could make it!"
    show sc w2twinsdate t11
    s"Thanks for inviting us ladies."
    show sc w2twinsdate t29
    lily"Oh wow, you look amazing [s_name]! Look at your dress!"
    show sc w2twinsdate t11
    s"Oh, why thank you Lily!"
    # (Friend and Lily hug)"
    # (Ivy turns to the MC)"
    show sc w2twinsdate t16
    ivy"And look at this strapping young man! Looking good there [y_name]."
    mc"Thanks. I‚Äôm just relieved to hear you say that Ivy."
    show sc w2twinsdate t14
    mc"We weren‚Äôt sure if we‚Äôd be overdressed for the occasion you see."
    show sc w2twinsdate t17
    ivy"Oh trust me, you two will fit right in."
    show sc w2twinsdate t12
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2twinsdate t12","sc w2twinsdate t12x","v_pt_image_index_w2_19")
    ivy"Follow me and Lily this way to where all the action is!"
    hide screen scr_peeping_tom
    # (MC and friend follow behind Ivy into the function room)"
    # (screen goes blank)"
    # (MC and friend enter the events room with the twins. They‚Äôre at a pre-wedding party which has been decorated for the numerous guests)"
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2twinsdate t40
    with dissolve
    play ambient "sound effects/02/01/People_Talking_in_Background_Ambience.mp3" loop fadein 1.0
    lily"So what do you think guys? "
    show sc w2twinsdate t39
    s"It looks amazing ladies! So you two created all of this?"
    show sc w2twinsdate t52
    lily"Yeah, pretty much. Pretty sweet. huh?"
    show sc w2twinsdate t36
    s"Yeah, you two have made this place an absolute dream!"
    show sc w2twinsdate t40
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2twinsdate t40","sc w2twinsdate t40x","v_pt_image_index_w2_20")
    mc"Ivy, is this a wedding party function?"
    ivy"Kind of, yeah. It‚Äôs actually a pre-wedding party to be more precise. "
    ivy"The couple who are getting married are from out of town."
    ivy"And their guests have flown in or driven here to Sunshine Bay for the wedding, which will take place this weekend."
    mc"It sounds like this wedding is a pretty big deal."
    hide screen scr_peeping_tom
    show sc w2twinsdate t52
    lily"It sure is."
    show sc w2twinsdate t57
    lily"No one is meant to know this, but, one half of the happy couple is a celebrity singer, and she wanted the wedding to be kept private."
    show sc w2twinsdate t46
    ivy"So we‚Äôve had to keep pretty tight-lipped about it ever since we gained the right to do the hosting and planning here at the hotel."
    show sc w2twinsdate t38
    s"So why exactly did you invite me and [y_name] here tonight?"
    show sc w2twinsdate t43
    ivy"We wanted to give you both an idea of how we host our events, the work that goes into the planning, and the feedback that we get from the attendees."
    show sc w2twinsdate t52
    lily"By the end of the night, we‚Äôre hoping it will inspire you both to host a similar kind of event at your own hotel in the near future."
    show sc w2twinsdate t31
    s"We‚Äôd like that very much, wouldn‚Äôt we [y_name]?"
    show sc w2twinsdate t36
    mc"Yes, most certainly."
    show sc w2twinsdate t41
    mc"And if it looks anything like what you‚Äôve done with this pre-wedding party, then we‚Äôre sure to be on a good thing."
    show sc w2twinsdate t40
    lily"Thank you [y_name]. My sister and I take a lot of pride in our work and we only want the best for our clients."
    show sc w2twinsdate t49
    ivy"But we also know how to have a good time while we‚Äôre here as well."
    # (Ivy downs a drink she‚Äôs holding)"
    show sc w2twinsdate t43
    ivy"Hmm‚Ä¶ I could do with a drink."
    show sc w2twinsdate t55
    lily"Before you do that sis, we have that thing to take care of first, remember?"
    show sc w2twinsdate t47
    ivy"Oh right, I almost forgot."
    show sc w2twinsdate t40
    ivy"Excuse us guys. Lily and I will be back before you know it."
    ivy"But while we‚Äôre gone, why don‚Äôt you find yourselves a table and get something to eat and drink."
    ivy"The drinks are on the house and we‚Äôve let the happy couple know that you‚Äôre here."
    ivy"They were more than happy to accommodate you."
    mc"That‚Äôs great to hear."
    show sc w2twinsdate t30
    mc"All right, perhaps we should take a look around and have something to eat, shouldn‚Äôt we [s_name]?"
    show sc w2twinsdate t31
    s"Yes, yes we should."
    show sc w2twinsdate t40
    lily"Okay guys, we‚Äôll see you both very soon."
    # (Lily and Ivy leave)"
    show sc w2twinsdate t31
    s"Let‚Äôs go and find a free table [y_name]. Then we can have some dinner and drinks and talk."
    mc"Sounds like a plan."
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    # (screen goes blank)"
    scene sc w2twinsdate t60
    with dissolve
    play ambient "sound effects/02/01/People_Talking_in_Background_Ambience.mp3" loop fadein 1.0
    s"So, are you as surprised as I am that we‚Äôve been invited to someone else‚Äôs pre-wedding party?"
    mc"Yeah, I am. I never would have guessed that this is where we‚Äôd be going tonight."
    mc"It‚Äôs just as well we dressed up!"
    show sc w2twinsdate t61
    s"Haha, it‚Äôs very sweet of the two people getting married to allow us to be here."
    show sc w2twinsdate t64
    s"I wonder who the celebrity is that‚Äôs getting married in town this weekend?"
    show sc w2twinsdate t60
    mc"I was wondering that myself."
    mc"It could be just about anybody, but if they wanted to keep their identities secret, then they must be a pretty big deal."
    show sc w2twinsdate t59
    s"Yeah, they must be."
    show sc w2twinsdate t70
    s"(Sigh‚Ä¶)"
    # (Friend looks down about something)"
    mc"Are you all right [s_name]? What‚Äôs got you down?"
    s"Sorry [y_name]."
    if v_w2_ashley_house:
        show sc w2twinsdate t59
        s"I don‚Äôt mean to be like this, but it‚Äôs still playing on my mind that you were over at my Mom‚Äôs house today."
        s"I know that this isn‚Äôt the time or the place to discuss this, but I can‚Äôt stop thinking about it."
        show sc w2twinsdate t71
        mc"What is it about your mother that troubles you the most [s_name]? Come on, you can tell me."
        show sc w2twinsdate t59
        s"I don‚Äôt know if I can. It‚Äôs too personal, and I don‚Äôt want it to potentially ruin our night."
        show sc w2twinsdate t60
        mc"[s_name], I really think you should consider mending your relationship with your Mom. Life‚Äôs too short to hold a grudge."
        mc"I‚Äôm sure whatever your Mom has done or said to you, her intentions might have been good initially."
        mc"(I really want to tell [s_name] the real reason why Ashley kept us apart, but I know I can‚Äôt do that. I promised her I wouldn‚Äôt.)"
    else:
        show sc w2twinsdate t70
        s"I don‚Äôt mean to be like this, but I‚Äôve had my Mom on my mind all day."
        s"I know that this isn‚Äôt the time or the place to discuss this, but I can‚Äôt stop thinking about her and the problems we‚Äôve had of late."
        show sc w2twinsdate t71
        mc"What is it about your mother that troubles you the most [s_name]? Come on, you can tell me."
        show sc w2twinsdate t59
        s"I don‚Äôt know if I can. It‚Äôs too personal, and I don‚Äôt want to potentially ruin our night."
        show sc w2twinsdate t60
        mc"[s_name], I really think you should consider mending your relationship with your Mom. Life‚Äôs too short to hold a grudge."
        mc"I‚Äôm sure whatever your Mom has done or said to you, her intentions might have been good initially."
    show sc w2twinsdate t71
    s"(If only [y_name] knew the truth about what my argument with my mother is mainly about, then he‚Äôd understand why I‚Äôm so angry at her.)"
    show sc w2twinsdate t65
    s"(But if he thinks that I should try and fix things with her, then I really should take the time to do that.)"
    show sc w2twinsdate t59
    s"I suppose so."
    show sc w2twinsdate t60
    mc"You know the one thing I wish I could have more than anything in this world?"
    s"No, what is it?"
    mc"I wish I could have one more day with my Mom. I know what happened to her couldn‚Äôt have been avoided."
    mc"But still, that‚Äôs what I‚Äôd wish for."
    show sc w2twinsdate t70
    s"(Sigh‚Ä¶)"
    s"Hmm‚Ä¶ I see your point. Sorry for being such a downer on our night out together."
    show sc w2twinsdate t59
    s"You must be sick of hearing about my issues with my Mom, and also having to listen to me go on about Brodie too, huh? "
    mc"No, not at all. It‚Äôs just life, isn‚Äôt it?"
    show sc w2twinsdate t60
    mc"Besides, we still have plenty of time to turn things around and make it a night to remember!"
    mc"We have our dinner and drinks all paid for, we‚Äôre among a lot of people who definitely know how to have a good time..."
    mc"And after all the work we‚Äôve done at the hotel so far, you and I deserve a night out to relax and have fun, right?"
    show sc w2twinsdate t62
    s"Yeah, absolutely!"
    # (Friend smiles)"
    show sc w2twinsdate t60
    mc"A smile, well that‚Äôs a good start."
    show sc w2twinsdate t61
    s"Oh shut up!"
    mc"Hahaha!"
    # [Say nothing / Compliment her]"
    menu:
        "Say nothing":
            show sc w2twinsdate t95
            # (scene continues)"
        "Compliment her"(wt="Best choice"):
            show sc w2twinsdate t60
            mc"[s_name]?"
            s"Yeah [y_name]?"
            mc"I just wanted to say, you look incredible tonight. And Brodie‚Äôs a fool if he can‚Äôt see what he might be giving up."
            show sc w2twinsdate t63
            $ s_points = change_stat(s_points,1,s_name)
            s"Oh, thank you [y_name]." #+1 FRIEND POINT
            # (friend plays with her hair while the MC looks at her)"
            # (scene continues)"

    # (The Twins return)"
    show sc w2twinsdate t95
    lily"Hey you two, are you enjoying yourselves?"
    show sc w2twinsdate t89
    s"Yes, very much so!"
    show sc w2twinsdate t97
    mc"I agree."
    show sc w2twinsdate t74
    show screen scr_rewards("sc w2twinsdate t74b","v_rewards_twins_1")
    mc"You and your sister have done quite well with what you‚Äôve accomplished here."
    hide screen scr_rewards
    show sc w2twinsdate t97
    mc"The bride and groom must be really happy with the quality service that you‚Äôve provided them."
    show sc w2twinsdate t75
    ivy"That would be bride and bride actually."
    show sc w2twinsdate t74
    mc"Excuse me?"
    ivy"The couple who are getting married, well they‚Äôre both women."
    mc"Oh, this is a lesbian wedding?"
    show sc w2twinsdate t97
    lily"Our understanding is that both women are openly bisexual, but they obviously love each other enough to want to be married to each other."
    mc"Interesting‚Ä¶"
    mc"I have to ask, how did you manage to secure such a high profile event?"
    mc"I imagine that there would have been stiff competition in the party planning market, especially when celebrities are involved."
    show sc w2twinsdate t99
    lily"Well, we got pretty lucky on this one."
    show sc w2twinsdate t93
    lily"Ivy and I know the hotel staff and management here pretty well..."
    lily"And they gave us a heads up that a celebrity was here in Sunshine Bay a few months ago, looking at places where they could have tonight‚Äôs party, and also the wedding this weekend."
    show sc w2twinsdate t99
    lily"Once they made inquiries about the hotel and this events room, they recommended our business for catering and hosting the events."
    lily"A few days later, we received an email from one of the girls that is getting married, asking if we were available."
    show sc w2twinsdate t78
    ivy"Lily and I were over the moon to be asked, and even more ecstatic when we discovered that one of the girls was a celebrity."
    mc"That‚Äôs an incredible story."
    show sc w2twinsdate t73
    ivy"You‚Äôre also right in saying that there is plenty of competition..."
    ivy"Not just between people who organise and plan these functions like me and my sister do, but also the various hotels who offer to host these glamorous events."
    show sc w2twinsdate t80
    ivy"Actually, one of the hotels that were interested and tried to persuade the wedding couple into changing the location this week was Brodie‚Äôs father‚Äôs hotel [s_name]."
    show sc w2twinsdate t90
    s"Oh, really?"
    show sc w2twinsdate t93
    lily"Yeah, and you‚Äôll like this."
    lily"The wedding couple was not overly impressed by how pushy they were with trying to change their minds."
    show sc w2twinsdate t95
    lily"I also think they decided to go with us because of our long list of clients, and also because of our impeccable recent history and client feedback."
    show sc w2twinsdate t90
    s"I suppose it's a good thing that this hotel beat out Seascape for the hosting rights."
    # (Friend takes a big swig of her drink)"
    show sc w2twinsdate t100
    mc"(Hmm‚Ä¶ It didn‚Äôt seem as though [s_name] wanted to hear about Brodie or his father.)"
    mc"(And she‚Äôs already had a fair bit to drink since we got here. I better ease up myself.)"
    mc"(I‚Äôll have to keep a close eye on her, so she doesn‚Äôt consume too much tonight.)"
    show sc w2twinsdate t82
    ivy"Say, I‚Äôve got an idea."
    show sc w2twinsdate t78
    ivy"Why don‚Äôt we show these two around the place, to give them a better idea of just how much influence we‚Äôve had on making tonight happen?"
    show sc w2twinsdate t93
    lily"That‚Äôs an excellent idea."
    show sc w2twinsdate t97
    mc"Are you sure? I mean, only if you have the time to ladies."
    show sc w2twinsdate t74
    ivy"Yeah, the party‚Äôs in full flow now, and the only thing we have to worry about is the end of the night when we take some notes for our post-event analysis."
    ivy"But for now, we have time."
    show sc w2twinsdate t93
    lily"Maybe one of us can show [s_name] around, while the other can escort [y_name]."
    show sc w2twinsdate t85
    s"That‚Äôs a good idea."
    show sc w2twinsdate t84
    s"So who do you want to go with [y_name]?"
    mc"Oh‚Ä¶ Well‚Ä¶"
    mc"(Hmm‚Ä¶ Who should I go with?)"
    # [Ivy / Lily]"
    menu:
        "Ivy"(wt="Favour Ivy"):
            $ v_w2_twins_ivy = True
            show sc w2twinsdate t73
            mc"How about you go with Lily, [s_name]."
            mc"And Ivy can show me just how much time and work that they have put in, just to make tonight happen."
            show sc w2twinsdate t74
            ivy"Good decision [y_name]. I have plenty to tell you, so be sure to take some mental notes."
            show sc w2twinsdate t88
            s"(Hmm‚Ä¶ I wonder why he chose Ivy and not Lily?)"
            scene sc w2twinsdate t53
            lily"Come on [s_name], let me show you some of the decorations and designs that I personally chose."
            show sc w2twinsdate t31
            s"We‚Äôll see you a bit later guys!"
            # (Friend and Lily walk away, friend giving the MC one last look)"
            show sc w2twinsdate t119
            ivy"So, are you ready to learn more about what makes me and Lily so successful?"
            show sc w2twinsdate t122
            show screen scr_rewards("sc w2twinsdate t122b","v_rewards_twins_3")
            mc"Yes, most certainly. Please, lead the way."
            hide screen scr_rewards
            show sc w2twinsdate t123
            ivy"How gentlemanly of you."
            stop ambient fadeout 1.0
            # (MC offers his arm, for Ivy to hold)"
            scene black
            with dissolve
            scene black
            with Pause (2)
            # (Ivy links her arms with his)"
            # (Ivy stands with the MC at one of the stand-up tables, close to the stage)"
            scene sc w2twinsdate t111
            with dissolve
            play ambient "sound effects/02/01/People_Talking_in_Background_Ambience.mp3" loop fadein 1.0
            mc"So what did you personally organise for tonight‚Äôs party Ivy?"
