label lb_w2_nicole_chat_mc:
    # Day 4 (MOW) 24 - Nicole chats with MC, suggests that they have an open relationship"
    # SCENE BEGINS"
    # (The MC sits on the edge of his bed, tying his shoes, about to get ready for his night out with Victoria)"
    scene sc w2gettingreadyvic v03
    with dissolve
    mc"(Why am I so nervous? It‚Äôs not like tonight is a real date.)"
