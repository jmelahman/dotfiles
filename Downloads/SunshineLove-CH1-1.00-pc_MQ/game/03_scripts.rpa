    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2ashleyhouse a93","sc w2ashleyhouse a93x","v_pt_image_index_w2_15")
    ash"Oh, hey, how are you?"
    ash"No, this isn‚Äôt a bad time. Uh, just give me a moment Sheila, I‚Äôm just gonna put you on hold."
    hide screen scr_peeping_tom
    # (Ashley puts her phone down)"
    show sc w2ashleyhouse a92
    ash"Sorry [y_name], I don‚Äôt mean to be rude, but I‚Äôm going to have to ask you to leave."
    ash"This woman is from the local newspaper, and she‚Äôs doing a phone call interview with me that was pre-scheduled."
    show sc w2ashleyhouse a90
    mc"But what about my question? I need to know Ashley."
    ash"And I sincerely want to give you an answer for that [y_name]. Look, I don‚Äôt have the time to discuss this with you now, not in full detail."
    mc"So when then?"
    show sc w2ashleyhouse a91
    ash"How about sometime later this week?"
    ash"There‚Äôs a nice place in town where we can talk in private and where we can have some dinner together."
    ash"Consider it on me to make up for this abrupt ending to our talk today."
    show sc w2ashleyhouse a90
    mc"Hmm‚Ä¶ I don‚Äôt know. I‚Äôm not sure I can get away from the hotel without lying to [s_name], or her being angry if I were to tell her the truth."
    show sc w2ashleyhouse a92
    ash"Well it‚Äôs your choice [y_name]."
    ash"If you want to know more, we can do something together, just you and me, by the end of the week. Or not."
    ash"So what‚Äôs it gonna be?"
    mc"(Shit! If I‚Äôm going to help to fix things between [s_name] and her Mom, then I really need to know the answer to my question.)"
    show sc w2ashleyhouse a90
    mc"All right fine, we‚Äôll do dinner."
    show sc w2ashleyhouse a91
    ash"Excellent. I‚Äôll call you in a couple of days to let you know which night this week works best for me."
    ash"And by the way, your scooter is in the garage. Please help yourself to it [y_name]."
    mc"Thanks Ashley, I really do appreciate it."
    show sc w2ashleyhouse a93
    mc"(Oh shit, the scooter! I was meant to ask her to show me how to ride it.)"
    mc"(How the hell am I going to do that, now that she‚Äôs on the phone and is asking me to leave?)"
    # ‚ÄúAdd these lines if the player fixed the shower head‚Äù"
    if v_w2_ashley_step1 and v_w2_ashley_step2 and v_w2_ashley_step3:
        show sc w2ashleyhouse a91
        ash"Oh and [y_name], before you go."
        # (Ashley kisses the MC on the lips)"
        show sc w2ashleyhouse a94
        play sound "sound effects/03/01/kiss_and_moan_sound_effect02.mp3"
        ash"Mmm‚Ä¶"
        stop sound
        # (Ashley smiles)"
        show sc w2ashleyhouse a91
        mc"What um‚Ä¶ What was that for??"
        ash"For fixing my shower of course. And for keeping me company."
        ash"It‚Äôs not everyday a guy comes over to my place and manages to impress me."
        ash"So you more than deserved that."
        mc"Uh, you‚Äôre welcome?"
        mc"(She just kissed me! Like, actually kissed me! What the fucking fuck is going on here??)"
        ash"Haha, you better run along, you don‚Äôt want to keep my daughter waiting, remember?"
        mc"Right, yes. I‚Äôll talk to you soon."
    ash"Bye [y_name]."
    # (Ashley turns, resumes her phone call)"
    show sc w2ashleyhouse a93
    mc"(Shit! I‚Äôm going to have to either learn how to ride that scooter, or push the damn thing all the way back to the hotel.)"
    mc"(I sure as hell can‚Äôt leave it here, otherwise Ashley will wonder why I didn‚Äôt take it with me.)"
    mc"(Man, what a weird hour or so it‚Äôs been. And Ashley is carrying on with her day as though nothing happened.)"
    mc"(What is her deal?)"
    mc"(I guess I won‚Äôt find out more until I see her later this week.)"
    mc"(It‚Äôs going to be difficult to explain this one to [s_name].)"
    mc"(And she‚Äôs no doubt going to ask me why the hell I was at her mother‚Äôs house, and how it all came about.)"
    mc"(But I promised not to keep anything from [s_name], and to not lie to her.)"
    mc"(I better go back to the hotel now, and to quickly grab this scooter in Ashley‚Äôs garage‚Ä¶)"
    stop ambient fadeout 1.0
    scene black
    with dissolve
    scene black
    with Pause (2)
    if _in_replay:
        scene black
        with dissolve
        scene black
        with Pause (2)
    $ persistent.replay_w2_ashley_shower = False
    $ renpy.end_replay()









label lb_w2_sow_jazmin_room:
    # Day 4 (SOW) 12 - Friend shows the MC the physio and therapy room with Jazmin"
    # SCENE BEGINS"
    # (MC on the scooter)"
    # (scooter sounds required here)"
    # (MC pushes the scooter along the road towards the hotel)"
    if v_w2_ashley_house:
        scene sc w2ashleyhouse a95
        with dissolve
        play ambient "sound effects/01/01/Birds_in_trees_sounds_effects1.mp3" loop fadein 1.0
        mc"(Man, I sure know how to make things more difficult for myself!)"
        # (a shot of the MC approaching the hotel)"
        show sc w2ashleyhouse a97
        mc"(Thank god, I‚Äôm almost there.)"
        show sc w2ashleyhouse a98
        mc"(Despite not being able to ask her how to ride this thing, at least Ashley has given me a lot to think about.)"
        show sc w2ashleyhouse a97
        mc"(I definitely don‚Äôt want to hide anything from [s_name], so I‚Äôm going to tell her that I was at her mother‚Äôs place.)"
        mc"(She‚Äôs probably not going to like to hear this from me, but they need to settle their differences in order for there not be any more complications moving forward.)"
        show sc w2ashleyhouse a96
        mc"(It was so easy to be upset with Ashley for keeping me and [s_name] apart, but I can kind of understand why she did it, now that she's told me everything.)"
        mc"(Well, almost everything.)"
        mc"(I don‚Äôt know what I‚Äôll say to my Dad the next time I speak to him. I‚Äôm still in such disbelief that he could do that to her.)"
        # (MC arrives at the hotel)"
        show sc w2ashleyhouse a95
        mc"(All right, time to face the music. I should just tell [s_name] as soon as I see her.)"
        mc"(And while things are good between us, perhaps now is the best time to speak up‚Ä¶)"
        stop ambient fadeout 1.0
        scene black
        with dissolve
        scene black
        with Pause (2)
    scene sc w2kitchena a12
    with dissolve
    s"Hey [y_name]! You're back!"
    # (MC goes over to her)"
    show sc w2kitchena a17
    mc"Hey [s_name], I got all the stuff that you asked for."
    show sc w2kitchena a12
    s"Awesome!"
    if v_w2_ashley_house:
        show sc w2kitchena a11
        mc"[s_name], I really need to tell you something. It‚Äôs kind of important."
        show sc w2kitchena a10
        s"Hang on, hold that thought [y_name]."
    show sc w2kitchena a12
    s"Come with me, there‚Äôs something that I‚Äôm dying to show you!"
    # (Friend grabs the MC‚Äôs hands, a really excited look on her face)"
    show sc w2kitchena a10
    mc"(Hmm‚Ä¶ Whatever it is, she seems incredibly excited by it!)"
    if v_w2_ashley_house:
        mc"(I guess I‚Äôll have to wait a little longer before I tell [s_name] where I‚Äôve been‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)

    # (Friend shows the MC the NEW physiotherapy room. It looks brand new)"
    scene sc w2jazminroom j04
    with dissolve
    s"So‚Ä¶ What do you think of our brand-new physiotherapy and beauty room?"
    show sc w2jazminroom j02
    mc"Oh wow! This room looks amazing [s_name]."
    show sc w2jazminroom j01
    mc"Did you do all of this by yourself?"
    show sc w2jazminroom j04
    s"Haha, not exactly. I had some help."
    # (Jazmin appears in fitness clothing)"
    show sc w2jazminroom j12
    jaz"Hey [y_name]. Do you like the look of your new hotel health centre?  "
    mc"Yeah, I was just telling [s_name] how incredible this room looks."
    mc"What have you two been up to since I was gone?"
    show sc w2jazminroom j10
    s"Well, I went to see Jazmin before I went out this morning, just as I planned to."
    show sc w2jazminroom j02
    s"She proposed an idea to me for the layout for this room."
    s"Jazmin spent a few hours last night, creating a rough design on her laptop for how she wanted it to be designed."
    show sc w2jazminroom j12
    jaz"I was able to get a good look at this room yesterday after I took a swim, and upon seeing what was already in here, the ideas in my head began to flow."
    show sc w2jazminroom j19
    jaz"I relayed some of those ideas to [s_name] this morning, and she agreed to let me redesign it."
    show sc w2jazminroom j13
    jaz"The room is still missing a few important components, like extra fitness equipment, restocking of the massage and therapy room, and you‚Äôll need a new water filter."
    show sc w2jazminroom j12
    jaz"But aside from that, it would be ready to reopen as soon as you guys are happy for that to happen."
    show sc w2jazminroom j01
    s"So what do you think? Jazzy‚Äôs done well, hasn‚Äôt she?"
    mc"Oh yeah, she‚Äôs done superbly."
    show sc w2jazminroom j02
    s"And just to say thanks to her for the work she has done here, I‚Äôve offered Jazmin to stay in the hotel for another week."
    s"Are you okay with that?"
    # (Jazzy looks at the MC)"
    # [Be sarcastic / Be appreciative]"
    menu:
        "Be sarcastic":
            show sc w2jazminroom j01
            mc"Hmm‚Ä¶ I don‚Äôt know about that [s_name]."
            mc"We wouldn‚Äôt want Jazmin to outstay her welcome, would we?"
            show sc w2jazminroom j03
            s"Huh?"
            # (Jazzy doesn‚Äôt look impressed)"
            show sc w2jazminroom j14
            mc"I‚Äôm kidding! I was only joking ladies."
            $ jazmin_points = change_stat(jazmin_points,-2,"Jazmin")
            jaz"Right‚Ä¶" #-2 JAZZY POINTS"
            show sc w2jazminroom j10
            jump lb_w2_sow_jazmin_room_1

            label lb_w2_sow_jazmin_room_1:
            s"Don‚Äôt mind [y_name], Jazmin. He sometimes has a weird sense of humour."

            label lb_w2_sow_jazmin_room_2:
            show sc w2jazminroom j02
            mc"(Huh? I do?)"
        "Be appreciative"(wt="Best choice"):
            show sc w2jazminroom j12
            if persistent.v_xray_enabled:
                show screen scr_peeping_tom("sc w2jazminroom j12","sc w2jazminroom j12x","v_pt_image_index_w2_16")
            mc"Yeah, I‚Äôm very happy for Jazmin to stay after what she‚Äôs done in here."
            mc"It would be crazy to let her stay anywhere else, as someone might snatch her away from us!"
            hide screen scr_peeping_tom
            show sc w2jazminroom j15
            jaz"Aww, that‚Äôs nice of you to say [y_name]."
            show sc w2jazminroom j19
            $ jazmin_points = change_stat(jazmin_points,2,"Jazmin")
            jaz"But I‚Äôm just getting started." # +2 JAZZY POINTS"
            # (scene continues)"
    show sc w2jazminroom j13
    jaz"I have a lot more great ideas, but for now, I think I need to take a break and use some of the afternoon to relax."
    show sc w2jazminroom j11
    s"Of course, take all the time that you need."
    show sc w2jazminroom j01
    s"Um, [y_name] and I are going into town tonight for a function with a couple of business owner friends."
    show sc w2jazminroom j09
    s"Are you sure you‚Äôre going to be okay here at the hotel without us?"
    show sc w2jazminroom j22
    jaz"Yeah, I‚Äôll be fine guys. I might find a local place where I can get some dinner."
    show sc w2jazminroom j10
    s"Great! Mister Roshi, the hotel maintenance guy will be onsite if you need anything."
    s"I‚Äôll let him know that you‚Äôre staying here in the hotel."
    show sc w2jazminroom j19
    jaz"Thanks. Okay, I‚Äôll leave you both to it as I‚Äôm sure you have a lot of work to do."
    show sc w2jazminroom j12
    jaz"Bye guys."
    mc"Bye Jazmin."
    # (Jazzy left)"
    show sc w2jazminroom j02
    s"She is such a godsend, isn‚Äôt she?"
    mc"Yeah, she certainly is."
    show sc w2jazminroom j01
    mc"So I presume you‚Äôre definitely going to ask Jazmin to run the health centre as soon as we re-open it, right?"
    show sc w2jazminroom j02
    s"I can‚Äôt think of anyone who would be more suitable or qualified for the role. So yes, I think I will."
    s"And after what she‚Äôs done with the room so far, it would be hard for me to say no to her now."
    mc"Yeah, that‚Äôs exactly right."
    show sc w2jazminroom j03
    s"Hey, why did you take so long to get back? It felt like you took ages!"

    if v_w2_ashley_house == False:
        # ‚ÄúIf the player called Yuki, but left a message on her answering service‚Äù"
        show sc w2jazminroom j01
        mc"You know all of that stuff that you asked me to get? Well, it was quite heavy to carry and walk all the way back here."
        show sc w2jazminroom j07
        s"Oh, I‚Äôm so sorry about that [y_name], I wasn‚Äôt thinking at all. I should have offered you my scooter to drive to the mall."
        show sc w2jazminroom j01
        mc"Yeah, about that."
        mc"I spoke to Yuki the other day, and she said that she has one at her father‚Äôs house that I could borrow while I‚Äôm in town."
        mc"Apparently, Mister Roshi doesn‚Äôt use it anymore."
        show sc w2jazminroom j07
        s"That‚Äôs really sweet of her. So when are you going over there to get it?"
        show sc w2jazminroom j01
        mc"Yuki said that she‚Äôll call me later in the week to let me know when the best time is to go around to her family‚Äôs house to pick it up."
        mc"But that‚Äôs good news, right?"
        show sc w2jazminroom j02
        s"Yeah, it‚Äôs terrific news!"
        # (screen goes blank)"

    else:
        # ‚ÄúIf the player visited Ashley, then the MC will tell her‚Äù"
        show sc w2jazminroom j05
        s"And what are those keys that you have in your hand for?"
        # (Friend points to the keys in the MC‚Äôs hand, which are for the scooter)"
        show sc w2jazminroom j01
        mc"That‚Äôs what I wanted to talk to you about. I um, I have a new scooter."
        show sc w2jazminroom j02
        s"You do? That‚Äôs awesome [y_name]! So are you like renting it or something?"
        show sc w2jazminroom j01
        mc"Uh, not exactly. I‚Äôm borrowing it from someone while I‚Äôm here in Sunshine Bay."
        s"You borrowed it? From who?"
        mc"Um, from Ashley, your Mom."
        show sc w2jazminroom j24
        s"My Mom?? How on earth did this happen?"
        show sc w2jazminroom j03
        mc"It‚Äôs a long story, but, do you remember the other day when you and your Mom had that argument down by the beach?"
        s"Yeah, what about it?"
        mc"Well after you walked off, I sat down and had a long chat with her as you know."
        mc"But I didn‚Äôt just ask about the hotel before and after she handed over the reins to you."
        show sc w2jazminroom j07
        s"What else did you talk to her about?"
        show sc w2jazminroom j01
        mc"I wanted to find out why there was so much friction between you two. But I didn‚Äôt get any answers from her."
        mc"I‚Äôve wanted to ask you myself, but I know it‚Äôs not been easy for you to talk about it."
        show sc w2jazminroom j03
        s"Oh‚Ä¶"
        mc"And then the other day, I called her to give me a lift back here when you asked me to get that toolbox for you."
        show sc w2jazminroom j07
        s"You did? Why did you call her? Why didn‚Äôt you just ask me to come and get you?"
        show sc w2jazminroom j03
        mc"Because I didn‚Äôt want to disturb you. You were showing Jazmin around town at the time, and I knew that was important to you."
        show sc w2jazminroom j07
        s"Oh [y_name], I had no idea that you needed help."
        s"But you still should‚Äôve called me, as I‚Äôm sure we could‚Äôve worked something out."
        show sc w2jazminroom j03
        s"So, what else have you talked with my mother about?"
        mc"Not much. Just more about you, the hotel, and the past, kind of."
        s"Did she tell you everything you wanted to know?"
        mc"Not really, no."
        mc"(Aside from my Dad being a cheating asshole.)"
        show sc w2jazminroom j01
        s"And what about today? Did you meet somewhere to get the scooter from her?"
        mc"Yes I did. I um, I went over to her house."
        show sc w2jazminroom j24
        s"You went to her house?? Why??"
        show sc w2jazminroom j03
        mc"Because that‚Äôs where the scooter was. As much as I don‚Äôt want to admit this [s_name], but you were right."
        s"About what?"
        mc"I really do need a scooter, and I realise now that only suckers choose to walk in this town."
        s"Yeah, they certainly do."
        # (Friend looks away from the MC)"
        show sc w2jazminroom j23
        s"(Sigh‚Ä¶)"
        s"I can‚Äôt believe you went to see her. My Mom of all people."
        # [Reassure her / Tell her to trust you]"
        menu:
            "Reassure her"(wt="Best choice"):
                show sc w2jazminroom j23
                mc"(I know she‚Äôs pissed at me, but she needs to know why I did this and why I‚Äôve told her everything, just like Ashley said I should.)"
                # (MC grabs Friend by the side of each arm so he has her attention)"
                show sc w2jazminroom j01
                mc"Listen to me [s_name]..."
                mc"The last person I want to hurt is you, do you hear me? The last person I want to see upset is also you."
                mc"And for us to have a trusting relationship, then that means me not keeping any secrets from you, and no more lying."
                mc"And that‚Äôs the sole reason why I‚Äôve told you everything, okay?"
                mc"But if you don‚Äôt want me to see your Mom again, then I won‚Äôt.?"
                # (Friend looks up at the MC)"
                show sc w2jazminroom j05
                s"(Oh, he sounds so sincere and maybe even concerned about how this has made me feel.)"
                s"(He really does care about me, and I think he believed he was trying to do the right thing.)"
                show sc w2jazminroom j02
                s"Okay [y_name], I believe you."
                show sc w2jazminroom j23
                s"I‚Äôm sorry if I got a little worked up about this. It‚Äôs family, you know?"
                show sc w2jazminroom j01
                $ s_points = change_stat(s_points,2,s_name)
                mc"Oh yeah, I definitely know what you mean." #+2 FRIEND POINTS"
                show sc w2jazminroom j03
                s"Look, if you really think you‚Äôre doing the right thing by talking to my Mom or by seeing her, then I won‚Äôt stop you."
                s"Just tell me if you do, all right?"
                mc"I will, I promise."
                show sc w2jazminroom j01
                mc"I want things to be good between you two, and if I can help in any way, then all the better."
                show sc w2jazminroom j23
                s"We‚Äôll see [y_name]."
                s"(I really want to tell him what I know, but now is definitely not the right time.)"

            "Tell her to trust you":
                show sc w2jazminroom j23
                mc"(I know she‚Äôs pissed at me, but I need [s_name] to know that she can trust me.)"
                # (MC grabs Friend by the side of each arm so he has her attention)"
                mc"[s_name]. Look at me."
                # (Friend looks up at the MC)"
                show sc w2jazminroom j01
                mc"I need you to trust me. Why else would I tell you everything I‚Äôve done or where I‚Äôve been? "
                s"Hmm, I guess. So nothing else happened when you over at my Mom‚Äôs house?"
                show sc w2jazminroom j03
                s"And she didn‚Äôt say anything nasty about me?"
                mc"No, of course not."
                $ s_points = change_stat(s_points,-2,s_name)
                mc"(I don‚Äôt think I should tell [s_name] about what happened in the shower this morning. That may not go down well.)"  #-2 FRIEND POINTS"
                show sc w2jazminroom j23
                s"Okay [y_name], I trust you. I‚Äôm sorry if I got a little worked up about this. It‚Äôs family, you know?"
                show sc w2jazminroom j03
                mc"Oh yeah, I definitely know what you mean."
                s"Look, if you really think you‚Äôre doing the right thing by talking to my Mom or by seeing her, then I won‚Äôt stop you."
                s"Just tell me if you do, all right?"
                mc"I will, I promise."
                mc"I want things to be good between you two, and if I can help in any way, then all the better."
                show sc w2jazminroom j23
                s"We‚Äôll see [y_name]."
                s"(I really want to tell him what I know, but now is definitely not the right time.)"
                show sc w2jazminroom j03
                s"All right, can we please just move on from this?"
                mc"I agree."
    # (scene continues)"
    show sc w2jazminroom j01
    s"All right, after I‚Äôve gone through everything you bought from the store and put it all away, we have some more painting to do in a few more of the hotel rooms in the west wing."
    mc"(Sigh‚Ä¶)"
    show sc w2jazminroom j03
    s"Yeah I know, I‚Äôm not looking forward to doing anymore painting either..."
    show sc w2jazminroom j02
    s"But we only have about four more rooms that require a fresh coat, and then that will be all of the west wing completed."
    mc"Okay, if we must‚Ä¶"
    scene black
    with dissolve
    scene black
    with Pause (2)




label lb_w2_sow_mc_night_out:
    # Day 4 (SOW) 13 - MC and friend get ready for their night out with the twins"
    # SCENE BEGINS"
    # (MC and friend in one of the hotel rooms, finishing the last part of the room that they are painting)"
    # (Friend stands at the top of the ladder)"
    scene sc w2paintingroom p01
    with dissolve
    s"There, that should just about do it. How does it look from down there [y_name]?"
    # (The MC stands on the floor)"
    mc"It looks pretty seamless [s_name]."
    show sc w2paintingroom p03
    mc"I can‚Äôt see any noticeable gaps from the work we‚Äôve done in this room."
    mc"I think all we need to do now is to air out the paint smell from all the rooms that we‚Äôve worked on this afternoon."
    show sc w2paintingroom p02
    s"I‚Äôll be sure to keep some of the windows slightly ajar before we head out."
    show sc w2paintingroom p04
    mc"Looks like you‚Äôve got a bit of paint on your arms there [s_name]."
    show sc w2paintingroom p06
    s"Oh! Thanks..."
    show sc w2paintingroom p05
    if persistent.v_xray_enabled:
        show screen scr_peeping_tom("sc w2paintingroom p05","sc w2paintingroom p05x","v_pt_image_index_w2_17")
    s"And you have some on your cheek."
    mc"I do? Where exactly?"
    hide screen scr_peeping_tom
    show sc w2paintingroom p12
    s"Right, here!"
    # (Friend dabs her paintbrush against his cheek, leaving a spot of paint on there.)"
    show sc w2paintingroom p08
    with vpunch
    mc"Oh..."
    show sc w2paintingroom p09
    mc"You‚Äôre going to get it for that!"
    # (MC returns fire by brushing paint across her neck)"
    show sc w2paintingroom p15
    with vpunch
    s"Oh no you didn‚Äôt!"
    show sc w2paintingroom p13
    mc"I did, haha! Care to take another swipe at the other cheek?"
    show sc w2paintingroom p16
    s"Nah, it‚Äôs okay. I‚Äôll get you next time."
    # (Friend drops her guard, to make it look like she‚Äôs given up)"
    show sc w2paintingroom p20
    mc"Huh?"
    show sc w2paintingroom p17
    s"Yeah, we're done here."
    show sc w2paintingroom p18
    mc"Aww, giving up so easily? That‚Äôs a shame. "
    show sc w2paintingroom p19
    s"Yeah, except I haven‚Äôt at all."
    show sc w2paintingroom p14
    with vpunch
    mc"What the!"
    show sc w2paintingroom p10
    s"Haha! Gotcha [y_name]!"
    # (The MC looks unimpressed)"
    show sc w2paintingroom p22
    s"You look like Raggedy Anne gone wrong! Or should I say, Raggedy [y_name]!"
    show sc w2paintingroom p11
    mc"(I‚Äôm trying my best not to laugh, even though I‚Äôd normally be very angry about this!)"
    mc"Hahaha, well played [s_name]."
    show sc w2paintingroom p16
    s"We‚Äôre both going to need to have a bath and to thoroughly clean all this paint off ourselves before we meet up with the twins tonight."
    show sc w2paintingroom p11
    mc"Yeah, sounds like a good idea."
    show sc w2paintingroom p21
    mc"Do you know where we‚Äôre meeting them?"
    show sc w2paintingroom p23
    s"Ivy messaged me earlier and said that it‚Äôs at some hotel function room that they‚Äôre hosting in town."
    s"She was a bit sketchy on any of the other details but I do have an address for where to meet her and Lily."
    show sc w2paintingroom p21
    mc"It sounds as though they want to show us first-hand exactly how they run an event."
    show sc w2paintingroom p16
    s"Yeah, and it‚Äôs also a great chance to see what we can learn from them and what questions to ask. So make sure to keep that in mind."
    show sc w2paintingroom p11
    mc"I will."
    show sc w2paintingroom p16
    s"Okay, you go ahead and take a bath while I pack everything up here."
    show sc w2paintingroom p23
    mc"Are you sure you don‚Äôt want a hand?"
    show sc w2paintingroom p22
    s"Nah, I‚Äôm good. Thanks for your help with this [y_name]. It‚Äôs all coming together, slowly but surely, and a lot of that is thanks to you."
    show sc w2paintingroom p11
    mc"Ah, it was nothing."
    show sc w2paintingroom p16
    s"I‚Äôll see you shortly. Make sure that you pick out something nice to wear, because I‚Äôm sure the twins will be expecting us to look our best."
    show sc w2paintingroom p11
    mc"Oh, sure thing [s_name]. I think I have something just for the occasion‚Ä¶"
    scene black
    with dissolve
    scene black
    with Pause (2)


    # (MC in the bath)"
    scene sc day1evehotel e13
    with dissolve
    mc"(Ahh, this is much better. I think I‚Äôve scrubbed every last speck of paint off.)"
    show sc day1evehotel e13
    mc"(I wonder how tonight will go? But what kind of function could Ivy and Lily be hosting, especially on a weeknight?)"
    mc"(It must be a pretty big deal if they want me and [s_name] to attend it.)"
    show sc day1evehotel e12
    mc"(Hmm‚Ä¶ I haven‚Äôt heard from Nicole today. I hope she‚Äôs all right...)"
    mc"(I can‚Äôt remember if I was meant to call her or if she said that she was going to call me.)"
    show sc day1evehotel e11
    mc"(I better keep my ear out just in case she tries to ring me.)"
    mc"(I‚Äôve been so preoccupied with other things and other people since I arrived here, that Nicole‚Äôs almost become an afterthought.)"
    show sc day1evehotel e12
    mc"(And I don‚Äôt want to feel like I‚Äôm neglecting her in any way.)"
    mc"(I don‚Äôt have time to call her now, otherwise, we might be late for this function.)"
    mc"(If we return home at a decent time, and Nicole hasn‚Äôt contacted me before then, I‚Äôll try to call her.)"
    mc"(But she may not be awake due to the time difference.)"
    mc"(Sigh‚Ä¶ This is all too much for one guy to have to think about.)"
    mc"(Hopefully she understands if I don‚Äôt get a chance to talk to her tonight‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    show sc day1evehotel e07
    s"(Oooh‚Ä¶ Nice, bubbly and warm, just the way I like it.)"
    # (Friend lays in the bath)"
    s"(Mmm‚Ä¶ This is just what I need.)"
    show sc day1evehotel e08
    s"(I wonder if [y_name] has thought much about this morning?)"
    s"(Surely he won‚Äôt want to come to my room if there‚Äôs another thunderstorm anytime soon.)"
    s"(It was nice to have him there next to me when I woke up, even despite where his hand was placed. It was strangely comforting.)"
    show sc day1evehotel e06
    s"(I have to look my best tonight, so I think I‚Äôll go with the stiletto heels, which should make my legs look even sexier in them.)"
    show sc day1evehotel e07
    s"(And I have the ideal dress for this function. At least I think I do. I‚Äôm sure [y_name] will be surprised when he sees me in it‚Ä¶)"
    scene black
    with dissolve
    scene black
    with Pause (2)
    scene sc w2eveready e01
    with dissolve
    # (MC waits in the living room for Friend to come out of the bedroom - he‚Äôs wearing a long-sleeved top with a tie on)"
    mc"(I hope what I‚Äôm wearing is appropriate for tonight.)"
    mc"(It‚Äôs kind of hard to tell what would be best, seeing as I have no idea what kind of function it is that we‚Äôre attending.)"
    mc"(Just as long as I‚Äôm not too over or underdressed compared to what [s_name] is wearing tonight, then I should be fine.)"
    # (Speaking of which, she better hurry up. We don‚Äôt want to be late to this thing.)"
    show sc w2eveready e09
    mc"ARE YOU ABOUT READY TO GO [s_name!u]?"
    show sc w2eveready e06
    s"I‚ÄôM COMING OUT NOW [y_name!u]!"
    show sc w2eveready e08
    mc"(Great. If we leave now, then we should still be able to make a punctual arrival.)"
    show sc w2eveready e02
    s"So‚Ä¶ What do you think?"
    # (Friend poses)"
    show sc w2eveready e10
    mc"(Whoah‚Ä¶ I really don‚Äôt know what to say. But I better come up with a reply, and fast!)"
    # [You look stunning / It‚Äôs a bit much]"
    show sc w2eveready e02
    menu:
        "You look stunning"(wt="Best choice"):
            mc"You look stunning [s_name]."
            show sc w2eveready e14
            s"Really? Are you sure it‚Äôs not too much?"
            # (Friend turns to show the MC the side and some of the back of her dress)"
